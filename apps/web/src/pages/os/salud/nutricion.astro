---
export const prerender = false;
import OSLayout from '../../../layouts/OSLayout.astro';
import OSSaludNutricion from '../../../os/components/salud/OSSaludNutricion';
import OSSaludNav from '../../../os/components/salud/OSSaludNav.astro';
---

<OSLayout title="Nutrición">
  <div class="os-fade-up">
    <div style="margin-bottom:1rem;">
      <p class="os-eyebrow" style="margin-bottom:6px;">Salud · Nutrición</p>
      <h1 class="os-h1">Nutrición</h1>
    </div>
    <OSSaludNav activo="nutricion" />
    <OSSaludNutricion client:load />
  </div>
</OSLayout>
