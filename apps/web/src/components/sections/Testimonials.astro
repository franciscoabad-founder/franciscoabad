<section class="py-12 md:py-20 bg-bg-primary">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-8">
    <div class="mb-14" data-reveal>
      <p
        class="font-montserrat font-semibold uppercase tracking-[3px] text-[11px] mb-4"
        style="color: hsl(var(--ember));"
      >
        TESTIMONIOS
      </p>
      <h2
        class="font-montserrat font-black text-[32px] lg:text-[40px] leading-[1.15]"
        style="color: hsl(var(--text-primary));"
      >
        Lo que dicen quienes<br />han trabajado conmigo
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div
          class="rounded-lg p-6 flex flex-col gap-4"
          data-reveal
          style="background-color: hsl(var(--bg-elevated)); border: 1px solid rgba(138,130,121,0.15); border-left: 2px solid hsl(var(--ember));"
        >
          <a
            href={t.linkedIn}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3.5 no-underline"
          >
            <img
              src={t.photo}
              alt={t.name}
              width="72"
              height="72"
              loading="lazy"
              decoding="async"
              class="rounded-full object-cover flex-shrink-0"
              style="width: 72px; height: 72px; border: 2px solid hsl(var(--ember));"
            />
            <div class="min-w-0">
              <p
                class="font-montserrat font-semibold text-[15px] m-0 leading-[1.3]"
                style="color: hsl(var(--text-primary));"
              >
                {t.name}
              </p>
              <p
                class="font-inter text-[12px] my-[3px] leading-[1.4]"
                style="color: hsl(var(--ember));"
              >
                {t.role}
              </p>
              <p
                class="font-inter text-[12px] m-0 leading-[1.4]"
                style="color: hsl(var(--text-muted));"
              >
                {t.company}
              </p>
            </div>
          </a>

          <p
            class="font-inter text-[14px] leading-[1.7] m-0"
            style="color: hsl(var(--text-primary));"
          >
            <span
              class="font-bold text-[20px] leading-none mr-0.5"
              style="color: hsl(var(--ember));"
            >&ldquo;</span>
            {t.quote}
          </p>
        </div>
