---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
import OSJuego from '../../os/components/OSJuego';
import '../../styles/os-conductual.css';
---

<OSLayout title="Juego">
  <div class="os-fade-up" data-modulo="habitos">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:1rem;position:relative;z-index:2;">
      <div>
        <p class="m-eyebrow">Sistema // Juego</p>
        <h1 class="m-h1">Juego</h1>
      </div>
      <a
        href="/os/habitos"
        style="font-size:11px;color:var(--m-muted);text-decoration:none;font-family:var(--m-font-mono);font-weight:700;text-transform:uppercase;letter-spacing:0.06em;white-space:nowrap;"
      >
        [ ← Hábitos ]
      </a>
    </div>
    <div style="position:relative;z-index:2;">
      <OSJuego client:load />
    </div>
  </div>
</OSLayout>
