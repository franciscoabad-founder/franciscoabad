---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
import OSHabitos from '../../os/components/OSHabitos';
---

<OSLayout title="Hábitos">
  <div class="os-fade-up">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:1rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Sistema · Hábitos</p>
        <h1 class="os-h1">Hábitos</h1>
      </div>
      <a
        href="/os/habitos/journeys"
        style="font-size:12px;color:var(--os-accent-light);text-decoration:none;font-family:var(--os-font-display);font-weight:600;white-space:nowrap;"
      >
        Ver journeys →
      </a>
    </div>
    <OSHabitos client:load />
  </div>
</OSLayout>
