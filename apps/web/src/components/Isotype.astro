---
interface Props {
  height?: number;
  class?: string;
}
const { height = 36, class: className = "" } = Astro.props;
const width = Math.round(height * 0.8);
---
<svg
  viewBox="0 0 32 40"
  width={width}
  height={height}
  fill="none"
  stroke="currentColor"
  stroke-width="3"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={`text-ember ${className}`}
  aria-label="Francisco Abad"
  xmlns="http://www.w3.org/2000/svg"
>
  <line x1="16" y1="2" x2="2" y2="38" />
  <line x1="16" y1="2" x2="30" y2="38" />
  <line x1="8" y1="26" x2="24" y2="26" />
</svg>
