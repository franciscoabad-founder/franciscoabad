# Copia este archivo a .env y completa los valores reales.
# .env NUNCA sube a Git.

# Resend — correos transaccionales
RESEND_API_KEY=

# URL pública de descarga del Kit IA (Supabase Storage o donde lo alojes)
KIT_DOWNLOAD_URL=

# Cortex — alta de testers desde el OS personal
# Token admin compartido con app-cortex.franciscoabad.com (endpoint POST /api/os/invitar)
CORTEX_ADMIN_TOKEN=
# URL base de la app de Cortex (default: https://app-cortex.franciscoabad.com)
CORTEX_APP_URL=
