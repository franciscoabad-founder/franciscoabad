---
export const prerender = false;

import OSLayout from '../../layouts/OSLayout.astro';
import { redes } from '../../os/data/redes';
import OSContenidoEditor from '../../os/components/OSContenidoEditor';

const redLabel: Record<string, string> = { linkedin: 'LinkedIn', instagram: 'Instagram', youtube: 'YouTube' };
const redColor: Record<string, string> = { linkedin: 'var(--os-accent)', instagram: 'var(--os-accent-light)', youtube: 'var(--os-muted)' };
const redIcon: Record<string, string>  = { linkedin: 'work', instagram: 'photo_camera', youtube: 'smart_display' };

const trendIcon: Record<string, string> = {
  up:   '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>',
  down: '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 17 13.5 8.5 8.5 13.5 2 7"/><polyline points="16 17 22 17 22 11"/></svg>',
  flat: '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>',
};
---

<OSLayout title="Redes">
  <div class="os-fade-up">

    <!-- Header -->
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:0.5rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Distribucion</p>
        <h1 class="os-h1">Redes y Contenido</h1>
      </div>
      <span class="os-pill os-tag" style="background:rgba(232,234,240,0.06);">Demo · conectar APIs pendiente</span>
    </div>

    <!-- Social insight cards -->
    <div class="os-social-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:10px;margin-bottom:1.5rem;">
      {redes.map((r) => (
        <div class="os-card-2" style={`border-top:2px solid ${redColor[r.red]};`}>
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
            <p style={`display:flex;align-items:center;gap:6px;font-family:var(--os-font-display);font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:${redColor[r.red]};margin:0;`}>
              <span class="material-symbols-outlined" style="font-size:15px;">{redIcon[r.red]}</span>
              {redLabel[r.red]}
            </p>
            <span set:html={trendIcon[r.tendencia]} />
          </div>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:0.875rem;">
            <div>
              <p class="os-kpi-label" style="margin:0 0 3px;">Seguidores</p>
              <p class="os-num" style="font-size:1.25rem;margin:0;line-height:1;">{r.seguidores.toLocaleString('es-EC')}</p>
            </div>
            <div>
              <p class="os-kpi-label" style="margin:0 0 3px;">Alcance / sem</p>
              <p class="os-num" style="font-size:1.25rem;margin:0;line-height:1;">{r.alcance_semana.toLocaleString('es-EC')}</p>
            </div>
          </div>

          <div style="padding-top:0.75rem;border-top:1px solid var(--os-line-soft);">
            <p class="os-section-title" style="margin:0 0 4px;">Ultimo post</p>
            <p style="font-size:12px;color:var(--os-text);margin:0;line-height:1.35;">{r.ultimo_post}</p>
            <p style="font-size:10px;color:var(--os-muted);margin:4px 0 0;"><span class="os-num" style="font-size:10px;">{r.publicaciones_semana}</span> publicacion{r.publicaciones_semana !== 1 ? 'es' : ''} esta semana</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Content editor -->
    <OSContenidoEditor client:load />
  </div>

  <style>
    @media (max-width: 820px) {
      .os-social-grid { grid-template-columns: 1fr !important; }
    }
  </style>
</OSLayout>
