---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
import { kpis } from '../../os/data/kpis';
import OSKPIGrid from '../../os/components/OSKPIGrid';

const categorias = [...new Set(kpis.map((k) => k.categoria))];
---

<OSLayout title="KPIs">
  <div>
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1.75rem;">
      <h1 style="font-size:1.375rem;font-weight:700;color:#F4F6F8;margin:0;">KPIs</h1>
      <p style="font-size:12px;color:#6B7280;margin:0;">Junio 2026</p>
    </div>

    <OSKPIGrid kpis={kpis} client:load />

    <!-- Por categoria -->
    <div style="margin-top:2rem;">
      <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#6B7280;margin:0 0 0.875rem;">Nota sobre los numeros</p>
      <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1.125rem;">
        <p style="font-size:13px;color:#6B7280;margin:0;line-height:1.6;">
          Los valores en <span style="color:#B5985A;font-weight:500;">champagne</span> son cifras reales del mes en curso. Las tendencias se calculan contra el mismo periodo del mes anterior. Todos los datos se conectaran a gbrain en la siguiente iteracion.
        </p>
      </div>
    </div>
  </div>
</OSLayout>
