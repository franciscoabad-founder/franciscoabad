---
---

<section class="bg-bg-elevated py-20 md:py-28 overflow-hidden" data-reveal>
  <div class="max-w-[1200px] mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-12 lg:gap-20 items-center">

      {/* Columna izquierda: tagline de marca */}
      <div class="space-y-6">
        <div class="font-inter font-black text-[clamp(2.5rem,7vw,5.5rem)] leading-[1] tracking-[-2px] uppercase">
          <span class="text-text-primary">CLARITY<br>BUILDS</span>
          <br>
          <span style="color: hsl(var(--accent-cobalt-mid));">GROWTH.</span>
        </div>
        <p class="font-inter text-text-secondary text-[17px] leading-relaxed max-w-[480px]">
          Systems transform complexity into sustainable growth.
        </p>
      </div>

      {/* Columna derecha: specimen tipográfico */}
      <div class="space-y-5">
        <div
          class="font-inter font-black text-text-primary leading-[0.85] select-none"
          style="font-size: clamp(4rem, 10vw, 7rem);"
          aria-hidden="true"
        >
          AaBbCc123
        </div>
        <div class="space-y-2 pt-2">
          <p class="font-inter font-medium text-text-muted-brand text-[11px] uppercase tracking-[3px]">
            Tipografía Principal &middot; Inter
          </p>
          <p class="font-inter text-text-secondary text-[13px] tracking-wide">
            <span style="font-weight: 300;">Light</span>
            <span class="text-border mx-2">·</span>
            <span style="font-weight: 400;">Regular</span>
            <span class="text-border mx-2">·</span>
            <span style="font-weight: 500;">Medium</span>
            <span class="text-border mx-2">·</span>
            <span style="font-weight: 600;">Semibold</span>
            <span class="text-border mx-2">·</span>
            <span style="font-weight: 700;">Bold</span>
            <span class="text-border mx-2">·</span>
            <span style="font-weight: 900;">Black</span>
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
