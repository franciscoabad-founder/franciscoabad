---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
import OSRevision from '../../os/components/OSRevision';
import PageHeader from '../../os/components/ui/PageHeader';
---

<OSLayout title="Revision">
  <div class="os-fade-up">

    <PageHeader eyebrow="Retrospectiva" title="Revision" subtitle="Weekly y monthly review, con el norte de 90 dias siempre a la vista." />

    <OSRevision client:load />
  </div>

  <style is:global>
    @media (max-width: 820px) {
      .os-2col { grid-template-columns: 1fr !important; }
    }
  </style>
</OSLayout>
