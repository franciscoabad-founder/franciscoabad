---
export const prerender = false;

import OSLayout from '../../layouts/OSLayout.astro';
import OSGraphBrain from '../../os/components/OSGraphBrain';
---

<OSLayout title="Cerebro">
  <div>
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1.75rem;">
      <h1 style="font-size:1.375rem;font-weight:700;color:#F4F6F8;margin:0;">Cerebro</h1>
      <p id="nota-count" style="font-size:12px;color:#6B7280;margin:0;">Cargando...</p>
    </div>

    <!-- Search -->
    <div style="position:relative;margin-bottom:1.5rem;">
      <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#6B7280;">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      </span>
      <input
        id="brain-search"
        type="text"
        placeholder="Buscar en gbrain..."
        style="width:100%;background:#131F4A;border:1px solid rgba(232,234,240,0.12);border-radius:8px;padding:0.75rem 0.875rem 0.75rem 2.375rem;font-size:14px;color:#F4F6F8;font-family:'Inter',sans-serif;box-sizing:border-box;outline:none;"
      />
    </div>

    <div id="search-results" style="display:none;margin-bottom:1.5rem;"></div>

    <!-- Force graph -->
    <div style="background:#131F4A;border:1px solid rgba(59,78,217,0.2);border-radius:12px;padding:1.25rem;margin-bottom:1.5rem;">
      <p style="font-family:'Montserrat',sans-serif;font-size:9px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:#6B7280;margin:0 0 1rem;">Grafo de ideas</p>
      <OSGraphBrain client:load />
    </div>

    <!-- Notes grid -->
    <div id="notes-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px;">
      <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.06);border-radius:12px;padding:1.125rem;color:#6B7280;font-size:13px;">
        Cargando notas...
      </div>
    </div>
  </div>
</OSLayout>

<script>
  async function loadNotes() {
    try {
      const res = await fetch('/api/brain/notes?limit=12');
      if (!res.ok) throw new Error(String(res.status));
      const { notes } = await res.json();

      const countEl = document.getElementById('nota-count');
      if (countEl) countEl.textContent = notes.length + ' notas indexadas';

      const grid = document.getElementById('notes-grid');
      if (!grid || !notes.length) return;

      grid.innerHTML = notes.map(function(n) {
        var linksHtml = n.conexiones && n.conexiones.length
          ? '<span style="font-size:10px;color:#6B7AE8;flex-shrink:0;">' + n.conexiones.length + ' links</span>'
          : '';
        var tagsHtml = (n.tags || []).map(function(t) {
          return '<span style="font-size:10px;color:#6B7280;background:rgba(232,234,240,0.05);padding:2px 7px;border-radius:4px;">#' + esc(t) + '</span>';
        }).join('');
        return '<div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1.125rem;display:flex;flex-direction:column;gap:0.625rem;">'
          + '<div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">'
          + '<h3 style="font-family:\'Montserrat\',sans-serif;font-size:13px;font-weight:700;color:#F4F6F8;margin:0;line-height:1.3;">' + esc(n.titulo) + '</h3>'
          + linksHtml + '</div>'
          + '<p style="font-size:12px;color:#6B7280;margin:0;line-height:1.45;">' + esc(n.resumen) + '</p>'
          + '<div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:auto;">' + tagsHtml + '</div>'
          + '<p style="font-size:10px;color:rgba(107,114,128,0.6);margin:0;">' + esc(n.fecha) + '</p>'
          + '</div>';
      }).join('');
    } catch (e) {
      var grid = document.getElementById('notes-grid');
      if (grid) grid.innerHTML = '<div style="color:#F87171;font-size:12px;padding:1rem;">Error cargando notas</div>';
    }
  }

  var searchTimer;
  var searchInput = document.getElementById('brain-search');
  if (searchInput) {
    searchInput.addEventListener('input', function(e) {
      clearTimeout(searchTimer);
      var q = e.target.value.trim();
      var resultsEl = document.getElementById('search-results');
      if (!resultsEl) return;

      if (!q) {
        resultsEl.style.display = 'none';
        resultsEl.innerHTML = '';
        return;
      }

      searchTimer = setTimeout(async function() {
        resultsEl.style.display = 'block';
        resultsEl.innerHTML = '<p style="color:#6B7280;font-size:12px;padding:0.5rem 0;">Buscando...</p>';
        try {
          var res = await fetch('/api/brain/search?q=' + encodeURIComponent(q));
          if (!res.ok) throw new Error(String(res.status));
          var data = await res.json();
          var results = data.results;

          if (!results.length) {
            resultsEl.innerHTML = '<p style="color:#6B7280;font-size:12px;padding:0.5rem 0;">Sin resultados.</p>';
            return;
          }

          resultsEl.innerHTML = '<div style="display:flex;flex-direction:column;gap:8px;">'
            + results.map(function(r) {
              return '<div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:10px;padding:0.875rem;">'
                + '<h4 style="font-size:13px;font-weight:700;color:#F4F6F8;margin:0 0 4px;font-family:\'Montserrat\',sans-serif;">' + esc(r.titulo) + '</h4>'
                + '<p style="font-size:12px;color:#6B7280;margin:0;line-height:1.45;">' + esc(r.resumen) + '</p>'
                + '</div>';
            }).join('')
            + '</div>';
        } catch (err) {
          resultsEl.innerHTML = '<p style="color:#F87171;font-size:12px;">Error al buscar.</p>';
        }
      }, 350);
    });
  }

  function esc(s) {
    return String(s || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  loadNotes();
</script>
