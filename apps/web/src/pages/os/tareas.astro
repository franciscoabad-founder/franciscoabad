---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
---

<OSLayout title="Tareas">
  <div class="os-fade-up">
    <!-- Header -->
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:1.25rem;flex-wrap:wrap;gap:0.5rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Growth OS</p>
        <h1 class="os-h1" style="display:flex;align-items:center;gap:9px;">
          <span class="material-symbols-outlined" style="font-size:24px;color:var(--os-accent-light);">checklist</span>
          Tareas
        </h1>
      </div>
      <p id="tarea-count" class="os-num" style="font-size:12px;margin:0;">Cargando...</p>
    </div>

    <!-- Quick-add form -->
    <form id="tarea-form" class="os-card-2" style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-end;margin-bottom:1.25rem;padding:0.875rem 1rem;">
      <input name="titulo" type="text" placeholder="Titulo de la tarea *" required
        class="os-input" style="flex:2;min-width:180px;font-size:12px;padding:6px 11px;" />
      <input name="proyecto" type="text" placeholder="Proyecto"
        class="os-input" style="flex:1;min-width:110px;font-size:12px;padding:6px 11px;" />
      <input name="deadline" type="date"
        class="os-input" style="font-size:12px;padding:6px 11px;color-scheme:dark;" />
      <label style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--os-muted);cursor:pointer;user-select:none;white-space:nowrap;">
        <input name="urgente" type="checkbox" value="true" style="accent-color:var(--os-accent);" />
        Urgente
      </label>
      <button type="submit" class="os-btn" style="padding:6px 16px;font-size:12px;">
        <span class="material-symbols-outlined" style="font-size:16px;">add</span>
        Agregar
      </button>
      <p id="tarea-form-msg" style="font-size:11px;color:var(--os-error);width:100%;margin:0;display:none;"></p>
    </form>

    <!-- Filters -->
    <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:1.25rem;align-items:center;">
      <!-- Estado -->
      <div style="display:flex;gap:4px;align-items:center;flex-wrap:wrap;">
        <span style="font-size:10px;color:var(--os-muted);font-family:'Montserrat',sans-serif;letter-spacing:0.08em;text-transform:uppercase;margin-right:2px;flex-shrink:0;">Estado</span>
        <button data-fest="todos" onclick="setEstadoFilter('todos')"
          style="padding:3px 11px;font-size:11px;font-family:'Montserrat',sans-serif;font-weight:700;border-radius:var(--os-r-sm);border:1px solid rgba(59,78,217,0.5);background:rgba(59,78,217,0.2);color:#E8EAF0;cursor:pointer;">Todos</button>
        <button data-fest="pendiente" onclick="setEstadoFilter('pendiente')"
          style="padding:3px 11px;font-size:11px;font-family:'Montserrat',sans-serif;font-weight:700;border-radius:var(--os-r-sm);border:1px solid rgba(232,234,240,0.12);background:transparent;color:#6B7280;cursor:pointer;">Pendiente</button>
        <button data-fest="en_progreso" onclick="setEstadoFilter('en_progreso')"
          style="padding:3px 11px;font-size:11px;font-family:'Montserrat',sans-serif;font-weight:700;border-radius:var(--os-r-sm);border:1px solid rgba(232,234,240,0.12);background:transparent;color:#6B7280;cursor:pointer;">En progreso</button>
        <button data-fest="hecho" onclick="setEstadoFilter('hecho')"
          style="padding:3px 11px;font-size:11px;font-family:'Montserrat',sans-serif;font-weight:700;border-radius:var(--os-r-sm);border:1px solid rgba(232,234,240,0.12);background:transparent;color:#6B7280;cursor:pointer;">Hecho</button>
      </div>
      <!-- Urgente toggle -->
      <button id="btn-urgente" onclick="toggleUrgente()"
        style="padding:3px 11px;font-size:11px;font-family:'Montserrat',sans-serif;font-weight:700;border-radius:var(--os-r-sm);border:1px solid rgba(232,234,240,0.12);background:transparent;color:#6B7280;cursor:pointer;">
        Urgente
      </button>
      <!-- Deadline -->
      <div style="display:flex;gap:4px;align-items:center;flex-wrap:wrap;">
        <span style="font-size:10px;color:var(--os-muted);font-family:'Montserrat',sans-serif;letter-spacing:0.08em;text-transform:uppercase;margin-right:2px;flex-shrink:0;">Deadline</span>
        <button data-fdl="todos" onclick="setDeadlineFilter('todos')"
          style="padding:3px 11px;font-size:11px;font-family:'Montserrat',sans-serif;font-weight:700;border-radius:var(--os-r-sm);border:1px solid rgba(59,78,217,0.5);background:rgba(59,78,217,0.2);color:#E8EAF0;cursor:pointer;">Todos</button>
        <button data-fdl="hoy" onclick="setDeadlineFilter('hoy')"
          style="padding:3px 11px;font-size:11px;font-family:'Montserrat',sans-serif;font-weight:700;border-radius:var(--os-r-sm);border:1px solid rgba(232,234,240,0.12);background:transparent;color:#6B7280;cursor:pointer;">Hoy</button>
        <button data-fdl="semana" onclick="setDeadlineFilter('semana')"
          style="padding:3px 11px;font-size:11px;font-family:'Montserrat',sans-serif;font-weight:700;border-radius:var(--os-r-sm);border:1px solid rgba(232,234,240,0.12);background:transparent;color:#6B7280;cursor:pointer;">Esta semana</button>
        <button data-fdl="vencidas" onclick="setDeadlineFilter('vencidas')"
          style="padding:3px 11px;font-size:11px;font-family:'Montserrat',sans-serif;font-weight:700;border-radius:var(--os-r-sm);border:1px solid rgba(232,234,240,0.12);background:transparent;color:#6B7280;cursor:pointer;">Vencidas</button>
        <button data-fdl="sin" onclick="setDeadlineFilter('sin')"
          style="padding:3px 11px;font-size:11px;font-family:'Montserrat',sans-serif;font-weight:700;border-radius:var(--os-r-sm);border:1px solid rgba(232,234,240,0.12);background:transparent;color:#6B7280;cursor:pointer;">Sin deadline</button>
      </div>
    </div>

    <!-- List -->
    <div id="tareas-list" style="display:flex;flex-direction:column;gap:4px;">
      <div class="os-card-2" style="padding:1rem;color:var(--os-muted);font-size:13px;">Cargando...</div>
    </div>
  </div>

  <style>
    @media (max-width: 820px) {
      #tarea-form { flex-direction: column; align-items: stretch; }
      #tarea-form .os-input,
      #tarea-form > label,
      #tarea-form > button[type="submit"] { width: 100%; }
    }
  </style>
</OSLayout>

<script is:inline>
var allTareas = [];
var estadoFilter = 'todos';
var urgenteFilter = false;
var deadlineFilter = 'todos';

var ESTADO_COLOR = { pendiente:'#6B7280', en_progreso:'#6B7AE8', hecho:'#22c55e', 'en progreso':'#6B7AE8' };
var ESTADO_LABEL = { pendiente:'Pendiente', en_progreso:'En progreso', hecho:'Hecho' };

function esc(s) {
  return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function todayStr() {
  return new Date().toISOString().slice(0,10);
}
function estadoValue(estado) {
  return estado === 'en progreso' ? 'en_progreso' : (estado || 'pendiente');
}
function endOfWeekStr() {
  var d = new Date();
  var diff = 6 - d.getDay();
  d.setDate(d.getDate() + diff);
  return d.toISOString().slice(0,10);
}
function dlDisplay(dl) {
  if (!dl) return '';
  var today = todayStr();
  var overdue = dl < today;
  var color = overdue ? '#F87171' : (dl === today ? '#FB923C' : '#6B7280');
  var label = new Date(dl + 'T12:00:00').toLocaleDateString('es',{day:'numeric',month:'short'});
  return '<span class="os-mono" style="font-size:11px;color:' + color + ';">' + (overdue ? 'Vencio: ' : '') + esc(label) + '</span>';
}
function applyFilters(tareas) {
  return tareas.filter(function(t) {
    if (estadoFilter !== 'todos' && estadoValue(t.estado) !== estadoFilter) return false;
    if (urgenteFilter && !t.urgente) return false;
    var dl = t.deadline;
    var today = todayStr();
    if (deadlineFilter === 'hoy') return dl === today;
    if (deadlineFilter === 'semana') return !!(dl && dl >= today && dl <= endOfWeekStr());
    if (deadlineFilter === 'vencidas') return !!(dl && dl < today && t.estado !== 'hecho');
    if (deadlineFilter === 'sin') return !dl;
    return true;
  });
}
function activateBtn(selector, attr, val) {
  document.querySelectorAll('[' + attr + ']').forEach(function(b) {
    var active = b.getAttribute(attr) === val;
    b.style.background = active ? 'rgba(59,78,217,0.2)' : 'transparent';
    b.style.color = active ? '#E8EAF0' : '#6B7280';
    b.style.borderColor = active ? 'rgba(59,78,217,0.5)' : 'rgba(232,234,240,0.12)';
  });
}
function setEstadoFilter(val) {
  estadoFilter = val;
  activateBtn(null, 'data-fest', val);
  renderTareas(applyFilters(allTareas));
}
function setDeadlineFilter(val) {
  deadlineFilter = val;
  activateBtn(null, 'data-fdl', val);
  renderTareas(applyFilters(allTareas));
}
function toggleUrgente() {
  urgenteFilter = !urgenteFilter;
  var btn = document.getElementById('btn-urgente');
  if (btn) {
    btn.style.background = urgenteFilter ? 'rgba(248,113,113,0.15)' : 'transparent';
    btn.style.color = urgenteFilter ? '#F87171' : '#6B7280';
    btn.style.borderColor = urgenteFilter ? 'rgba(248,113,113,0.4)' : 'rgba(232,234,240,0.12)';
  }
  renderTareas(applyFilters(allTareas));
}
async function patchDeadline(id, current) {
  var val = prompt('Fecha limite (YYYY-MM-DD):', current || '');
  if (val === null) return;
  val = val.trim();
  if (val && !/^\d{4}-\d{2}-\d{2}$/.test(val)) { alert('Formato invalido. Usa YYYY-MM-DD'); return; }
  try {
    var res = await fetch('/api/os/tareas?id=' + encodeURIComponent(id), {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ deadline: val || null }),
    });
    if (!res.ok) throw new Error(String(res.status));
    await loadTareas();
  } catch(e) { alert('Error: ' + e.message); }
}
async function patchEstado(id, estado) {
  try {
    var res = await fetch('/api/os/tareas?id=' + encodeURIComponent(id), {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ estado: estado }),
    });
    if (!res.ok) throw new Error(String(res.status));
    await loadTareas();
  } catch(e) { alert('Error: ' + e.message); }
}
async function completarTarea(id) {
  await patchEstado(id, 'hecho');
}
async function editTarea(id) {
  var tarea = allTareas.find(function(t) { return t.id === id; });
  if (!tarea) return;
  var titulo = prompt('Titulo de la tarea:', tarea.titulo || '');
  if (titulo === null) return;
  titulo = titulo.trim();
  if (!titulo) { alert('Titulo requerido'); return; }
  var proyecto = prompt('Proyecto:', tarea.proyecto || '');
  if (proyecto === null) return;
  var deadline = prompt('Deadline (YYYY-MM-DD):', tarea.deadline || '');
  if (deadline === null) return;
  deadline = deadline.trim();
  if (deadline && !/^\d{4}-\d{2}-\d{2}$/.test(deadline)) { alert('Formato invalido. Usa YYYY-MM-DD'); return; }
  var urgente = confirm('Marcar como urgente? Aceptar = si, Cancelar = no');
  try {
    var res = await fetch('/api/os/tareas?id=' + encodeURIComponent(id), {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        titulo: titulo,
        proyecto: proyecto.trim() || null,
        deadline: deadline || null,
        urgente: urgente,
      }),
    });
    var json = await res.json();
    if (!res.ok) throw new Error(json.error || String(res.status));
    await loadTareas();
  } catch(e) { alert('Error: ' + e.message); }
}
async function deleteTarea(id) {
  if (!confirm('Eliminar esta tarea?')) return;
  try {
    var res = await fetch('/api/os/tareas?id=' + encodeURIComponent(id), { method: 'DELETE' });
    if (!res.ok) throw new Error(String(res.status));
    await loadTareas();
  } catch(e) { alert('Error: ' + e.message); }
}

function renderTareas(tareas) {
  var list = document.getElementById('tareas-list');
  if (!list) return;
  if (!tareas.length) {
    list.innerHTML = '<div class="os-card-2" style="padding:1.75rem;text-align:center;color:#6B7280;font-size:12px;">Sin tareas con estos filtros.</div>';
    return;
  }
  var byProyecto = {};
  tareas.forEach(function(t) {
    var p = t.proyecto || 'Sin proyecto';
    if (!byProyecto[p]) byProyecto[p] = [];
    byProyecto[p].push(t);
  });
  list.innerHTML = Object.keys(byProyecto).map(function(p) {
    return '<div style="margin-bottom:1.25rem;">'
      + '<p style="font-family:Montserrat,sans-serif;font-size:10px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#6B7280;margin:0 0 8px;display:flex;align-items:center;gap:6px;"><span class="material-symbols-outlined" style="font-size:14px;color:#6B7AE8;">folder</span>' + esc(p) + '</p>'
      + '<div style="display:flex;flex-direction:column;gap:6px;">'
      + byProyecto[p].map(function(t) {
          var isDone = t.estado === 'hecho';
          var currentEstado = estadoValue(t.estado);
          var opts = Object.keys(ESTADO_LABEL).map(function(e) {
            return '<option value="' + e + '"' + (currentEstado === e ? ' selected' : '') + '>' + ESTADO_LABEL[e] + '</option>';
          }).join('');
          var dlHtml = t.deadline
            ? '<button onclick="patchDeadline(\'' + t.id + '\',\'' + t.deadline + '\')" title="Cambiar" style="background:none;border:none;cursor:pointer;padding:0;line-height:1;">' + dlDisplay(t.deadline) + '</button>'
            : '<button onclick="patchDeadline(\'' + t.id + '\',\'\')" style="font-size:10px;color:rgba(107,114,128,0.55);background:none;border:1px dashed rgba(107,114,128,0.3);border-radius:4px;padding:2px 8px;cursor:pointer;font-family:Montserrat,sans-serif;white-space:nowrap;">+ deadline</button>';
          var check = isDone
            ? '<button onclick="patchEstado(\'' + t.id + '\',\'pendiente\')" title="Reabrir" style="background:none;border:none;padding:0;cursor:pointer;line-height:1;display:inline-flex;flex-shrink:0;"><span class="material-symbols-outlined" style="font-size:20px;color:#22c55e;">check_circle</span></button>'
            : '<button onclick="completarTarea(\'' + t.id + '\')" title="Marcar como hecha" style="background:none;border:none;padding:0;cursor:pointer;line-height:1;display:inline-flex;flex-shrink:0;"><span class="material-symbols-outlined" style="font-size:20px;color:' + (t.urgente ? '#6B7AE8' : 'rgba(107,114,128,0.55)') + ';">radio_button_unchecked</span></button>';
          return '<div style="display:flex;align-items:center;gap:11px;background:#131F4A;border:1px solid rgba(255,255,255,0.10);border-left:3px solid ' + (t.urgente && !isDone ? '#3B4ED9' : 'transparent') + ';border-radius:10px;padding:0.625rem 0.875rem;transition:border-color .15s;">'
            + check
            + '<p style="font-size:13px;color:' + (isDone ? '#6B7280' : '#F4F6F8') + ';margin:0;flex:1;min-width:0;line-height:1.4;text-decoration:' + (isDone ? 'line-through' : 'none') + ';">' + esc(t.titulo) + '</p>'
            + '<div style="display:flex;align-items:center;gap:9px;flex-shrink:0;">'
            + dlHtml
            + '<select onchange="patchEstado(\'' + t.id + '\',this.value)" style="background:#0E1738;border:1px solid rgba(255,255,255,0.12);border-radius:var(--os-r-sm);padding:3px 7px;font-size:11px;font-family:Montserrat,sans-serif;font-weight:700;color:' + (ESTADO_COLOR[t.estado] || '#6B7280') + ';cursor:pointer;outline:none;">'
            + opts
            + '</select>'
            + '<button onclick="editTarea(\'' + t.id + '\')" title="Editar" style="background:none;border:1px solid rgba(255,255,255,0.12);border-radius:var(--os-r-sm);color:#6B7AE8;cursor:pointer;padding:2px 7px;line-height:1;display:inline-flex;align-items:center;gap:3px;font-size:10px;font-family:Montserrat,sans-serif;font-weight:700;text-transform:uppercase;white-space:nowrap;"><span class="material-symbols-outlined" style="font-size:14px;">edit</span>Editar</button>'
            + '<button onclick="deleteTarea(\'' + t.id + '\')" title="Eliminar" style="background:none;border:none;color:rgba(107,114,128,0.45);cursor:pointer;padding:0;line-height:1;display:inline-flex;"><span class="material-symbols-outlined" style="font-size:16px;">close</span></button>'
            + '</div>'
            + '</div>';
        }).join('')
      + '</div></div>';
  }).join('');
}

async function loadTareas() {
  try {
    var res = await fetch('/api/os/tareas');
    if (!res.ok) throw new Error(String(res.status));
    var data = await res.json();
    allTareas = data.tareas || [];
    var pending = allTareas.filter(function(t) { return t.estado !== 'hecho'; }).length;
    var countEl = document.getElementById('tarea-count');
    if (countEl) countEl.textContent = pending + ' pendientes';
    renderTareas(applyFilters(allTareas));
  } catch(e) {
    var list = document.getElementById('tareas-list');
    if (list) list.innerHTML = '<div style="color:#F87171;font-size:12px;padding:1rem;">Error: ' + e.message + '</div>';
  }
}

var form = document.getElementById('tarea-form');
if (form) {
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    var msg = document.getElementById('tarea-form-msg');
    if (msg) msg.style.display = 'none';
    var fd = new FormData(form);
    var body = {
      titulo: fd.get('titulo'),
      proyecto: fd.get('proyecto') || null,
      deadline: fd.get('deadline') || null,
      urgente: fd.get('urgente') === 'true',
    };
    try {
      var res = await fetch('/api/os/tareas', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      var json = await res.json();
      if (!res.ok) throw new Error(json.error || String(res.status));
      form.reset();
      await loadTareas();
    } catch(err) {
      if (msg) { msg.textContent = 'Error: ' + err.message; msg.style.display = 'block'; }
    }
  });
}

loadTareas();
</script>
