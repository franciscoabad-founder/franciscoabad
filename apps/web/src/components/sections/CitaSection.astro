<section class="bg-bg-elevated py-20 md:py-28" data-reveal>
  <div class="max-w-[880px] mx-auto px-6 lg:px-8 text-center">

    {/* Comilla decorativa en cobalt */}
    <div
      class="font-inter font-black leading-none select-none mb-4"
      style="font-size: 6rem; color: hsl(var(--accent-cobalt)); opacity: 0.6; line-height: 0.7;"
      aria-hidden="true"
    >
      &ldquo;
    </div>

    <blockquote>
      <p class="font-inter font-bold text-text-primary text-[clamp(1.75rem,4vw,3rem)] leading-[1.2] tracking-[-0.5px]">
        Build systems that outlast hype.
      </p>
