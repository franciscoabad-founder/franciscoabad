---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
import OSContenido from '../../os/components/OSContenido';
import PageHeader from '../../os/components/ui/PageHeader';
---

<OSLayout title="Contenido">
  <div class="os-fade-up">

    <PageHeader eyebrow="Pipeline editorial" title="Contenido" subtitle="Ideas, produccion y repurposing en un solo pipeline." />

    <OSContenido client:load />
  </div>

  <style is:global>
    @media (max-width: 820px) {
      .os-card-2 { padding: 1rem; }
    }
  </style>
</OSLayout>
