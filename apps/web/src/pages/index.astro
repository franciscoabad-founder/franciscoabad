---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/sections/Hero.astro";
import LogosInstitucionales from "../components/sections/LogosInstitucionales.astro";
import ProblemStatement from "../components/sections/ProblemStatement.astro";
import Stats from "../components/sections/Stats.astro";
import Services from "../components/sections/Services.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import Resources from "../components/sections/Resources.astro";
import BlogPreview from "../components/sections/BlogPreview.astro";
import NewsletterCTA from "../components/sections/NewsletterCTA.astro";
import { useTranslations } from "../i18n/utils";

const lang = Astro.currentLocale ?? "es";
const t = useTranslations(lang);
---

<BaseLayout
  title={t("page.index.title")}
  description={t("page.index.desc")}
>
  <Navbar />
  <main>
    <Hero lang={lang} />
    <LogosInstitucionales />
    <ProblemStatement lang={lang} />
    <Stats />
    <Services lang={lang} />
    <Testimonials lang={lang} />
    <Resources />
    <BlogPreview />
    <NewsletterCTA />
  </main>
  <Footer lang={lang} />
</BaseLayout>
