---
export const prerender = false;

import OSLayout from '../../layouts/OSLayout.astro';
import { notas } from '../../os/data/cerebro';
import { grafoNodos, grafoAristas } from '../../os/data/grafo';
import OSGraphBrain from '../../os/components/OSGraphBrain';
---

<OSLayout title="Cerebro">
  <div>
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1.75rem;">
      <h1 style="font-size:1.375rem;font-weight:700;color:#F4F6F8;margin:0;">Cerebro</h1>
      <p style="font-size:12px;color:#6B7280;margin:0;">{notas.length} notas indexadas</p>
    </div>

    <!-- Search (placeholder) -->
    <div style="position:relative;margin-bottom:1.5rem;">
      <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#6B7280;">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      </span>
      <input
        type="text"
        placeholder="Buscar en gbrain... (conexion pendiente)"
        disabled
        style="width:100%;background:#131F4A;border:1px solid rgba(232,234,240,0.12);border-radius:8px;padding:0.75rem 0.875rem 0.75rem 2.375rem;font-size:14px;color:#6B7280;font-family:'Inter',sans-serif;cursor:not-allowed;box-sizing:border-box;"
      />
    </div>

    <!-- Force graph -->
    <div style="background:#131F4A;border:1px solid rgba(59,78,217,0.2);border-radius:12px;padding:1.25rem;margin-bottom:1.5rem;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
        <p style="font-family:'Montserrat',sans-serif;font-size:9px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:#6B7280;margin:0;">Grafo de ideas</p>
        <span style="font-size:10px;color:#6B7280;font-family:'Montserrat',sans-serif;letter-spacing:0.06em;">Demo — gbrain pendiente</span>
      </div>
      <!-- TODO: replace grafoNodos/grafoAristas with real gbrain data from /mcp endpoint -->
      <OSGraphBrain nodos={grafoNodos} aristas={grafoAristas} client:load />
      <div style="display:flex;gap:1.25rem;margin-top:0.875rem;padding-top:0.875rem;border-top:1px solid rgba(232,234,240,0.07);">
        <div style="display:flex;align-items:center;gap:5px;">
          <span style="width:8px;height:8px;border-radius:50%;background:#3B4ED9;display:block;"></span>
          <span style="font-size:10px;color:#6B7280;">Proyecto</span>
        </div>
        <div style="display:flex;align-items:center;gap:5px;">
          <span style="width:8px;height:8px;border-radius:50%;background:#6B7AE8;display:block;"></span>
          <span style="font-size:10px;color:#6B7280;">Concepto</span>
        </div>
        <div style="display:flex;align-items:center;gap:5px;">
          <span style="width:8px;height:8px;border-radius:50%;background:#B5985A;display:block;"></span>
          <span style="font-size:10px;color:#6B7280;">Persona</span>
        </div>
      </div>
    </div>

    <!-- Notas cards -->
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px;">
      {notas.map((nota) => (
        <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1.125rem;display:flex;flex-direction:column;gap:0.625rem;">
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">
            <h3 style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:700;color:#F4F6F8;margin:0;line-height:1.3;">{nota.titulo}</h3>
            {nota.conexiones.length > 0 && (
              <span style="font-size:10px;color:#6B7AE8;flex-shrink:0;font-family:'Montserrat',sans-serif;letter-spacing:0.05em;">{nota.conexiones.length} links</span>
            )}
          </div>
          <p style="font-size:12px;color:#6B7280;margin:0;line-height:1.45;">{nota.resumen}</p>
          <div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:auto;">
            {nota.tags.map((tag) => (
              <span style="font-size:10px;color:#6B7280;background:rgba(232,234,240,0.05);padding:2px 7px;border-radius:4px;">#{tag}</span>
            ))}
          </div>
          <p style="font-size:10px;color:rgba(107,114,128,0.6);margin:0;">{nota.fecha}</p>
        </div>
      ))}
    </div>
  </div>
</OSLayout>
