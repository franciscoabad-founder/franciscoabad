---
export const prerender = false;

import OSLayout from '../../layouts/OSLayout.astro';
import OSSistema from '../../os/components/OSSistema';
import { sistemaDefault } from '../../os/data/sistema';
---

<OSLayout title="Mi Sistema">
  <div class="os-fade-up">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:0.75rem;margin-bottom:1.5rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Growth OS</p>
        <h1 class="os-h1">Mi Sistema</h1>
      </div>
      <a class="os-btn os-btn-ghost" href="/os/aprobaciones" style="text-decoration:none;">
        <span class="material-symbols-outlined" style="font-size:16px;">approval_delegation</span>
        Aprobaciones
      </a>
    </div>

    <div class="os-domino" style="margin-bottom:1rem;">
      <p class="os-eyebrow" style="margin-bottom:0.5rem;">Cortex aplicado a Pancho OS</p>
      <p style="font-size:1rem;font-weight:600;color:var(--os-text);margin:0 0 0.375rem;line-height:1.35;">
        El OS guarda objetivos, prioridad, modulos, tono y ritmo para que Mateo, n8n y Hermes operen con el mismo contexto.
      </p>
      <p style="font-size:12px;color:var(--os-muted);margin:0;line-height:1.5;">
        Este estado vive en Supabase cuando la migracion esta aplicada y queda disponible por API server-side para el VPS.
      </p>
    </div>

    <OSSistema initialState={sistemaDefault} client:load />
  </div>
</OSLayout>
