---
export const prerender = false;

import OSLayout from '../../layouts/OSLayout.astro';
---

<OSLayout title="Cortex">
  <div class="os-fade-up">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:0.75rem;margin-bottom:1.5rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">BrainTech · Cortex</p>
        <h1 class="os-h1">Cortex Admin</h1>
      </div>
      <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
        <button id="cortex-refresh" type="button" class="os-btn os-btn-ghost">
          <span class="material-symbols-outlined" style="font-size:16px;">refresh</span>
          Actualizar
        </button>
        <a class="os-btn os-btn-ghost" href="https://app-cortex.franciscoabad.com" target="_blank" rel="noopener" style="text-decoration:none;">
          <span class="material-symbols-outlined" style="font-size:16px;">open_in_new</span>
          Abrir app
        </a>
      </div>
    </div>

    <!-- Estado de carga / error global -->
    <p id="cortex-overview-status" style="font-size:var(--os-text-sm);color:var(--os-muted);margin:0 0 1rem;">Cargando panel...</p>

    <!-- KPIs -->
    <div id="cortex-kpi-grid" class="os-kpi-grid" style="margin-bottom:1.5rem;">
      <div class="os-kpi">
        <p class="os-kpi-label">Tenants</p>
        <p class="os-kpi-value" id="kpi-tenants">-</p>
      </div>
      <div class="os-kpi">
        <p class="os-kpi-label">Activos</p>
        <p class="os-kpi-value" id="kpi-active">-</p>
      </div>
      <div class="os-kpi">
        <p class="os-kpi-label">Beta</p>
        <p class="os-kpi-value" id="kpi-beta">-</p>
      </div>
      <div class="os-kpi">
        <p class="os-kpi-label">Aprobaciones pend.</p>
        <p class="os-kpi-value" id="kpi-approvals">-</p>
      </div>
      <div class="os-kpi">
        <p class="os-kpi-label">Conexiones activas</p>
        <p class="os-kpi-value" id="kpi-connections">-</p>
      </div>
      <div class="os-kpi">
        <p class="os-kpi-label">Eventos del mes</p>
        <p class="os-kpi-value" id="kpi-usage">-</p>
      </div>
    </div>

    <!-- Alta de tester (colapsable) -->
    <details class="os-card" style="margin-bottom:1.5rem;">
      <summary class="os-section-title" style="cursor:pointer;margin:0;list-style:none;display:flex;align-items:center;gap:6px;">
        <span class="material-symbols-outlined" style="font-size:16px;">person_add</span>
        Alta de tester
      </summary>

      <form id="cortex-form" novalidate style="display:flex;flex-direction:column;gap:1rem;max-width:560px;margin-top:1rem;">
        <div>
          <label for="ci-nombre" class="cortex-field-label">Nombre *</label>
          <input id="ci-nombre" name="nombre" type="text" required placeholder="Nombre completo" class="os-input" style="width:100%;" />
        </div>

        <div>
          <label for="ci-email" class="cortex-field-label">Email *</label>
          <input id="ci-email" name="email" type="email" required placeholder="tester@correo.com" class="os-input" style="width:100%;" />
        </div>

        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
          <div style="flex:1;min-width:180px;">
            <label for="ci-empresa" class="cortex-field-label">Empresa</label>
            <input id="ci-empresa" name="empresa" type="text" placeholder="Empresa" class="os-input" style="width:100%;" />
          </div>
          <div style="flex:1;min-width:180px;">
            <label for="ci-rol" class="cortex-field-label">Rol</label>
            <input id="ci-rol" name="rol" type="text" placeholder="Rol / cargo" class="os-input" style="width:100%;" />
          </div>
        </div>

        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
          <div style="flex:1;min-width:180px;">
            <label for="ci-telefono" class="cortex-field-label">Telefono</label>
            <input id="ci-telefono" name="telefono" type="text" placeholder="+593 9..." class="os-input" style="width:100%;" />
          </div>
          <div style="flex:1;min-width:180px;">
            <label for="ci-tz" class="cortex-field-label">Zona horaria</label>
            <select id="ci-tz" name="tz" class="os-input" style="width:100%;">
              <option value="America/Guayaquil" selected>America/Guayaquil</option>
              <option value="America/Mexico_City">America/Mexico_City</option>
              <option value="America/Bogota">America/Bogota</option>
              <option value="America/Lima">America/Lima</option>
              <option value="America/Santiago">America/Santiago</option>
              <option value="America/Argentina/Buenos_Aires">America/Argentina/Buenos_Aires</option>
              <option value="US/Eastern">US/Eastern</option>
              <option value="Europe/Madrid">Europe/Madrid</option>
            </select>
          </div>
        </div>

        <div>
          <label for="ci-objetivo" class="cortex-field-label">Hipotesis de uso</label>
          <textarea id="ci-objetivo" name="objetivo" rows="3" placeholder="Que va a probar este tester y para que" class="os-input" style="width:100%;resize:vertical;"></textarea>
        </div>

        <div style="display:flex;gap:10px;align-items:flex-start;">
          <input id="ci-consentimiento" name="consentimiento_datos" type="checkbox" required style="margin-top:3px;width:16px;height:16px;flex-shrink:0;accent-color:var(--os-accent);" />
          <label for="ci-consentimiento" style="font-size:var(--os-text-sm);color:var(--os-text-2);line-height:1.5;">
            El tester consiente el registro de metricas de uso, errores y feedback durante el beta.
          </label>
        </div>

        <p id="cortex-error" style="display:none;font-size:var(--os-text-sm);color:var(--os-error);margin:0;"></p>

        <button id="cortex-submit" type="submit" class="os-btn" style="align-self:flex-start;">
          <span class="material-symbols-outlined" style="font-size:16px;">rocket_launch</span>
          Dar de alta
        </button>
      </form>

      <div id="cortex-result" class="os-card os-card-accent" style="display:none;max-width:560px;margin-top:1rem;">
        <p class="os-section-title">Tester creado</p>
        <div id="cortex-result-body" style="display:flex;flex-direction:column;gap:8px;font-size:var(--os-text-sm);color:var(--os-text-2);"></div>
        <div style="display:flex;align-items:center;gap:10px;margin-top:1rem;flex-wrap:wrap;">
          <button id="cortex-copy" type="button" class="os-btn os-btn-ghost">
            <span class="material-symbols-outlined" style="font-size:16px;">content_copy</span>
            Copiar credenciales
          </button>
          <span id="cortex-copy-ok" style="display:none;font-size:var(--os-text-xs);color:var(--os-ok);">Copiado.</span>
        </div>
      </div>
    </details>

    <!-- Tenants -->
    <p class="os-section-title">Tenants</p>
    <div class="os-card-2" style="margin-bottom:1.5rem;overflow-x:auto;">
      <table style="width:100%;border-collapse:collapse;font-size:13px;min-width:720px;">
        <thead>
          <tr>
            {['Slug','Nombre','Plan','Onboarded','Miembros','Beta email','Conexiones'].map((h) => (
              <th style="text-align:left;padding:8px 10px;font-family:var(--os-font-display);font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--os-muted);border-bottom:1px solid var(--os-line);">{h}</th>
            ))}
          </tr>
        </thead>
        <tbody id="cortex-tenants-body">
          <tr><td colspan="7" style="padding:2rem;text-align:center;color:var(--os-muted);font-size:var(--os-text-sm);">Cargando...</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Waitlist + Actividad -->
    <div class="cortex-two-col">
      <div>
        <p class="os-section-title">Waitlist reciente</p>
        <div class="os-card-2" id="cortex-waitlist-list" style="display:flex;flex-direction:column;gap:0;">
          <p style="padding:1rem 0;text-align:center;color:var(--os-muted);font-size:var(--os-text-sm);margin:0;">Cargando...</p>
        </div>
      </div>
      <div>
        <p class="os-section-title">Actividad reciente</p>
        <div class="os-card-2" id="cortex-activity-list" style="display:flex;flex-direction:column;gap:0;">
          <p style="padding:1rem 0;text-align:center;color:var(--os-muted);font-size:var(--os-text-sm);margin:0;">Cargando...</p>
        </div>
      </div>
    </div>
  </div>

  <style>
    .cortex-field-label {
      display: block;
      font-family: var(--os-font-display);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--os-muted);
      margin-bottom: 5px;
    }
    .cortex-two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
    }
    @media (max-width: 820px) {
      .cortex-two-col { grid-template-columns: 1fr; }
    }
    .cortex-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 10px;
      padding: 9px 0;
      border-bottom: 1px solid var(--os-line-soft);
    }
    .cortex-row:last-child { border-bottom: none; }
    details > summary::-webkit-details-marker { display: none; }
  </style>

  <script is:inline>
    (function () {
      const form = document.getElementById('cortex-form');
      const btn = document.getElementById('cortex-submit');
      const errorEl = document.getElementById('cortex-error');
      const resultCard = document.getElementById('cortex-result');
      const resultBody = document.getElementById('cortex-result-body');
      const copyBtn = document.getElementById('cortex-copy');
      const copyOk = document.getElementById('cortex-copy-ok');

      const esc = (s) => String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

      let credenciales = '';

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        errorEl.style.display = 'none';
        resultCard.style.display = 'none';

        const nombre = document.getElementById('ci-nombre').value.trim();
        const email = document.getElementById('ci-email').value.trim();
        const consentimiento = document.getElementById('ci-consentimiento').checked;

        if (!nombre || !email) {
          errorEl.textContent = 'Completa nombre y email.';
          errorEl.style.display = 'block';
          return;
        }
        if (!consentimiento) {
          errorEl.textContent = 'El consentimiento de datos es obligatorio.';
          errorEl.style.display = 'block';
          return;
        }

        const payload = {
          nombre,
          email,
          empresa: document.getElementById('ci-empresa').value.trim() || undefined,
          rol: document.getElementById('ci-rol').value.trim() || undefined,
          telefono: document.getElementById('ci-telefono').value.trim() || undefined,
          tz: document.getElementById('ci-tz').value || undefined,
          objetivo: document.getElementById('ci-objetivo').value.trim() || undefined,
          consentimiento_datos: true,
        };

        btn.disabled = true;
        const originalHtml = btn.innerHTML;
        btn.innerHTML = 'Provisionando... (puede tardar 1-2 minutos)';

        try {
          const res = await fetch('/api/os/cortex-invitar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json();

          if (!res.ok || data.error) {
            errorEl.textContent = data.error || 'Algo salio mal. Intenta de nuevo.';
            errorEl.style.display = 'block';
            btn.disabled = false;
            btn.innerHTML = originalHtml;
            return;
          }

          let html = '';
          html += '<p><strong style="color:var(--os-text);">Login:</strong> <a href="' + esc(data.login_url) + '" target="_blank" rel="noopener" style="color:var(--os-accent-light);">' + esc(data.login_url) + '</a></p>';
          html += '<p><strong style="color:var(--os-text);">Email:</strong> ' + esc(data.email) + '</p>';

          credenciales = 'URL: ' + (data.login_url || '') + ' / Email: ' + (data.email || '');

          if (data.temporary_password) {
            html += '<p><strong style="color:var(--os-text);">Password temporal:</strong> <span class="os-mono">' + esc(data.temporary_password) + '</span></p>';
            html += '<p style="color:var(--os-error);font-size:var(--os-text-xs);margin-top:2px;">La contrasena se muestra UNA sola vez; compartela por canal seguro.</p>';
            credenciales += ' / Password: ' + data.temporary_password;
          }

          if (data.email_sent) {
            html += '<p style="color:var(--os-ok);">El tester ya recibio el correo de bienvenida.</p>';
          }

          if (typeof data.restantes === 'number') {
            html += '<p style="color:var(--os-muted);font-size:var(--os-text-xs);">Cupos restantes: ' + esc(data.restantes) + '</p>';
          }

          resultBody.innerHTML = html;
          resultCard.style.display = 'block';
          copyOk.style.display = 'none';
          form.reset();
          document.getElementById('ci-tz').value = 'America/Guayaquil';

          // El alta de un tester cambia los datos del panel: refresca.
          if (typeof window.cortexLoadOverview === 'function') window.cortexLoadOverview();
        } catch (err) {
          errorEl.textContent = 'Error de conexion. Intenta de nuevo.';
          errorEl.style.display = 'block';
        }

        btn.disabled = false;
        btn.innerHTML = originalHtml;
      });

      copyBtn.addEventListener('click', function () {
        if (!credenciales) return;
        navigator.clipboard.writeText(credenciales).then(function () {
          copyOk.style.display = 'inline';
          setTimeout(function () { copyOk.style.display = 'none'; }, 2000);
        });
      });
    })();
  </script>

  <script is:inline>
    (function () {
      const esc = (s) => String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      const fmtDate = (d) => {
        if (!d) return '-';
        const dt = new Date(d);
        if (isNaN(dt.getTime())) return '-';
        return dt.toLocaleDateString('es', { day: '2-digit', month: 'short', year: 'numeric' });
      };

      const statusEl = document.getElementById('cortex-overview-status');
      const refreshBtn = document.getElementById('cortex-refresh');

      const kpiEls = {
        tenants: document.getElementById('kpi-tenants'),
        active: document.getElementById('kpi-active'),
        beta: document.getElementById('kpi-beta'),
        approvals: document.getElementById('kpi-approvals'),
        connections: document.getElementById('kpi-connections'),
        usage: document.getElementById('kpi-usage'),
      };

      const tenantsBody = document.getElementById('cortex-tenants-body');
      const waitlistList = document.getElementById('cortex-waitlist-list');
      const activityList = document.getElementById('cortex-activity-list');

      function renderKpis(counts) {
        counts = counts || {};
        kpiEls.tenants.textContent = counts.tenants ?? 0;
        kpiEls.active.textContent = counts.active ?? 0;
        kpiEls.beta.textContent = counts.beta ?? 0;
        kpiEls.approvals.textContent = counts.approvals ?? 0;
        kpiEls.connections.textContent = counts.connections ?? 0;
        kpiEls.usage.textContent = counts.usageThisMonth ?? 0;
      }

      function renderTenants(tenants) {
        tenants = Array.isArray(tenants) ? tenants : [];
        if (tenants.length === 0) {
          tenantsBody.innerHTML = '<tr><td colspan="7" style="padding:2rem;text-align:center;color:var(--os-muted);font-size:var(--os-text-sm);">Sin tenants todavia.</td></tr>';
          return;
        }
        tenantsBody.innerHTML = tenants.map(function (t) {
          const onboarded = !!t.onboarded_at;
          const conexiones = Array.isArray(t.connections) && t.connections.length > 0 ? t.connections.map(esc).join(', ') : '-';
          return '<tr style="border-bottom:1px solid var(--os-line-soft);">'
            + '<td style="padding:9px 10px;color:var(--os-text-2);font-family:var(--os-font-mono);white-space:nowrap;">' + esc(t.slug) + '</td>'
            + '<td style="padding:9px 10px;color:var(--os-text);font-weight:600;white-space:nowrap;">' + esc(t.name || '-') + '</td>'
            + '<td style="padding:9px 10px;"><span class="os-pill os-pill-accent">' + esc(t.plan || '-') + '</span></td>'
            + '<td style="padding:9px 10px;' + (onboarded ? 'color:var(--os-champagne);font-weight:700;' : 'color:var(--os-muted);') + '">' + (onboarded ? 'Si' : 'No') + '</td>'
            + '<td style="padding:9px 10px;color:var(--os-text-2);text-align:right;">' + (t.member_count ?? 0) + '</td>'
            + '<td style="padding:9px 10px;color:var(--os-text-2);">' + esc(t.beta_email || '-') + '</td>'
            + '<td style="padding:9px 10px;color:var(--os-text-2);">' + conexiones + '</td>'
            + '</tr>';
        }).join('');
      }

      function renderWaitlist(waitlist) {
        waitlist = Array.isArray(waitlist) ? waitlist : [];
        if (waitlist.length === 0) {
          waitlistList.innerHTML = '<p style="padding:1rem 0;text-align:center;color:var(--os-muted);font-size:var(--os-text-sm);margin:0;">Sin leads todavia.</p>';
          return;
        }
        waitlistList.innerHTML = waitlist.map(function (w) {
          return '<div class="cortex-row">'
            + '<div style="min-width:0;">'
            + '<p style="margin:0;color:var(--os-text);font-weight:600;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + esc(w.nombre || w.email || 'Sin nombre') + '</p>'
            + '<p style="margin:2px 0 0;color:var(--os-muted);font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + esc(w.email || '') + (w.empresa ? ' · ' + esc(w.empresa) : '') + '</p>'
            + '</div>'
            + '<p style="margin:0;color:var(--os-muted);font-size:12px;white-space:nowrap;flex-shrink:0;">' + fmtDate(w.created_at) + '</p>'
            + '</div>';
        }).join('');
      }

      function renderActivity(approvals, usage) {
        approvals = Array.isArray(approvals) ? approvals : [];
        usage = Array.isArray(usage) ? usage : [];

        const items = [];
        approvals.forEach(function (a) {
          items.push({
            kind: 'Aprobacion',
            label: a.titulo || a.tipo || 'Aprobacion',
            sub: (a.tipo || '-') + (a.estado ? ' · ' + a.estado : ''),
            date: a.created_at,
          });
        });
        usage.forEach(function (u) {
          items.push({
            kind: 'Uso',
            label: u.modelo || u.tipo || 'Evento',
            sub: (u.tipo || '-') + (typeof u.costo_usd === 'number' ? ' · $' + u.costo_usd.toFixed(4) : ''),
            date: u.created_at,
          });
        });

        items.sort(function (a, b) {
          return new Date(b.date || 0).getTime() - new Date(a.date || 0).getTime();
        });

        if (items.length === 0) {
          activityList.innerHTML = '<p style="padding:1rem 0;text-align:center;color:var(--os-muted);font-size:var(--os-text-sm);margin:0;">Sin actividad reciente.</p>';
          return;
        }

        activityList.innerHTML = items.slice(0, 20).map(function (it) {
          return '<div class="cortex-row">'
            + '<div style="min-width:0;">'
            + '<p style="margin:0;color:var(--os-text);font-weight:600;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><span class="os-tag" style="margin-right:6px;">' + esc(it.kind) + '</span>' + esc(it.label) + '</p>'
            + '<p style="margin:2px 0 0;color:var(--os-muted);font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + esc(it.sub) + '</p>'
            + '</div>'
            + '<p style="margin:0;color:var(--os-muted);font-size:12px;white-space:nowrap;flex-shrink:0;">' + fmtDate(it.date) + '</p>'
            + '</div>';
        }).join('');
      }

      function showError(msg) {
        statusEl.textContent = msg;
        statusEl.style.color = 'var(--os-error)';
        tenantsBody.innerHTML = '<tr><td colspan="7" style="padding:2rem;text-align:center;color:var(--os-error);font-size:var(--os-text-sm);">' + esc(msg) + '</td></tr>';
        waitlistList.innerHTML = '<p style="padding:1rem 0;text-align:center;color:var(--os-error);font-size:var(--os-text-sm);margin:0;">No se pudo cargar.</p>';
        activityList.innerHTML = '<p style="padding:1rem 0;text-align:center;color:var(--os-error);font-size:var(--os-text-sm);margin:0;">No se pudo cargar.</p>';
      }

      async function loadOverview() {
        statusEl.textContent = 'Cargando panel...';
        statusEl.style.color = 'var(--os-muted)';
        refreshBtn.disabled = true;

        try {
          const res = await fetch('/api/os/cortex-admin');
          const data = await res.json();

          if (!res.ok || data.error) {
            showError(data.error || 'No se pudo cargar el panel de Cortex.');
            refreshBtn.disabled = false;
            return;
          }

          renderKpis(data.counts);
          renderTenants(data.tenants);
          renderWaitlist(data.waitlist);
          renderActivity(data.recentApprovals, data.recentUsage);

          statusEl.textContent = 'Actualizado ' + new Date().toLocaleTimeString('es', { hour: '2-digit', minute: '2-digit' });
          statusEl.style.color = 'var(--os-muted)';
        } catch (err) {
          showError('Error de conexion con Cortex. Intenta de nuevo.');
        }

        refreshBtn.disabled = false;
      }

      window.cortexLoadOverview = loadOverview;
      refreshBtn.addEventListener('click', loadOverview);

      loadOverview();
    })();
  </script>
</OSLayout>
