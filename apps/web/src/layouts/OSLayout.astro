---
import '../styles/os.css';
import { datosHoy } from '../os/data/hoy';
import { datosDaily } from '../os/data/daily';
import OSJugadorBar from '../os/components/OSJugadorBar';
import TaskiBubble from '../os/components/TaskiBubble';

interface Props {
  title: string;
}

const { title } = Astro.props;
const pathname = Astro.url.pathname;

const DIAS = ['Domingo', 'Lunes', 'Martes', 'Miercoles', 'Jueves', 'Viernes', 'Sabado'];
const diaHoy = DIAS[new Date().getDay()];
const diaData = datosDaily.semana.find(d => d.dia === diaHoy);
const tipoDia = diaData?.tipo ?? 'manager';

const tipoLabel: Record<string, string> = { maker: 'Maker Mode', manager: 'Manager Mode', off: 'Modo Off' };
const tipoColor: Record<string, string> = { maker: '#6B7AE8', manager: '#6B7280', off: '#6B7280' };

const dominoTexto = datosHoy.domino.tarea;

// route → Material Symbol
const ms: Record<string, string> = {
  '/os': 'dashboard',
  '/os/sistema': 'account_tree',
  '/os/aprobaciones': 'approval_delegation',
  '/os/daily': 'wb_sunny',
  '/os/revision': 'history',
  '/os/semana': 'calendar_view_week',
  '/os/kpis': 'bar_chart',
  '/os/proyectos': 'folder',
  '/os/crm': 'contacts',
  '/os/tareas': 'checklist',
  '/os/agenda': 'calendar_today',
  '/os/grabar': 'mic',
  '/os/bandeja': 'inbox',
  '/os/contenido': 'edit_note',
  '/os/redes': 'share',
  '/os/finanzas': 'payments',
  '/os/salud': 'favorite',
  '/os/gfit': 'fitness_center',
  '/os/habitos': 'task_alt',
  '/os/juego': 'sports_esports',
  '/os/comidas': 'restaurant',
  '/os/cerebro': 'psychology',
  '/os/pendientes': 'pending_actions',
  '/os/notas': 'edit_note',
  '/os/recordatorios': 'notifications',
  '/os/cortex': 'rocket_launch',
};

const navGroups = [
  { label: 'Sistema', items: [
    { href: '/os', label: 'Hoy' },
    { href: '/os/sistema', label: 'Mi Sistema' },
    { href: '/os/aprobaciones', label: 'Aprobaciones' },
    { href: '/os/daily', label: 'Daily OS' },
    { href: '/os/revision', label: 'Revision' },
    { href: '/os/cortex', label: 'Cortex' },
  ]},
  { label: 'Control', items: [
    { href: '/os/semana', label: 'Semana' },
    { href: '/os/kpis', label: 'KPIs' },
    { href: '/os/proyectos', label: 'Proyectos' },
    { href: '/os/crm', label: 'CRM' },
    { href: '/os/tareas', label: 'Tareas' },
    { href: '/os/pendientes', label: 'Pendientes' },
    { href: '/os/recordatorios', label: 'Recordatorios' },
    { href: '/os/agenda', label: 'Agenda' },
    { href: '/os/grabar', label: 'Grabar' },
  ]},
  { label: 'Captura', items: [
    { href: '/os/bandeja', label: 'Por revisar' },
    { href: '/os/notas', label: 'Notas' },
    { href: '/os/contenido', label: 'Contenido' },
    { href: '/os/redes', label: 'Redes' },
    { href: '/os/finanzas', label: 'Finanzas' },
    { href: '/os/salud', label: 'Salud' },
    { href: '/os/gfit', label: 'GFIT' },
    { href: '/os/habitos', label: 'Hábitos' },
    { href: '/os/juego', label: 'Juego' },
    { href: '/os/comidas', label: 'Comidas' },
  ]},
  { label: 'Conocimiento', items: [
    { href: '/os/cerebro', label: 'Cerebro' },
  ]},
];

// DECISION DE NAVEGACION (fase 1 rediseño): una sola jerarquia.
// navGroups es LA fuente de verdad de toda la navegacion del OS.
// - Desktop: sidebar con los 4 grupos completos.
// - Movil: bottom-nav con 5 destinos primarios (Hoy, Sistema, Tareas,
//   Agenda, Salud) DERIVADOS de navGroups, + boton "Mas" que abre el
//   drawer con los mismos navGroups. Nada se define dos veces.
const primariosMovil = ['/os', '/os/sistema', '/os/tareas', '/os/agenda', '/os/salud'];
const etiquetaCorta: Record<string, string> = { '/os/sistema': 'Sistema' };
const todosLosItems = navGroups.flatMap((g) => g.items);
const bottomNav = primariosMovil.map((href) => {
  const item = todosLosItems.find((i) => i.href === href);
  return {
    href,
    label: etiquetaCorta[href] ?? item?.label ?? href,
    icon: ms[href] ?? 'circle',
  };
});

function isActive(href: string): boolean {
  if (href === '/os') return pathname === '/os' || pathname === '/os/';
  return pathname === href || pathname === href + '/';
}
const anyBottomActive = bottomNav.some(i => isActive(i.href));
---

<!doctype html>
<html lang="es">
  <head>
    <script is:inline>
      // Prevencion de FOUC: aplica el tema guardado antes del primer paint.
      // Clave 'os-theme' (independiente del tema del sitio publico, que usa 'theme').
      // Por defecto SIEMPRE claro: oscuro solo si el usuario lo eligio con el toggle.
      // No se consulta prefers-color-scheme a proposito.
      (function() {
        var t = localStorage.getItem('os-theme') === 'dark' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title} — OS · Francisco Abad</title>
    <meta name="robots" content="noindex, nofollow" />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta id="os-theme-color-meta" name="theme-color" content="#FAFAF7" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="OS Pancho" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;900&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;700&family=Nunito:wght@400;600;700;800&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
    />

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; }
      body {
        background: var(--os-bg);
        color: var(--os-text);
        font-family: var(--os-font-body);
        -webkit-font-smoothing: antialiased;
        min-height: 100dvh;
      }
      h1, h2, h3, h4, h5, h6 { font-family: var(--os-font-display); }
      a { color: inherit; }

      /* ── Command bar (desktop/tablet) ── */
      .os-cmdbar {
        position: sticky; top: 0; z-index: 100;
        height: 44px; display: flex; align-items: center;
        background: var(--os-bg-sunken);
        border-bottom: 1px solid var(--os-line-accent);
        flex-shrink: 0;
      }
      .cmd-brand {
        width: 196px; flex-shrink: 0; display: flex; align-items: center; gap: 8px;
        padding: 0 1rem 0 1.125rem; height: 100%;
        border-right: 1px solid var(--os-line-soft);
      }
      .cmd-mode {
        display: inline-flex; align-items: center; gap: 5px;
      }
      .cmd-mode .material-symbols-outlined {
        font-size: 16px; color: var(--os-accent-light);
        animation: os-pulse 2.4s cubic-bezier(0.4,0,0.6,1) infinite;
      }
      .cmd-mode-label {
        font-family: var(--os-font-display); font-size: 11px; font-weight: 700;
        letter-spacing: 0.14em; text-transform: uppercase; color: var(--os-accent-light);
      }
      .cmd-sep { width: 1px; height: 12px; background: var(--os-line); }
      .cmd-name {
        font-family: var(--os-font-display); font-size: 11px; font-weight: 600;
        letter-spacing: 0.1em; text-transform: uppercase; color: var(--os-muted);
      }
      .cmd-center {
        flex: 1; display: flex; align-items: center; gap: 10px;
        padding: 0 1rem; min-width: 0; height: 100%;
        border-right: 1px solid var(--os-line-soft); overflow: hidden;
      }
      .cmd-day-pill {
        display: inline-flex; align-items: center; padding: 3px 10px;
        border-radius: 5px; font-family: var(--os-font-display);
        font-size: 11px; font-weight: 700; letter-spacing: 0.1em;
        text-transform: uppercase; flex-shrink: 0;
        background: rgba(59,78,217,0.14);
      }
      .cmd-right { display: flex; align-items: center; gap: 10px; padding: 0 0.875rem; height: 100%; flex-shrink: 0; }
      .cmd-capture {
        display: flex; align-items: center;
        background: var(--os-fill-subtle);
        border: 1px solid var(--os-line-soft);
        border-radius: 7px; overflow: hidden;
      }
      .cmd-capture input {
        background: transparent; border: none; outline: none;
        padding: 6px 8px; font-size: 12px; color: var(--os-text);
        font-family: var(--os-font-body); width: 190px; min-height: 32px;
      }
      .cmd-capture input::placeholder { color: var(--os-muted); }
      .cmd-quick-mode {
        display: inline-flex; align-items: center; justify-content: center;
        width: 32px; height: 32px; flex-shrink: 0; background: transparent;
        border: none; border-right: 1px solid var(--os-line-soft);
        color: var(--os-accent-light); cursor: pointer; padding: 0;
      }
      .cmd-quick-mode .material-symbols-outlined { font-size: 17px; }
      .cmd-quick-mode:hover { background: var(--os-hover); }
      .cmd-logout {
        font-size: 11px; color: var(--os-muted); text-decoration: none;
        font-family: var(--os-font-display); letter-spacing: 0.06em;
        text-transform: uppercase; font-weight: 600; transition: color 0.14s;
        padding: 3px 6px; border-radius: 4px; border: 1px solid var(--os-line-soft);
      }
      .cmd-logout:hover { color: var(--os-text); border-color: var(--os-line); }

      /* ── Theme toggle ── */
      .os-theme-toggle {
        display: inline-flex; align-items: center; justify-content: center;
        background: none; border: 1px solid var(--os-line);
        border-radius: var(--os-r-sm); color: var(--os-muted);
        cursor: pointer; width: 36px; height: 36px; padding: 0; flex-shrink: 0;
        transition: background 0.14s, color 0.14s, border-color 0.14s;
      }
      .os-theme-toggle:hover { background: var(--os-hover); color: var(--os-text); border-color: var(--os-line-accent); }
      .os-theme-toggle .material-symbols-outlined { font-size: 16px; }

      /* ── Mobile topbar ── */
      .os-topbar {
        display: none; align-items: center; justify-content: space-between;
        padding: 0 0.875rem 0 1rem; background: var(--os-bg-sunken);
        border-bottom: 1px solid var(--os-line-accent);
        height: 44px; position: sticky; top: 0; z-index: 100; flex-shrink: 0;
      }
      .os-topbar-title { display: flex; align-items: center; gap: 7px; min-width: 0; }
      .os-topbar-jugador { display: none; justify-content: flex-end; }

      /* ── Shell ── */
      .os-shell { display: flex; min-height: calc(100dvh - 44px); }

      /* ── Sidebar ── */
      .os-sidebar {
        width: 196px; flex-shrink: 0; background: var(--os-bg-sunken);
        border-right: 1px solid var(--os-line-soft);
        display: flex; flex-direction: column; overflow-y: auto;
        position: sticky; top: 44px; height: calc(100dvh - 44px);
      }

      /* ── Main ── */
      .os-main {
        flex: 1; min-width: 0; overflow-y: auto; position: relative;
        background-image:
          linear-gradient(rgba(59,78,217,0.013) 1px, transparent 1px),
          linear-gradient(90deg, rgba(59,78,217,0.013) 1px, transparent 1px);
        background-size: 36px 36px;
      }
      .os-glow {
        position: absolute; top: 0; left: 0; right: 0; height: 360px;
        background: radial-gradient(ellipse 80% 100% at 50% 0%, rgba(59,78,217,0.06) 0%, transparent 70%);
        pointer-events: none; z-index: 0;
      }
      /* En oscuro la grilla/glow recupera su intensidad original */
      [data-theme="dark"] .os-main {
        background-image:
          linear-gradient(rgba(59,78,217,0.022) 1px, transparent 1px),
          linear-gradient(90deg, rgba(59,78,217,0.022) 1px, transparent 1px);
      }
      [data-theme="dark"] .os-glow {
        background: radial-gradient(ellipse 80% 100% at 50% 0%, rgba(59,78,217,0.10) 0%, transparent 70%);
      }
      .os-content { position: relative; z-index: 1; padding: 2rem 2.5rem; max-width: 1200px; }

      /* ── Nav ── */
      .nav-group-label {
        font-family: var(--os-font-display); font-size: 11px; font-weight: 700;
        letter-spacing: 0.12em; text-transform: uppercase;
        color: rgba(107,114,128,0.8); padding: 0 0.625rem; margin-bottom: 2px;
      }
      .nav-item {
        display: flex; align-items: center; gap: 9px;
        padding: 0.35rem 0.625rem; min-height: 40px; border-radius: 7px;
        font-size: 13px; color: var(--os-muted); background: transparent;
        border-left: 2px solid transparent; text-decoration: none;
        transition: color 0.14s, background 0.14s; white-space: nowrap; letter-spacing: 0.01em;
      }
      .nav-item:hover { color: var(--os-text); background: var(--os-fill-subtle); }
      .nav-item.active { color: var(--os-text); font-weight: 600; background: rgba(59,78,217,0.13); border-left-color: var(--os-accent); }
      .nav-item .material-symbols-outlined { font-size: 18px; color: rgba(107,114,128,0.8); flex-shrink: 0; }
      .nav-item.active .material-symbols-outlined { color: var(--os-accent-light); }

      /* ── Mobile drawer (Mas) ── */
      .os-mobile-nav { display: none; position: fixed; inset: 0; z-index: 200; flex-direction: row; }
      .os-mobile-nav-inner {
        width: 264px; background: var(--os-bg-sunken); height: 100%; overflow-y: auto;
        display: flex; flex-direction: column; border-right: 1px solid var(--os-line);
        animation: os-fade-up 0.2s ease-out;
      }
      .os-overlay { flex: 1; background: rgba(0,0,0,0.65); backdrop-filter: blur(2px); }
      .menu-btn { background: none; border: none; cursor: pointer; color: var(--os-text); padding: 5px; display: flex; align-items: center; }

      /* ── Bottom nav (movil) ── */
      .os-bottomnav {
        display: none; position: fixed; bottom: 0; left: 0; right: 0; z-index: 150;
        height: calc(72px + env(safe-area-inset-bottom, 0px));
        padding-bottom: env(safe-area-inset-bottom, 0px);
        background: var(--os-bg-sunken);
        border-top: 1px solid var(--os-line);
        box-shadow: 0 -6px 20px rgba(14,23,56,0.28);
        align-items: stretch; justify-content: space-around;
      }
      .bn-item {
        flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 3px; color: var(--os-muted); text-decoration: none; background: none; border: none;
        cursor: pointer; transition: color 0.15s, transform 0.15s; padding: 8px 0;
      }
      .bn-item .material-symbols-outlined { font-size: 23px; }
      .bn-label { font-family: var(--os-font-display); font-size: 11px; font-weight: 600; letter-spacing: 0.02em; }
      .bn-item:active { transform: scale(0.9); }
      .bn-item.active { color: var(--os-accent-light); }
      .bn-item.active .material-symbols-outlined { font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24; }

      /* ── Responsive ── */
      @media (max-width: 820px) {
        .os-sidebar { display: none; }
        .os-cmdbar { display: none; }
        .os-topbar { display: flex; }
        .os-topbar-jugador { display: flex; }
        .os-bottomnav { display: flex; }
        .os-content { padding: 1.25rem 1rem calc(72px + 1.5rem + env(safe-area-inset-bottom, 0px)); }
        .os-main { background-size: 30px 30px; }
        .os-shell { min-height: calc(100dvh - 44px); }
        .os-theme-toggle { width: 44px; height: 44px; }
        .os-theme-toggle .material-symbols-outlined { font-size: 20px; }
        /* Items de nav (drawer movil): area tactil de 48px */
        .nav-item { min-height: 48px; }
      }
    </style>
  </head>
  <body>

    <!-- Desktop command bar -->
    <header class="os-cmdbar">
      <div class="cmd-brand">
        <span class="cmd-mode">
          <span class="material-symbols-outlined">bolt</span>
          <span class="cmd-mode-label">OS</span>
        </span>
        <span class="cmd-sep"></span>
        <span class="cmd-name">Pancho</span>
      </div>

      <div class="cmd-center">
        <!-- El Domino del dia ya vive en el dashboard (Hoy); aqui queda solo
             como tooltip del pill de modo para no cargar la barra. -->
        <span class="cmd-day-pill" style={`color:${tipoColor[tipoDia]};`} title={`Domino de hoy: ${dominoTexto}`}>{tipoLabel[tipoDia]}</span>
      </div>

      <div class="cmd-right">
        <!-- Captura rapida unificada: un solo input con conmutador
             preguntar al cerebro / capturar idea. -->
        <div class="cmd-capture" id="quick-wrap">
          <button type="button" class="cmd-quick-mode" id="os-quick-toggle" title="Cambiar entre preguntar y capturar" aria-label="Cambiar entre preguntar y capturar">
            <span class="material-symbols-outlined" id="os-quick-icon">psychology</span>
          </button>
          <input id="os-quick" type="text" placeholder="Preguntar al cerebro..." maxlength="400" />
        </div>
        <OSJugadorBar client:load />
        <button type="button" class="os-theme-toggle" data-os-theme-toggle aria-label="Cambiar tema">
          <span class="material-symbols-outlined" data-os-theme-icon="sun">light_mode</span>
          <span class="material-symbols-outlined" data-os-theme-icon="moon">dark_mode</span>
        </button>
        <a href="/api/os-auth?action=logout" class="cmd-logout" title="Cerrar sesion">salir</a>
      </div>
    </header>

    <!-- Mobile top bar -->
    <header class="os-topbar">
      <span class="cmd-mode">
        <span class="material-symbols-outlined">bolt</span>
        <span class="cmd-mode-label">{tipoLabel[tipoDia]}</span>
      </span>
      <span class="os-topbar-title">
        <span style="font-size:12px;color:var(--os-text);font-family:var(--os-font-display);font-weight:600;">{title}</span>
      </span>
      <div style="display:flex;align-items:center;gap:4px;">
        <button type="button" class="os-theme-toggle" data-os-theme-toggle aria-label="Cambiar tema">
          <span class="material-symbols-outlined" data-os-theme-icon="sun">light_mode</span>
          <span class="material-symbols-outlined" data-os-theme-icon="moon">dark_mode</span>
        </button>
        <button class="menu-btn" id="search-open" aria-label="Preguntar al cerebro">
          <span class="material-symbols-outlined" style="font-size:21px;color:var(--os-muted);">search</span>
        </button>
      </div>
    </header>
    <div class="os-topbar-jugador">
      <OSJugadorBar client:load />
    </div>

    <!-- Mobile nav drawer (Mas) -->
    <div class="os-mobile-nav" id="mobile-nav">
      <div class="os-mobile-nav-inner">
        <div style="display:flex;align-items:center;justify-content:space-between;padding:0.875rem 1rem;border-bottom:1px solid var(--os-line-soft);">
          <span class="cmd-mode">
            <span class="material-symbols-outlined" style="font-size:16px;">bolt</span>
            <span class="cmd-mode-label">OS · Pancho</span>
          </span>
          <button class="menu-btn" id="menu-close" aria-label="Cerrar menu">
            <span class="material-symbols-outlined" style="font-size:20px;color:var(--os-muted);">close</span>
          </button>
        </div>
        {navGroups.map((group) => (
          <div style="padding:0.875rem 0.5rem 0.125rem;">
            <p class="nav-group-label" style="margin-bottom:3px;">{group.label}</p>
            {group.items.map((item) => (
              <a href={item.href} class={`nav-item${isActive(item.href) ? ' active' : ''}`}>
                <span class="material-symbols-outlined">{ms[item.href] ?? 'circle'}</span>
                {item.label}
              </a>
            ))}
          </div>
        ))}
        <div style="margin-top:auto;padding:0.875rem 1rem;border-top:1px solid var(--os-line-soft);display:flex;flex-direction:column;gap:8px;">
          <a href="/" style="font-size:11px;color:var(--os-muted);text-decoration:none;">franciscoabad.com</a>
          <a href="/api/os-auth?action=logout" style="font-size:11px;color:var(--os-muted);text-decoration:none;">Cerrar sesion</a>
        </div>
      </div>
      <div class="os-overlay" id="overlay"></div>
    </div>

    <!-- Chat con el cerebro -->
    <div id="os-pregunta-panel" style="display:none;position:fixed;top:44px;right:0;z-index:160;width:420px;max-width:100vw;background:var(--os-surface-2);border:1px solid var(--os-line-accent);border-bottom-left-radius:10px;box-shadow:var(--os-shadow-modal);flex-direction:column;max-height:calc(100dvh - 44px);">
      <div style="display:flex;align-items:center;justify-content:space-between;padding:0.625rem 1rem;border-bottom:1px solid var(--os-line-soft);flex-shrink:0;">
        <span class="os-eyebrow">Chat con el cerebro</span>
        <div style="display:flex;align-items:center;gap:10px;">
          <button id="os-pregunta-clear" style="background:none;border:none;color:var(--os-muted);cursor:pointer;font-size:11px;font-family:var(--os-font-display);letter-spacing:0.06em;text-transform:uppercase;padding:0;" title="Limpiar conversacion">Limpiar</button>
          <button id="os-pregunta-close" style="background:none;border:none;color:var(--os-muted);cursor:pointer;font-size:18px;line-height:1;padding:0;" title="Cerrar">×</button>
        </div>
      </div>
      <div id="os-pregunta-body" style="padding:0.875rem 1rem;font-size:13px;color:var(--os-text-2);line-height:1.65;overflow-y:auto;flex:1;min-height:120px;display:flex;flex-direction:column;gap:10px;"></div>
      <div style="display:flex;gap:6px;padding:0.625rem 0.75rem;border-top:1px solid var(--os-line-soft);flex-shrink:0;">
        <input id="os-pregunta-input" type="text" placeholder="Escribe tu pregunta..." maxlength="400"
          style="flex:1;background:var(--os-fill-subtle);border:1px solid var(--os-line);border-radius:6px;padding:7px 10px;font-size:12px;color:var(--os-text);font-family:var(--os-font-body);outline:none;" />
        <button id="os-pregunta-send" class="os-btn">Enviar</button>
      </div>
    </div>

    <div class="os-shell">
      <!-- Desktop sidebar -->
      <nav class="os-sidebar">
        {navGroups.map((group) => (
          <div style="padding:0.875rem 0.5rem 0.125rem;">
            <p class="nav-group-label">{group.label}</p>
            {group.items.map((item) => (
              <a href={item.href} class={`nav-item${isActive(item.href) ? ' active' : ''}`}>
                <span class="material-symbols-outlined">{ms[item.href] ?? 'circle'}</span>
                {item.label}
              </a>
            ))}
          </div>
        ))}
        <div style="margin-top:auto;padding:0.875rem 0.875rem 1rem;border-top:1px solid var(--os-line-soft);">
          <a href="/" style="display:block;font-size:11px;color:rgba(107,114,128,0.6);text-decoration:none;letter-spacing:0.03em;">franciscoabad.com</a>
        </div>
      </nav>

      <!-- Main content -->
      <main class="os-main">
        <div class="os-glow" aria-hidden="true"></div>
        <div class="os-content">
          <slot />
        </div>
      </main>
    </div>

    <!-- Taski: burbuja de chat directo con Hermes (visible en todo el OS) -->
    <TaskiBubble client:load />

    <!-- Bottom nav (movil) -->
    <nav class="os-bottomnav">
      {bottomNav.map((item) => (
        <a href={item.href} class={`bn-item${isActive(item.href) ? ' active' : ''}`}>
          <span class="material-symbols-outlined">{item.icon}</span>
          <span class="bn-label">{item.label}</span>
        </a>
      ))}
      <button class="bn-item" id="bn-more" type="button" aria-label="Mas secciones">
        <span class="material-symbols-outlined">{anyBottomActive ? 'apps' : 'apps'}</span>
        <span class="bn-label">Mas</span>
      </button>
    </nav>

    <script>
      // ── Theme toggle (os-theme) ──
      const OS_THEME_KEY = 'os-theme';
      const OS_LIGHT_COLOR = '#FAFAF7';
      const OS_DARK_COLOR = '#060C1E';
      const osThemeColorMeta = document.getElementById('os-theme-color-meta');

      function getOsTheme(): string {
        return document.documentElement.getAttribute('data-theme') || 'light';
      }
      function applyOsTheme(theme: string) {
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem(OS_THEME_KEY, theme);
        if (osThemeColorMeta) osThemeColorMeta.setAttribute('content', theme === 'dark' ? OS_DARK_COLOR : OS_LIGHT_COLOR);
        document.querySelectorAll('[data-os-theme-icon="sun"]').forEach((el) => {
          (el as HTMLElement).style.display = theme === 'dark' ? 'flex' : 'none';
        });
        document.querySelectorAll('[data-os-theme-icon="moon"]').forEach((el) => {
          (el as HTMLElement).style.display = theme === 'light' ? 'flex' : 'none';
        });
      }
      // Guarda: evita doble-init si Astro reejecuta el script en navegacion client-side.
      if (!(window as any).__osThemeToggleInit) {
        (window as any).__osThemeToggleInit = true;
        applyOsTheme(getOsTheme());
        document.querySelectorAll('[data-os-theme-toggle]').forEach((btn) => {
          btn.addEventListener('click', () => {
            applyOsTheme(getOsTheme() === 'dark' ? 'light' : 'dark');
          });
        });
      }

      // ── Mobile drawer (Mas) ──
      const menuClose = document.getElementById('menu-close');
      const mobileNav = document.getElementById('mobile-nav');
      const overlay   = document.getElementById('overlay');
      const bnMore    = document.getElementById('bn-more');

      const openDrawer  = () => { if (mobileNav) mobileNav.style.display = 'flex'; };
      const closeDrawer = () => { if (mobileNav) mobileNav.style.display = 'none'; };
      bnMore?.addEventListener('click', openDrawer);
      menuClose?.addEventListener('click', closeDrawer);
      overlay?.addEventListener('click', closeDrawer);

      // ── Chat con el cerebro ──
      const preguntaPanel = document.getElementById('os-pregunta-panel') as HTMLElement | null;
      const preguntaBody  = document.getElementById('os-pregunta-body') as HTMLElement | null;
      const preguntaClose = document.getElementById('os-pregunta-close') as HTMLElement | null;
      const preguntaClear = document.getElementById('os-pregunta-clear') as HTMLElement | null;
      const preguntaInput = document.getElementById('os-pregunta-input') as HTMLInputElement | null;
      const preguntaSend  = document.getElementById('os-pregunta-send') as HTMLButtonElement | null;
      const searchOpen    = document.getElementById('search-open');

      type ChatTurn = { role: 'user' | 'brain' | 'error'; text: string };
      const CHAT_KEY = 'os-chat-history';
      let chatHistory: ChatTurn[] = [];
      try { chatHistory = JSON.parse(sessionStorage.getItem(CHAT_KEY) ?? '[]'); } catch { chatHistory = []; }

      const escHtml = (s: string) =>
        s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');

      function renderChat(pending = false) {
        if (!preguntaBody) return;
        if (!chatHistory.length && !pending) {
          preguntaBody.innerHTML = '<p style="color:var(--os-muted);font-size:12px;margin:auto;text-align:center;">Pregunta lo que quieras. El cerebro recuerda esta conversacion.</p>';
          return;
        }
        let html = chatHistory.map((t) => {
          if (t.role === 'user') {
            return '<div style="align-self:flex-end;max-width:85%;background:var(--os-accent);color:#fff;padding:7px 11px;border-radius:10px 10px 2px 10px;font-size:13px;white-space:pre-wrap;">' + escHtml(t.text) + '</div>';
          }
          if (t.role === 'error') {
            return '<div style="align-self:flex-start;max-width:85%;color:var(--os-error);font-size:12px;padding:2px 0;">' + escHtml(t.text) + '</div>';
          }
          return '<div style="align-self:flex-start;max-width:90%;background:var(--os-fill-subtle);border:1px solid var(--os-line-soft);color:var(--os-text-2);padding:8px 11px;border-radius:10px 10px 10px 2px;font-size:13px;white-space:pre-wrap;">' + escHtml(t.text) + '</div>';
        }).join('');
        if (pending) {
          html += '<div style="align-self:flex-start;color:var(--os-muted);font-size:12px;padding:2px 0;">Consultando el cerebro...</div>';
        }
        preguntaBody.innerHTML = html;
        preguntaBody.scrollTop = preguntaBody.scrollHeight;
      }

      function openChat() {
        if (preguntaPanel) preguntaPanel.style.display = 'flex';
        renderChat();
        preguntaInput?.focus();
      }
      searchOpen?.addEventListener('click', openChat);

      async function askBrain(q: string) {
        if (!q.trim()) return;
        chatHistory.push({ role: 'user', text: q.trim() });
        sessionStorage.setItem(CHAT_KEY, JSON.stringify(chatHistory.slice(-50)));
        if (preguntaPanel) preguntaPanel.style.display = 'flex';
        renderChat(true);
        try {
          const res = await fetch('/api/os/preguntar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ pregunta: q.trim() }),
          });
          const data: { respuesta?: string; error?: string } = await res.json();
          if (data.error) {
            chatHistory.push({ role: 'error', text: 'Error: ' + data.error });
          } else {
            chatHistory.push({ role: 'brain', text: data.respuesta ?? '(sin respuesta)' });
          }
        } catch {
          chatHistory.push({ role: 'error', text: 'Error de conexion.' });
        }
        sessionStorage.setItem(CHAT_KEY, JSON.stringify(chatHistory.slice(-50)));
        renderChat();
      }

      const sendFromPanel = () => {
        if (!preguntaInput) return;
        const q = preguntaInput.value.trim();
        if (!q) return;
        preguntaInput.value = '';
        askBrain(q);
      };
      preguntaSend?.addEventListener('click', sendFromPanel);
      preguntaInput?.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter') { e.preventDefault(); sendFromPanel(); }
      });
      preguntaClose?.addEventListener('click', () => { if (preguntaPanel) preguntaPanel.style.display = 'none'; });
      preguntaClear?.addEventListener('click', () => {
        chatHistory = [];
        sessionStorage.removeItem(CHAT_KEY);
        renderChat();
      });

      // ── Captura rapida unificada (un input, conmutador preguntar/capturar) ──
      // Mismos endpoints de siempre: /api/os/preguntar (chat) y /api/os/capturar.
      const quickInput  = document.getElementById('os-quick') as HTMLInputElement | null;
      const quickToggle = document.getElementById('os-quick-toggle');
      const quickIcon   = document.getElementById('os-quick-icon');
      let quickMode: 'preguntar' | 'capturar' = 'preguntar';

      function aplicarQuickMode() {
        if (quickInput) quickInput.placeholder = quickMode === 'preguntar' ? 'Preguntar al cerebro...' : 'Capturar idea...';
        if (quickIcon) quickIcon.textContent = quickMode === 'preguntar' ? 'psychology' : 'edit_note';
      }
      quickToggle?.addEventListener('click', () => {
        quickMode = quickMode === 'preguntar' ? 'capturar' : 'preguntar';
        aplicarQuickMode();
        quickInput?.focus();
      });

      async function sendCapture(texto: string) {
        if (!quickInput) return;
        quickInput.placeholder = 'Guardando...';
        try {
          const res = await fetch('/api/os/capturar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ texto }),
          });
          const data: { ok?: boolean; error?: string } = await res.json();
          quickInput.placeholder = (res.ok && data.ok) ? 'Guardado en el cerebro' : 'Error al guardar';
        } catch {
          quickInput.placeholder = 'Error al guardar';
        }
        setTimeout(aplicarQuickMode, 1800);
      }

      quickInput?.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key !== 'Enter') return;
        const v = quickInput.value.trim();
        if (quickMode === 'preguntar') {
          if (!v) { openChat(); return; }
          quickInput.value = '';
          askBrain(v);
        } else {
          if (!v) return;
          quickInput.value = '';
          sendCapture(v);
        }
      });

      // ── PWA: registrar service worker ──
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js', { scope: '/os' }).catch(() => {});
        });
      }
    </script>
  </body>
</html>
