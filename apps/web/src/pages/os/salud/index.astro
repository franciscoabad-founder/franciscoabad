---
export const prerender = false;
import OSLayout from '../../../layouts/OSLayout.astro';
import OSSaludDashboard from '../../../os/components/salud/OSSaludDashboard';
import OSSaludNav from '../../../os/components/salud/OSSaludNav.astro';

const fechaLarga = new Date().toLocaleDateString('es-EC', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
});
---

<OSLayout title="Salud">
  <div class="os-fade-up">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;margin-bottom:1rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Cuerpo</p>
        <h1 class="os-h1">Salud</h1>
      </div>
      <span style="font-size:12px;color:var(--os-muted);text-transform:capitalize;">{fechaLarga}</span>
    </div>
    <OSSaludNav activo="dashboard" />
    <OSSaludDashboard client:load />
  </div>
</OSLayout>
