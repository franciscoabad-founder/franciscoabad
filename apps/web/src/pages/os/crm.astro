---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
---

<OSLayout title="CRM">
  <div class="os-fade-up">

    <!-- Header -->
    <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.25rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Growth OS</p>
        <h1 class="os-h1">CRM</h1>
        <p style="font-size:var(--os-text-sm);color:var(--os-muted);margin:4px 0 0;">Pipeline de leads y deals</p>
      </div>
      <div style="display:flex;align-items:center;gap:12px;">
        <p id="lead-count" style="font-size:var(--os-text-xs);color:var(--os-muted);margin:0;">Cargando...</p>
        <div style="display:flex;background:var(--os-fill-subtle);border:1px solid var(--os-line);border-radius:var(--os-r-sm);overflow:hidden;">
          <button id="btn-kanban" onclick="setView('kanban')" style="padding:5px 13px;min-height:var(--os-tap-min);font-size:11px;font-family:var(--os-font-display);font-weight:700;letter-spacing:0.06em;text-transform:uppercase;background:rgba(59,78,217,0.22);color:var(--os-accent-light);border:none;cursor:pointer;transition:background .15s,color .15s;">Kanban</button>
          <button id="btn-tabla" onclick="setView('tabla')" style="padding:5px 13px;min-height:var(--os-tap-min);font-size:11px;font-family:var(--os-font-display);font-weight:700;letter-spacing:0.06em;text-transform:uppercase;background:transparent;color:var(--os-muted);border:none;cursor:pointer;transition:background .15s,color .15s;">Tabla</button>
        </div>
      </div>
    </div>

    <!-- KPI row -->
    <div class="os-crm-kpis" style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:1.25rem;">
      <div class="os-kpi">
        <p class="os-kpi-label">Revenue Pipeline</p>
        <p class="os-kpi-value" id="kpi-pipeline">$0</p>
        <div style="display:flex;align-items:center;gap:5px;">
          <span class="material-symbols-outlined" style="font-size:14px;color:var(--os-accent-light);">trending_up</span>
          <span style="font-size:11px;color:var(--os-muted);">Deals abiertos</span>
        </div>
      </div>
      <div class="os-kpi">
        <p class="os-kpi-label">Active Deals</p>
        <p class="os-kpi-value" id="kpi-deals">0</p>
        <div style="display:flex;align-items:center;gap:5px;">
          <span class="material-symbols-outlined" style="font-size:14px;color:var(--os-accent-light);">workspaces</span>
          <span style="font-size:11px;color:var(--os-muted);">Sin cerrar</span>
        </div>
      </div>
    </div>

    <!-- Filter pills -->
    <div class="os-hscroll" style="display:flex;gap:8px;margin-bottom:1.25rem;padding-bottom:2px;">
      <button id="filter-todos" onclick="setFilter('todos')" class="os-pill os-pill-accent" style="border:none;cursor:pointer;min-height:var(--os-tap-min);">Todos</button>
      <button id="filter-nuevo" onclick="setFilter('nuevo')" class="os-pill" style="background:var(--os-fill-subtle);color:var(--os-muted);border:none;cursor:pointer;min-height:var(--os-tap-min);">Nuevo</button>
      <button id="filter-prospecto" onclick="setFilter('prospecto')" class="os-pill" style="background:var(--os-fill-subtle);color:var(--os-muted);border:none;cursor:pointer;min-height:var(--os-tap-min);">Prospecto</button>
      <button id="filter-contacto" onclick="setFilter('contacto')" class="os-pill" style="background:var(--os-fill-subtle);color:var(--os-muted);border:none;cursor:pointer;min-height:var(--os-tap-min);">Contacto</button>
      <button id="filter-propuesta" onclick="setFilter('propuesta')" class="os-pill" style="background:var(--os-fill-subtle);color:var(--os-muted);border:none;cursor:pointer;min-height:var(--os-tap-min);">Propuesta</button>
      <button id="filter-negociacion" onclick="setFilter('negociacion')" class="os-pill" style="background:var(--os-fill-subtle);color:var(--os-muted);border:none;cursor:pointer;min-height:var(--os-tap-min);">Negociacion</button>
      <button id="filter-cerrado" onclick="setFilter('cerrado')" class="os-pill" style="background:var(--os-fill-subtle);color:var(--os-muted);border:none;cursor:pointer;min-height:var(--os-tap-min);">Cerrado</button>
    </div>

    <!-- Quick-add form -->
    <form id="lead-form" class="os-card-2" style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-end;margin-bottom:1.25rem;padding:1rem;">
      <input name="nombre" type="text" placeholder="Nombre del lead *" required
        class="os-input" style="flex:2;min-width:140px;font-size:var(--os-text-sm);padding:6px 11px;" />
      <input name="empresa" type="text" placeholder="Empresa"
        class="os-input" style="flex:1;min-width:110px;font-size:var(--os-text-sm);padding:6px 11px;" />
      <input name="proyecto" type="text" placeholder="Proyecto"
        class="os-input" style="flex:1;min-width:100px;font-size:var(--os-text-sm);padding:6px 11px;" />
      <select name="etapa"
        class="os-input" style="font-size:var(--os-text-sm);padding:6px 11px;cursor:pointer;background:var(--os-bg);">
        <option value="nuevo">Nuevo</option>
        <option value="prospecto">Prospecto</option>
        <option value="contacto">Contacto</option>
        <option value="propuesta">Propuesta</option>
        <option value="negociacion">Negociacion</option>
        <option value="cerrado">Cerrado</option>
      </select>
      <button type="submit" class="os-btn" style="padding:6px 16px;font-size:var(--os-text-sm);">
        <span class="material-symbols-outlined" style="font-size:16px;">add</span>
        Agregar
      </button>
      <p id="form-msg" style="font-size:var(--os-text-xs);color:var(--os-error);width:100%;margin:0;display:none;"></p>
    </form>

    <!-- Kanban view -->
    <div id="crm-kanban" class="os-hscroll" style="display:flex;gap:12px;padding-bottom:1rem;min-height:300px;">
      <div style="color:var(--os-muted);font-size:13px;padding:1rem 0;">Cargando...</div>
    </div>

    <!-- Tabla view -->
    <div id="crm-tabla" style="display:none;overflow-x:auto;">
      <table style="width:100%;border-collapse:collapse;font-size:13px;min-width:600px;">
        <thead>
          <tr>
            {['Lead','Empresa','Proyecto','Etapa'].map(h => (
              <th style="text-align:left;padding:8px 10px;font-family:var(--os-font-display);font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--os-muted);border-bottom:1px solid var(--os-line);">{h}</th>
            ))}
            {['Prob %','Scoring','Valor'].map(h => (
              <th style="text-align:right;padding:8px 10px;font-family:var(--os-font-display);font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--os-muted);border-bottom:1px solid var(--os-line);">{h}</th>
            ))}
            <th style="text-align:left;padding:8px 10px;font-family:var(--os-font-display);font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--os-muted);border-bottom:1px solid var(--os-line);">Etiquetas</th>
            <th style="border-bottom:1px solid var(--os-line);padding:8px 10px;"></th>
          </tr>
        </thead>
        <tbody id="tabla-body">
          <tr><td colspan="9" style="padding:2rem;text-align:center;color:var(--os-muted);font-size:var(--os-text-sm);">Cargando...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- FAB: enfoca el quick-add -->
  <button class="os-fab" onclick="focusLeadForm()" aria-label="Agregar lead">
    <span class="material-symbols-outlined" style="font-size:26px;">add</span>
  </button>

  <style>
    @media (max-width: 820px) {
      .os-crm-kpis { grid-template-columns: 1fr 1fr !important; }
    }
  </style>
</OSLayout>

<script is:inline>
var ETAPAS = ['nuevo','prospecto','contacto','propuesta','negociacion','cerrado'];
var ETAPA_LABEL = {nuevo:'Nuevo',prospecto:'Prospecto',contacto:'Contacto',propuesta:'Propuesta',negociacion:'Negociacion',cerrado:'Cerrado'};
// Colores de etapa con tokens duales: fg = texto/punto, bg = relleno del pill.
var ETAPA_COLOR = {
  nuevo:       { fg:'var(--os-muted)',        bg:'var(--os-fill-subtle)' },
  prospecto:   { fg:'var(--os-text-2)',       bg:'var(--os-fill-subtle)' },
  contacto:    { fg:'var(--os-accent-light)', bg:'rgba(59,78,217,0.14)' },
  propuesta:   { fg:'var(--os-accent)',       bg:'rgba(59,78,217,0.14)' },
  negociacion: { fg:'var(--os-champagne)',    bg:'rgba(181,152,90,0.16)' },
  cerrado:     { fg:'var(--os-champagne)',    bg:'rgba(181,152,90,0.16)' }
};
var ETAPA_COLOR_DEFAULT = { fg:'var(--os-muted)', bg:'var(--os-fill-subtle)' };
var allLeads = [];
var activeFilter = 'todos';

function esc(s) {
  return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function fmtValor(n) {
  if (!n && n !== 0) return '';
  return '$' + Number(n).toLocaleString('es-EC', {minimumFractionDigits:0,maximumFractionDigits:2});
}

function focusLeadForm() {
  var form = document.getElementById('lead-form');
  if (!form) return;
  form.scrollIntoView({ behavior: 'smooth', block: 'center' });
  var first = form.querySelector('input[name="nombre"]');
  if (first) setTimeout(function() { first.focus(); }, 350);
}

var VIEW_ON_BG = 'rgba(59,78,217,0.22)';
function setView(v) {
  var kanban = document.getElementById('crm-kanban');
  var tabla = document.getElementById('crm-tabla');
  var btnK = document.getElementById('btn-kanban');
  var btnT = document.getElementById('btn-tabla');
  var isKanban = v === 'kanban';
  if (kanban) kanban.style.display = isKanban ? 'flex' : 'none';
  if (tabla) tabla.style.display = isKanban ? 'none' : 'block';
  if (btnK) { btnK.style.background = isKanban ? VIEW_ON_BG : 'transparent'; btnK.style.color = isKanban ? 'var(--os-accent-light)' : 'var(--os-muted)'; }
  if (btnT) { btnT.style.background = isKanban ? 'transparent' : VIEW_ON_BG; btnT.style.color = isKanban ? 'var(--os-muted)' : 'var(--os-accent-light)'; }
}

function setFilter(f) {
  activeFilter = f;
  ['todos'].concat(ETAPAS).forEach(function(key) {
    var btn = document.getElementById('filter-' + key);
    if (!btn) return;
    var on = key === f;
    btn.style.background = on ? VIEW_ON_BG : 'var(--os-fill-subtle)';
    btn.style.color = on ? 'var(--os-accent-light)' : 'var(--os-muted)';
  });
  renderAll(allLeads);
}

function filtered(leads) {
  if (activeFilter === 'todos') return leads;
  return leads.filter(function(l) { return l.etapa === activeFilter; });
}

function renderKanban(leads) {
  var kanban = document.getElementById('crm-kanban');
  if (!kanban) return;
  var etapas = activeFilter === 'todos' ? ETAPAS : [activeFilter];
  kanban.innerHTML = etapas.map(function(etapa) {
    var ec = ETAPA_COLOR[etapa] || ETAPA_COLOR_DEFAULT;
    var cols = leads.filter(function(l) { return l.etapa === etapa; });
    var cards = cols.length === 0
      ? '<div style="background:var(--os-surface-2);border:1px dashed var(--os-line);border-radius:12px;padding:1.25rem;text-align:center;"><p style="font-size:var(--os-text-xs);color:var(--os-muted);margin:0;">Sin leads</p></div>'
      : cols.map(function(lead) {
          var priority = (lead.scoring && lead.scoring >= 70) || (lead.probabilidad && lead.probabilidad >= 70);
          return '<div style="background:var(--os-surface);border:1px solid var(--os-line);border-radius:12px;padding:0.875rem;position:relative;box-shadow:var(--os-shadow-card);">'
            + '<button onclick="deleteLead(\'' + lead.id + '\')" title="Eliminar" style="position:absolute;top:2px;right:2px;background:none;border:none;cursor:pointer;color:var(--os-muted);font-size:16px;line-height:1;padding:0;min-width:var(--os-tap-min);min-height:var(--os-tap-min);display:flex;align-items:center;justify-content:center;"><span class="material-symbols-outlined" style="font-size:16px;">close</span></button>'
            + '<div style="display:flex;align-items:center;gap:6px;margin:0 30px 4px 0;">'
            + (priority ? '<span class="material-symbols-outlined fill" style="font-size:15px;color:var(--os-champagne);flex-shrink:0;">star</span>' : '')
            + '<p style="font-family:var(--os-font-display);font-size:var(--os-text-sm);font-weight:600;color:var(--os-text);margin:0;">' + esc(lead.nombre) + '</p>'
            + '</div>'
            + (lead.empresa ? '<p style="font-size:11px;color:var(--os-muted);margin:0 0 6px;">' + esc(lead.empresa) + '</p>' : '')
            + (lead.valor ? '<p style="font-family:var(--os-font-mono);font-size:var(--os-text-sm);font-weight:700;color:var(--os-champagne);margin:0 0 6px;">' + fmtValor(lead.valor) + '</p>' : '')
            + (lead.proyecto ? '<p style="font-size:11px;color:var(--os-text);margin:0 0 6px;">' + esc(lead.proyecto) + '</p>' : '')
            + '<span style="display:inline-flex;align-items:center;gap:5px;padding:2px 9px;border-radius:999px;font-family:var(--os-font-display);font-size:11px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:' + ec.fg + ';background:' + ec.bg + ';">' + esc(ETAPA_LABEL[etapa]) + '</span>'
            + '</div>';
        }).join('');
    return '<div style="min-width:210px;flex-shrink:0;display:flex;flex-direction:column;gap:8px;">'
      + '<div style="display:flex;align-items:center;gap:6px;padding:0 2px;margin-bottom:4px;">'
      + '<span style="width:7px;height:7px;border-radius:50%;background:' + ec.fg + ';flex-shrink:0;"></span>'
      + '<p style="font-family:var(--os-font-display);font-size:11px;font-weight:700;letter-spacing:0.10em;text-transform:uppercase;color:var(--os-muted);margin:0;">' + esc(ETAPA_LABEL[etapa]) + '</p>'
      + '<span style="font-family:var(--os-font-mono);font-size:11px;color:var(--os-muted);margin-left:auto;">' + cols.length + '</span>'
      + '</div>'
      + cards
      + '</div>';
  }).join('');
}

function renderTabla(leads) {
  var tbody = document.getElementById('tabla-body');
  if (!tbody) return;
  if (!leads.length) {
    tbody.innerHTML = '<tr><td colspan="9" style="padding:2rem;text-align:center;color:var(--os-muted);font-size:var(--os-text-sm);">Sin leads. Agrega uno arriba.</td></tr>';
    return;
  }
  tbody.innerHTML = leads.map(function(l) {
    var tags = (l.etiquetas || []).map(function(t) {
      return '<span style="font-size:11px;color:var(--os-muted);background:var(--os-fill-subtle);padding:2px 7px;border-radius:4px;margin-right:3px;">' + esc(t) + '</span>';
    }).join('');
    var ec = ETAPA_COLOR[l.etapa] || ETAPA_COLOR_DEFAULT;
    var etapaLabel = ETAPA_LABEL[l.etapa] || l.etapa;
    var priority = (l.scoring && l.scoring >= 70) || (l.probabilidad && l.probabilidad >= 70);
    var star = priority ? '<span class="material-symbols-outlined fill" style="font-size:13px;color:var(--os-champagne);vertical-align:middle;margin-right:5px;">star</span>' : '';
    return '<tr style="border-bottom:1px solid var(--os-line-soft);transition:background .12s;" onmouseenter="this.style.background=\'rgba(59,78,217,0.06)\'" onmouseleave="this.style.background=\'transparent\'">'
      + '<td style="padding:9px 10px;color:var(--os-text);font-weight:600;white-space:nowrap;">' + star + esc(l.nombre) + '</td>'
      + '<td style="padding:9px 10px;color:var(--os-text-2);">' + esc(l.empresa || '') + '</td>'
      + '<td style="padding:9px 10px;color:var(--os-text-2);">' + esc(l.proyecto || '') + '</td>'
      + '<td style="padding:9px 10px;"><span style="font-size:11px;font-weight:700;font-family:var(--os-font-display);letter-spacing:0.05em;color:' + ec.fg + ';background:' + ec.bg + ';padding:2px 9px;border-radius:999px;">' + esc(etapaLabel) + '</span></td>'
      + '<td style="padding:9px 10px;text-align:right;color:var(--os-champagne);font-family:var(--os-font-mono);font-weight:700;">' + (l.probabilidad || 0) + '%</td>'
      + '<td style="padding:9px 10px;text-align:right;color:var(--os-champagne);font-family:var(--os-font-mono);font-weight:700;">' + (l.scoring || 0) + '</td>'
      + '<td style="padding:9px 10px;text-align:right;color:var(--os-champagne);font-family:var(--os-font-mono);font-weight:700;">' + (l.valor ? fmtValor(l.valor) : '') + '</td>'
      + '<td style="padding:9px 10px;">' + (tags || '<span style="color:var(--os-muted);font-size:11px;">-</span>') + '</td>'
      + '<td style="padding:9px 10px;text-align:right;"><button onclick="deleteLead(\'' + l.id + '\')" title="Eliminar" style="background:none;border:none;color:var(--os-muted);cursor:pointer;padding:0;line-height:1;min-width:var(--os-tap-min);min-height:var(--os-tap-min);display:inline-flex;align-items:center;justify-content:center;"><span class="material-symbols-outlined" style="font-size:15px;">close</span></button></td>'
      + '</tr>';
  }).join('');
}

function updateKpis(leads) {
  var activos = leads.filter(function(l) { return l.etapa !== 'cerrado'; });
  var pipeline = activos.reduce(function(sum, l) { return sum + (Number(l.valor) || 0); }, 0);
  var pEl = document.getElementById('kpi-pipeline');
  var dEl = document.getElementById('kpi-deals');
  if (pEl) pEl.textContent = fmtValor(pipeline) || '$0';
  if (dEl) dEl.textContent = String(activos.length);
}

function renderAll(leads) {
  allLeads = leads;
  var countEl = document.getElementById('lead-count');
  if (countEl) countEl.textContent = leads.length + ' leads';
  updateKpis(leads);
  var view = filtered(leads);
  renderKanban(view);
  renderTabla(view);
}

async function loadLeads() {
  try {
    var res = await fetch('/api/os/leads');
    if (!res.ok) throw new Error(String(res.status));
    var data = await res.json();
    renderAll(data.leads || []);
  } catch(e) {
    var kanban = document.getElementById('crm-kanban');
    if (kanban) kanban.innerHTML = '<div style="color:var(--os-error);font-size:var(--os-text-sm);padding:1rem 0;">' + e.message + '</div>';
  }
}

// NOTA fase 2a: el confirm() de borrado se mantiene a proposito (reemplazarlo
// implica rehacer el flujo). El alert() de error se cambio por el mensaje inline #form-msg.
async function deleteLead(id) {
  if (!confirm('Eliminar este lead?')) return;
  try {
    var res = await fetch('/api/os/leads?id=' + encodeURIComponent(id), { method: 'DELETE' });
    if (!res.ok) throw new Error(String(res.status));
    var msgOk = document.getElementById('form-msg');
    if (msgOk) msgOk.style.display = 'none';
    await loadLeads();
  } catch(e) {
    var msg = document.getElementById('form-msg');
    if (msg) { msg.textContent = 'Error al eliminar: ' + e.message; msg.style.display = 'block'; }
  }
}

var form = document.getElementById('lead-form');
if (form) {
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    var msg = document.getElementById('form-msg');
    if (msg) msg.style.display = 'none';
    var fd = new FormData(form);
    var body = { nombre: fd.get('nombre'), empresa: fd.get('empresa'), proyecto: fd.get('proyecto'), etapa: fd.get('etapa') };
    try {
      var res = await fetch('/api/os/leads', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      var json = await res.json();
      if (!res.ok) throw new Error(json.error || String(res.status));
      form.reset();
      await loadLeads();
    } catch(err) {
      if (msg) { msg.textContent = 'Error: ' + err.message; msg.style.display = 'block'; }
    }
  });
}

loadLeads();
</script>
