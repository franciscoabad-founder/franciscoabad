---
export const prerender = false;

import OSLayout from '../../layouts/OSLayout.astro';
import OSGraphBrain from '../../os/components/OSGraphBrain';
---

<OSLayout title="Cerebro">
  <div>
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1.75rem;">
      <h1 style="font-size:1.375rem;font-weight:700;color:#F4F6F8;margin:0;">Cerebro</h1>
      <p id="nota-count" style="font-size:12px;color:#6B7280;margin:0;">Cargando...</p>
    </div>

    <!-- Search -->
    <div style="position:relative;margin-bottom:1rem;">
      <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#6B7280;pointer-events:none;">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      </span>
      <input
        id="brain-search"
        type="text"
        placeholder="Buscar en gbrain..."
        autocomplete="off"
        style="width:100%;background:#131F4A;border:1px solid rgba(232,234,240,0.12);border-radius:8px;padding:0.75rem 0.875rem 0.75rem 2.375rem;font-size:14px;color:#F4F6F8;font-family:'Inter',sans-serif;box-sizing:border-box;outline:none;"
      />
    </div>

    <!-- Search results -->
    <div id="search-results" style="display:none;margin-bottom:1.25rem;"></div>

    <!-- Force graph -->
    <div style="background:#131F4A;border:1px solid rgba(59,78,217,0.2);border-radius:12px;padding:1.25rem;margin-bottom:1.5rem;">
      <p style="font-family:'Montserrat',sans-serif;font-size:9px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:#6B7280;margin:0 0 1rem;">Grafo de ideas</p>
      <OSGraphBrain client:load />
    </div>

    <!-- Notes grid -->
    <div id="notes-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px;">
      <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.06);border-radius:12px;padding:1.125rem;color:#6B7280;font-size:13px;">
        Cargando notas...
      </div>
    </div>
  </div>

  <!-- Note modal -->
  <div id="note-modal" style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(10,16,32,0.82);backdrop-filter:blur(4px);padding:1.5rem;overflow:auto;" role="dialog" aria-modal="true">
    <div id="note-modal-inner" style="max-width:680px;margin:0 auto;background:#0E1738;border:1px solid rgba(59,78,217,0.3);border-radius:14px;padding:1.75rem;position:relative;min-height:200px;">
      <button id="note-modal-close" aria-label="Cerrar" style="position:absolute;top:14px;right:16px;background:none;border:none;color:#6B7280;font-size:22px;cursor:pointer;line-height:1;padding:0;">x</button>
      <div id="note-modal-content" style="color:#F4F6F8;"></div>
    </div>
  </div>
</OSLayout>

<script is:inline>
  // ---- helpers ----
  function esc(s) {
    return String(s || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function mdToHtml(md) {
    return md
      .replace(/^#### (.+)$/gm, '<b style="color:#6B7AE8;font-size:12px;">$1</b>')
      .replace(/^### (.+)$/gm, '<b style="color:#94A3B8;font-size:13px;">$1</b>')
      .replace(/^## (.+)$/gm, '<b style="color:#F4F6F8;font-size:14px;">$1</b>')
      .replace(/^# (.+)$/gm, '<b style="color:#F4F6F8;font-size:16px;">$1</b>')
      .replace(/\*\*(.+?)\*\*/g, '<b>$1</b>')
      .replace(/`(.+?)`/g, '<code style="background:rgba(59,78,217,0.18);padding:1px 5px;border-radius:3px;font-size:12px;">$1</code>')
      .replace(/^- (.+)$/gm, '<span style="display:block;padding-left:12px;">• $1</span>')
      .replace(/^\d+\. (.+)$/gm, '<span style="display:block;padding-left:12px;">$1</span>')
      .replace(/\n\n/g, '<br><br>')
      .replace(/\n/g, '<br>');
  }

  // ---- modal ----
  var modal = document.getElementById('note-modal');
  var modalContent = document.getElementById('note-modal-content');
  var modalClose = document.getElementById('note-modal-close');

  function openNote(slug) {
    if (!modal || !modalContent) return;
    modal.style.display = 'block';
    modalContent.innerHTML = '<p style="color:#6B7280;font-size:13px;">Cargando...</p>';
    fetch('/api/brain/note?slug=' + encodeURIComponent(slug))
      .then(function(r) { return r.json(); })
      .then(function(n) {
        if (n.error) { modalContent.innerHTML = '<p style="color:#F87171;">Error: ' + esc(n.error) + '</p>'; return; }
        var tagsHtml = (n.tags || []).map(function(t) {
          return '<span style="font-size:10px;color:#6B7280;background:rgba(232,234,240,0.07);padding:2px 8px;border-radius:4px;margin-right:4px;">#' + esc(t) + '</span>';
        }).join('');
        modalContent.innerHTML =
          '<p style="font-size:10px;color:#6B7AE8;letter-spacing:0.1em;text-transform:uppercase;font-family:Montserrat,sans-serif;margin:0 0 10px;">' + esc(n.tipo) + '</p>'
          + '<h2 style="font-size:1.1rem;font-weight:700;color:#F4F6F8;margin:0 0 10px;line-height:1.3;font-family:Montserrat,sans-serif;">' + esc(n.titulo) + '</h2>'
          + '<div style="margin-bottom:14px;flex-wrap:wrap;">' + tagsHtml + '</div>'
          + '<p style="font-size:10px;color:rgba(107,114,128,0.6);margin:0 0 16px;">' + esc(n.fecha) + '</p>'
          + '<div style="font-size:13px;color:#CBD5E1;line-height:1.7;border-top:1px solid rgba(232,234,240,0.1);padding-top:16px;">' + mdToHtml(n.contenido || '') + '</div>';
      })
      .catch(function() { modalContent.innerHTML = '<p style="color:#F87171;">Error al cargar la nota.</p>'; });
  }

  if (modalClose) modalClose.addEventListener('click', function() { modal.style.display = 'none'; });
  if (modal) modal.addEventListener('click', function(e) { if (e.target === modal) modal.style.display = 'none'; });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && modal) modal.style.display = 'none'; });

  // ---- notes grid ----
  async function loadNotes() {
    try {
      var res = await fetch('/api/brain/notes?limit=12');
      if (!res.ok) throw new Error(String(res.status));
      var data = await res.json();
      var notes = data.notes;

      var countEl = document.getElementById('nota-count');
      if (countEl) countEl.textContent = notes.length + ' notas indexadas';

      var grid = document.getElementById('notes-grid');
      if (!grid || !notes.length) return;

      grid.innerHTML = notes.map(function(n) {
        var tagsHtml = (n.tags || []).map(function(t) {
          return '<span style="font-size:10px;color:#6B7280;background:rgba(232,234,240,0.05);padding:2px 7px;border-radius:4px;">#' + esc(t) + '</span>';
        }).join('');
        return '<div data-slug="' + esc(n.slug) + '" class="nota-card" style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1.125rem;display:flex;flex-direction:column;gap:0.5rem;cursor:pointer;transition:border-color .15s;">'
          + '<h3 style="font-family:\'Montserrat\',sans-serif;font-size:13px;font-weight:700;color:#F4F6F8;margin:0;line-height:1.3;">' + esc(n.titulo) + '</h3>'
          + '<p style="font-size:12px;color:#6B7280;margin:0;line-height:1.45;flex:1;">' + esc(n.resumen) + '</p>'
          + '<div style="display:flex;gap:4px;flex-wrap:wrap;">' + tagsHtml + '</div>'
          + '<p style="font-size:10px;color:rgba(107,114,128,0.5);margin:0;">' + esc(n.fecha) + '</p>'
          + '</div>';
      }).join('');

      // click handlers
      grid.querySelectorAll('.nota-card').forEach(function(card) {
        card.addEventListener('click', function() { openNote(this.dataset.slug); });
        card.addEventListener('mouseenter', function() { this.style.borderColor = 'rgba(59,78,217,0.4)'; });
        card.addEventListener('mouseleave', function() { this.style.borderColor = 'rgba(232,234,240,0.09)'; });
      });
    } catch (e) {
      var grid = document.getElementById('notes-grid');
      if (grid) grid.innerHTML = '<div style="color:#F87171;font-size:12px;padding:1rem;">Error cargando notas.</div>';
    }
  }

  // ---- search ----
  var searchTimer;
  var searchInput = document.getElementById('brain-search');

  function renderResults(results) {
    var resultsEl = document.getElementById('search-results');
    if (!resultsEl) return;
    if (!results || !results.length) {
      resultsEl.innerHTML = '<p style="color:#6B7280;font-size:12px;padding:0.25rem 0;">Sin resultados.</p>';
      return;
    }
    resultsEl.innerHTML = '<div style="display:flex;flex-direction:column;gap:6px;">'
      + results.map(function(r) {
        return '<div data-slug="' + esc(r.slug) + '" class="result-card" style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:10px;padding:0.875rem;cursor:pointer;transition:border-color .15s;">'
          + '<h4 style="font-size:13px;font-weight:700;color:#F4F6F8;margin:0 0 4px;font-family:\'Montserrat\',sans-serif;">' + esc(r.titulo) + '</h4>'
          + '<p style="font-size:12px;color:#6B7280;margin:0;line-height:1.4;">' + esc(r.resumen) + '</p>'
          + '</div>';
      }).join('')
      + '</div>';

    resultsEl.querySelectorAll('.result-card').forEach(function(card) {
      card.addEventListener('click', function() { openNote(this.dataset.slug); });
      card.addEventListener('mouseenter', function() { this.style.borderColor = 'rgba(59,78,217,0.4)'; });
      card.addEventListener('mouseleave', function() { this.style.borderColor = 'rgba(232,234,240,0.09)'; });
    });
  }

  async function runSearch(q) {
    var resultsEl = document.getElementById('search-results');
    if (!resultsEl) return;
    resultsEl.style.display = 'block';
    resultsEl.innerHTML = '<p style="color:#6B7280;font-size:12px;padding:0.25rem 0;">Buscando...</p>';
    try {
      var res = await fetch('/api/brain/search?q=' + encodeURIComponent(q));
      if (!res.ok) throw new Error(String(res.status));
      var data = await res.json();
      renderResults(data.results);
    } catch {
      resultsEl.innerHTML = '<p style="color:#F87171;font-size:12px;">Error al buscar.</p>';
    }
  }

  if (searchInput) {
    searchInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        clearTimeout(searchTimer);
        var q = this.value.trim();
        var resultsEl = document.getElementById('search-results');
        if (!q) { if (resultsEl) { resultsEl.style.display = 'none'; resultsEl.innerHTML = ''; } return; }
        runSearch(q);
      }
    });

    searchInput.addEventListener('input', function() {
      clearTimeout(searchTimer);
      var q = this.value.trim();
      var resultsEl = document.getElementById('search-results');
      if (!q) { if (resultsEl) { resultsEl.style.display = 'none'; resultsEl.innerHTML = ''; } return; }
      searchTimer = setTimeout(function() { runSearch(q); }, 380);
    });
  }

  loadNotes();
</script>
