---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
import { bandeja } from '../../os/data/bandeja';
import OSBandeja from '../../os/components/OSBandeja';
---

<OSLayout title="Por revisar">
  <div class="os-fade-up">
    <!-- Header -->
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:0.5rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Growth OS</p>
        <h1 class="os-h1" style="display:flex;align-items:center;gap:9px;">
          <span class="material-symbols-outlined" style="font-size:24px;color:var(--os-accent-light);">inbox</span>
          Por revisar
        </h1>
      </div>
    </div>
    <OSBandeja items={bandeja} client:load />
  </div>
</OSLayout>
