---
import { useTranslations } from "../../i18n/utils";

interface Props { lang?: string; }
const { lang = "es" } = Astro.props;
const t = useTranslations(lang);

const services = [
  {
    eyebrowKey: "services.growth_os.eyebrow" as const,
    titleKey:   "services.growth_os.title" as const,
    descKey:    "services.growth_os.desc" as const,
    itemKeys:   ["services.growth_os.item1", "services.growth_os.item2", "services.growth_os.item3", "services.growth_os.item4"] as const,
    ctaKey:     "services.growth_os.cta" as const,
    href: "/contacto",
  },
  {
    eyebrowKey: "services.advisory.eyebrow" as const,
    titleKey:   "services.advisory.title" as const,
    descKey:    "services.advisory.desc" as const,
    itemKeys:   ["services.advisory.item1", "services.advisory.item2", "services.advisory.item3"] as const,
    ctaKey:     "services.advisory.cta" as const,
    href: "/trabaja-conmigo",
  },
  {
    eyebrowKey: "services.speaking.eyebrow" as const,
    titleKey:   "services.speaking.title" as const,
    descKey:    "services.speaking.desc" as const,
    itemKeys:   ["services.speaking.item1", "services.speaking.item2", "services.speaking.item3"] as const,
    ctaKey:     "services.speaking.cta" as const,
    href: "/trabaja-conmigo",
  },
];
---

<section id="servicios" class="bg-bg-primary py-12 md:py-20">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-8">
    <h2
      class="font-montserrat font-bold text-text-primary text-[32px] md:text-[36px] text-center mb-16"
      data-reveal
    >
      {t("services.heading")}
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {services.map((s, i) => (
        <div
          class="bg-bg-elevated rounded-lg p-10 border border-border-subtle hover:border-ember transition-colors duration-300 flex flex-col"
          data-reveal
          data-reveal-delay={String(i + 1)}
        >
          <p class="font-montserrat text-[11px] uppercase tracking-[1.5px] text-ember mb-3">
            {t(s.eyebrowKey)}
          </p>
          <h3 class="font-montserrat font-semibold text-text-primary text-[22px] mb-3">
            {t(s.titleKey)}
          </h3>
          <p class="font-inter text-text-secondary text-[15px] leading-relaxed mb-6">
            {t(s.descKey)}
          </p>
          <ul class="space-y-2 mb-8 flex-1">
            {s.itemKeys.map((key) => (
              <li class="font-inter text-text-muted-brand text-[13px] flex items-start gap-2">
                <span class="text-ember mt-[2px] flex-shrink-0 select-none">·</span>
                {t(key)}
              </li>
            ))}
          </ul>
          <a
            href={s.href}
            class="font-inter font-medium text-ember text-[14px] hover:underline mt-auto"
          >
            {t(s.ctaKey)}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
