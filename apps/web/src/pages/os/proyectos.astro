---
import OSLayout from '../../layouts/OSLayout.astro';
import { proyectos } from '../../os/data/proyectos';

const statusLabel: Record<string, string> = {
  activo: 'Activo',
  pausado: 'Pausado',
  'por-lanzar': 'Por lanzar',
  'en-curso': 'En curso',
};
const statusColor: Record<string, string> = {
  activo: '#6B7AE8',
  pausado: '#6B7280',
  'por-lanzar': '#B5985A',
  'en-curso': '#3B4ED9',
};
const tipoLabel: Record<string, string> = {
  consultora: 'Consultora',
  startup: 'Startup',
  ong: 'ONG',
  'for-profit': 'For-profit',
  cliente: 'Cliente',
  negocio: 'Negocio',
  marca: 'Marca',
};

const conMaker = proyectos.filter((p) => p.recibe_maker);
const sinMaker = proyectos.filter((p) => !p.recibe_maker);
---

<OSLayout title="Proyectos">
  <div>
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1.75rem;flex-wrap:wrap;gap:0.5rem;">
      <h1 style="font-size:1.375rem;font-weight:700;color:#F4F6F8;margin:0;">Proyectos</h1>
      <div style="display:flex;gap:1rem;">
        <div style="display:flex;align-items:center;gap:5px;">
          <span style="width:8px;height:8px;border-radius:2px;background:#3B4ED9;display:block;"></span>
          <span style="font-size:11px;color:#6B7280;">Recibe tiempo Maker</span>
        </div>
        <div style="display:flex;align-items:center;gap:5px;">
          <span style="width:8px;height:8px;border-radius:2px;background:rgba(232,234,240,0.12);display:block;"></span>
          <span style="font-size:11px;color:#6B7280;">Solo dias Manager</span>
        </div>
      </div>
    </div>

    <!-- Lineas con tiempo Maker -->
    <p style="font-family:'Montserrat',sans-serif;font-size:9px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:#6B7280;margin:0 0 0.5rem;">Con tiempo Maker (Mie / Vie / Sab)</p>
    <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:1.5rem;">
      {conMaker.map((p) => (
        <div style={`background:#131F4A;border:1px solid ${p.motor ? 'rgba(59,78,217,0.3)' : 'rgba(232,234,240,0.09)'};border-left:3px solid #3B4ED9;border-radius:12px;padding:1rem 1.25rem;`}>
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:0.4rem;flex-wrap:wrap;">
            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
              <h3 style="font-family:'Montserrat',sans-serif;font-size:15px;font-weight:700;color:#F4F6F8;margin:0;">{p.nombre}</h3>
              {p.motor && (
                <span style="font-family:'Montserrat',sans-serif;font-size:9px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;background:rgba(59,78,217,0.2);color:#6B7AE8;padding:2px 7px;border-radius:4px;">Motor</span>
              )}
              <span style={`font-size:11px;color:${statusColor[p.status]};font-weight:500;`}>{statusLabel[p.status]}</span>
              <span style="font-size:11px;color:#6B7280;">{tipoLabel[p.tipo]}</span>
            </div>
            {p.deadline && (
              <span style="font-size:11px;color:#B5985A;white-space:nowrap;flex-shrink:0;">{p.deadline}</span>
            )}
          </div>
          <p style="font-size:13px;color:#6B7280;margin:0 0 0.5rem;line-height:1.4;">{p.descripcion}</p>
          <div style="display:flex;align-items:flex-start;gap:8px;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#3B4ED9" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><polyline points="9 18 15 12 9 6"/></svg>
            <p style="font-size:13px;color:#E8EAF0;margin:0;line-height:1.4;">{p.siguiente_accion}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Solo dias Manager -->
    {sinMaker.length > 0 && (
      <div>
        <p style="font-family:'Montserrat',sans-serif;font-size:9px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:#6B7280;margin:0 0 0.5rem;">Solo coordinacion Manager (Lun / Mar / Jue)</p>
        <div style="display:flex;flex-direction:column;gap:8px;">
          {sinMaker.map((p) => (
            <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.07);border-left:3px solid rgba(232,234,240,0.15);border-radius:12px;padding:1rem 1.25rem;opacity:0.8;">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:0.4rem;flex-wrap:wrap;">
                <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                  <h3 style="font-family:'Montserrat',sans-serif;font-size:15px;font-weight:700;color:#F4F6F8;margin:0;">{p.nombre}</h3>
                  <span style={`font-size:11px;color:${statusColor[p.status]};font-weight:500;`}>{statusLabel[p.status]}</span>
                  <span style="font-size:11px;color:#6B7280;">{tipoLabel[p.tipo]}</span>
                </div>
              </div>
              <p style="font-size:13px;color:#6B7280;margin:0 0 0.5rem;line-height:1.4;">{p.descripcion}</p>
              <div style="display:flex;align-items:flex-start;gap:8px;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><polyline points="9 18 15 12 9 6"/></svg>
                <p style="font-size:13px;color:#6B7280;margin:0;line-height:1.4;">{p.siguiente_accion}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</OSLayout>
