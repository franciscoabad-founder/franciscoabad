---
const kpis = [
  {
    value: "$10B+",
    label: "Capital administrado",
    icon: `<path d="M3 3h18v4H3zM3 10h18v4H3zM3 17h18v4H3z" stroke-width="0"/>
           <rect x="3" y="3" width="18" height="3" rx="0.5"/>
           <rect x="3" y="9.5" width="14" height="3" rx="0.5"/>
           <rect x="3" y="16" width="10" height="3" rx="0.5"/>`,
  },
  {
    value: "32K+",
    label: "Personas lideradas",
    icon: `<circle cx="9" cy="7" r="3"/>
           <circle cx="15" cy="7" r="3"/>
           <path d="M2 20c0-4 3.1-7 7-7h6c3.9 0 7 3 7 7" stroke-linecap="round"/>`,
  },
  {
    value: "12,000+",
    label: "Emprendedores impactados",
    icon: `<circle cx="12" cy="12" r="2"/>
           <path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12" stroke-linecap="round"/>`,
  },
  {
    value: "15",
    label: "Países con presencia",
    icon: `<circle cx="12" cy="12" r="9"/>
           <path d="M12 3c-2.5 3-4 5.5-4 9s1.5 6 4 9"/>
           <path d="M12 3c2.5 3 4 5.5 4 9s-1.5 6-4 9"/>
           <path d="M3 12h18"/>`,
  },
];
---

<div class="bg-bg-primary border-t border-b border-border-subtle" data-reveal>
  <div class="max-w-[1200px] mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4">
      {kpis.map((kpi, i) => (
        <div class={`flex items-start gap-4 py-8 px-6 ${i < kpis.length - 1 ? "border-r border-border-subtle" : ""}`}>
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            class="text-ember flex-shrink-0 mt-1"
            aria-hidden="true"
          >
            <Fragment set:html={kpi.icon} />
          </svg>
          <div>
            <p class="font-inter font-bold text-text-primary text-[clamp(1.5rem,3vw,2rem)] leading-none tabular-nums">
              {kpi.value}
            </p>
            <p class="font-inter text-text-secondary text-[12px] leading-snug mt-1 max-w-[140px]">
              {kpi.label}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
