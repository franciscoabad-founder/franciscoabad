---
export const prerender = false;

import OSLayout from '../../layouts/OSLayout.astro';
import { kpis } from '../../os/data/kpis';
import { notas } from '../../os/data/cerebro';
import OSOnboarding from '../../os/components/OSOnboarding';
import OSHoy from '../../os/components/OSHoy';

const trendIcon: Record<string, string> = {
  up:   '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="var(--os-champagne)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>',
  down: '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#D4537E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 17 13.5 8.5 8.5 13.5 2 7"/><polyline points="16 17 22 17 22 11"/></svg>',
  flat: '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="var(--os-muted)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>',
};

const fechaLarga = new Date().toLocaleDateString('es-EC', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
});
---

<OSLayout title="Hoy">
  <OSOnboarding client:load />
  <div class="os-fade-up">

    <!-- Header -->
    <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.5rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Cockpit</p>
        <h1 class="os-h1">Hoy</h1>
      </div>
      <span style="font-size:12px;color:var(--os-muted);text-transform:capitalize;">{fechaLarga}</span>
    </div>

    <!-- KPI strip -->
    <div class="os-kpi-grid" style="margin-bottom:1.25rem;">
      {kpis.slice(0, 6).map((k) => (
        <div class="os-kpi">
          <p class="os-kpi-label">{k.label}</p>
          <p class="os-kpi-value">{k.valor}</p>
          <div style="display:flex;align-items:center;gap:4px;">
            <span set:html={trendIcon[k.tendencia]} />
            <span style="font-size:11px;color:var(--os-muted);">{k.cambio}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Hoy: domino, priority stack, wins, checklist, discomfort, principios, semana, norte -->
    <OSHoy client:load />

    <!-- Salud -->
    <a href="/os/salud" class="os-card os-card-interactive" style="display:flex;align-items:center;gap:14px;margin-bottom:1rem;text-decoration:none;">
      <span class="material-symbols-outlined" style="font-size:26px;color:var(--os-accent-light);flex-shrink:0;">favorite</span>
      <div style="flex:1;min-width:0;">
        <p style="font-size:14px;font-weight:700;color:var(--os-text);margin:0;">Salud</p>
        <p style="font-size:12px;color:var(--os-muted);margin:2px 0 0;">Nutrición, ayuno, entrenamiento, cuerpo y estiramiento</p>
      </div>
      <span class="material-symbols-outlined" style="font-size:20px;color:var(--os-muted);">chevron_right</span>
    </a>

    <!-- Brain feed -->
    <div class="os-card">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.875rem;">
        <p class="os-section-title" style="margin:0;">Cerebro · ultimas notas</p>
        <a href="/os/cerebro" style="font-size:11px;color:var(--os-accent-light);text-decoration:none;font-family:var(--os-font-display);letter-spacing:0.06em;">ver todo</a>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:8px;">
        {notas.slice(0, 4).map((n) => (
          <div style="padding:0.875rem;border-radius:8px;background:var(--os-fill-subtle);border:1px solid var(--os-line-soft);">
            <p style="font-size:12px;font-weight:600;color:var(--os-text);margin:0 0 0.375rem;line-height:1.3;">{n.titulo}</p>
            <p style="font-size:11px;color:var(--os-muted);margin:0;line-height:1.4;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">{n.resumen}</p>
          </div>
        ))}
      </div>
    </div>

  </div>

  <style is:global>
    @media (max-width: 820px) {
      .os-2col { grid-template-columns: 1fr !important; }
    }
  </style>
</OSLayout>
