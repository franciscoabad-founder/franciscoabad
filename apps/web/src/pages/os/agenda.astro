---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
import { eventos } from '../../os/data/agenda';

const fechas = [...new Set(eventos.map((e) => e.fecha))].sort();

const tipoColor: Record<string, string> = {
  reunion: 'var(--os-accent)',
  recordatorio: 'var(--os-champagne)',
  'deep-work': 'var(--os-accent-light)',
  personal: 'var(--os-muted)',
};
const tipoIcon: Record<string, string> = {
  reunion: 'groups',
  recordatorio: 'notifications',
  'deep-work': 'bolt',
  personal: 'person',
};
const tipoLabel: Record<string, string> = {
  reunion: 'Reunion',
  recordatorio: 'Recordatorio',
  'deep-work': 'Deep work',
  personal: 'Personal',
};

const fechaLabel: Record<string, string> = {
  '2026-06-22': 'Hoy · lun 22 jun',
  '2026-06-23': 'Manana · mar 23 jun',
  '2026-06-26': 'Vie 26 jun',
};
---

<OSLayout title="Agenda">
  <div class="os-fade-up">

    <!-- Header -->
    <div style="margin-bottom:1.5rem;">
      <p class="os-eyebrow" style="margin-bottom:6px;">Calendario</p>
      <h1 class="os-h1">Agenda</h1>
    </div>

    <div style="display:flex;flex-direction:column;gap:1.5rem;">
      {fechas.map((fecha) => {
        const eventosDia = eventos.filter((e) => e.fecha === fecha).sort((a, b) => a.hora.localeCompare(b.hora));
        return (
          <div>
            <p class="os-section-title" style="margin:0 0 0.625rem;">
              {fechaLabel[fecha] ?? fecha}
            </p>
            <div style="display:flex;flex-direction:column;gap:6px;">
              {eventosDia.map((e) => (
                <div class="os-card-2 os-card-interactive" style="display:flex;align-items:flex-start;gap:12px;padding:0.75rem 1rem;">
                  <div style="min-width:48px;text-align:right;flex-shrink:0;">
                    <p class="os-mono" style="font-size:13px;font-weight:700;color:var(--os-text);margin:0;">{e.hora}</p>
                    <p style="font-size:10px;color:var(--os-muted);margin:1px 0 0;">{e.duracion}</p>
                  </div>
                  <div style={`width:2px;min-width:2px;border-radius:2px;background:${tipoColor[e.tipo]};align-self:stretch;flex-shrink:0;`}></div>
                  <div style="flex:1;min-width:0;">
                    <p style="font-size:14px;font-weight:500;color:var(--os-text);margin:0 0 2px;line-height:1.3;">{e.titulo}</p>
                    {e.con && (
                      <p style="font-size:12px;color:var(--os-muted);margin:0;">{e.con}</p>
                    )}
                  </div>
                  <span style={`display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:700;color:${tipoColor[e.tipo]};flex-shrink:0;font-family:var(--os-font-display);letter-spacing:0.05em;text-transform:uppercase;white-space:nowrap;`}>
                    <span class="material-symbols-outlined" style={`font-size:14px;color:${tipoColor[e.tipo]};`}>{tipoIcon[e.tipo]}</span>
                    {tipoLabel[e.tipo]}
                  </span>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</OSLayout>
