---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
---

<BaseLayout
  title="Registro confirmado · Francisco Abad"
  description="Te agregué a la lista de acceso anticipado. Recibirás el kit en los próximos 3 días."
>
  <Navbar />

  <main class="bg-bg-primary min-h-screen flex items-center justify-center px-6">
    <div class="max-w-[520px] text-center py-24">
      <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-bg-elevated border border-border-subtle mb-8">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--ultramarine)">
          <polyline points="20 6 9 17 4 12" />
        </svg>
      </div>

      <h1 class="font-montserrat font-bold text-text-primary text-[32px] md:text-[38px] leading-tight mb-4">
        Te apunté en la lista.
      </h1>
      <p class="font-inter text-text-secondary text-[16px] leading-relaxed mb-2">
        Recibirás el kit en los próximos 3 días en el correo que registraste.
      </p>
      <p class="font-inter text-text-muted text-[14px] mb-10">
        Revisa la carpeta de spam si no aparece en tu bandeja de entrada.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="font-montserrat font-semibold text-[13px] uppercase tracking-[1px] text-text-secondary hover:text-ember transition-colors duration-200 border border-border-subtle px-5 py-3 rounded-lg"
        >
          Volver al inicio
        </a>
        <a
          href="/blog"
          style="background-color: var(--ultramarine);"
          class="font-montserrat font-semibold text-[13px] uppercase tracking-[1px] text-white px-5 py-3 rounded-lg hover:opacity-90 transition-opacity duration-200"
        >
          Leer el blog
        </a>
      </div>
    </div>
  </main>

  <Footer lang="es" />
</BaseLayout>
