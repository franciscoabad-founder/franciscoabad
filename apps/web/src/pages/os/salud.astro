---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
import { datosSalud } from '../../os/data/salud';

const { identidad, filosofia, reglas, pasos, pasos_meta, sueno_horas, sueno_meta,
        peso_kg, agua_litros, agua_meta, habitos, fecha } = datosSalud;

const pct = (actual: number, meta: number) => Math.min(100, Math.round((actual / meta) * 100));

const metricas = [
  { label: 'Pasos',  valor: pasos.toLocaleString('es-EC'),  meta: pasos_meta.toLocaleString('es-EC'), p: pct(pasos, pasos_meta),      unidad: 'pasos' },
  { label: 'Sueno',  valor: sueno_horas + 'h',              meta: sueno_meta + 'h',                   p: pct(sueno_horas, sueno_meta), unidad: 'horas' },
  { label: 'Agua',   valor: agua_litros + 'L',              meta: agua_meta + 'L',                    p: pct(agua_litros, agua_meta),  unidad: 'litros' },
  { label: 'Peso',   valor: peso_kg + ' kg',                meta: '--',                               p: 100,                         unidad: 'kg' },
];

const rachaTotal = habitos.reduce((max, h) => Math.max(max, h.racha), 0);
---

<OSLayout title="Salud">
  <div class="os-fade-up">

    <!-- Header -->
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:1.25rem;flex-wrap:wrap;gap:0.5rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Cuerpo</p>
        <h1 class="os-h1">Salud</h1>
      </div>
      <span style="font-size:12px;color:var(--os-muted);">{fecha}</span>
    </div>

    <!-- Identidad -->
    <div class="os-card-2 os-card-accent" style="margin-bottom:1rem;border-left:4px solid var(--os-accent);">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:0.25rem;">
        <span class="material-symbols-outlined" style="font-size:18px;color:var(--os-accent-light);">favorite</span>
        <p style="font-family:var(--os-font-display);font-size:1rem;font-weight:700;color:var(--os-text);margin:0;">{identidad}</p>
      </div>
      <p style="font-size:13px;color:var(--os-text-2);margin:0 0 0.75rem;line-height:1.4;">{filosofia}</p>
      <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:4px;">
        {reglas.map((r) => (
          <li style="display:flex;align-items:flex-start;gap:8px;">
            <span class="material-symbols-outlined" style="font-size:14px;color:var(--os-accent-light);flex-shrink:0;margin-top:1px;">check</span>
            <span style="font-size:12px;color:var(--os-text);line-height:1.35;">{r}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Metricas -->
    <div class="os-kpi-grid" style="margin-bottom:1.25rem;">
      {metricas.map((m) => (
        <div class="os-kpi">
          <p class="os-kpi-label">{m.label}</p>
          <p class="os-kpi-value">{m.valor}</p>
          <p style="font-size:11px;color:var(--os-muted);margin:0 0 0.5rem;">meta: {m.meta}</p>
          {m.meta !== '--' && (
            <div style="height:3px;background:rgba(232,234,240,0.08);border-radius:2px;overflow:hidden;">
              <div style={`height:100%;width:${m.p}%;background:${m.p >= 100 ? 'var(--os-accent-light)' : 'var(--os-accent)'};border-radius:2px;`}></div>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Habitos y rachas -->
    <div class="os-card">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.875rem;">
        <p class="os-section-title" style="margin:0;">Habitos de hoy</p>
        <div style="display:flex;align-items:center;gap:5px;">
          <span style="font-size:11px;color:var(--os-muted);">Racha maxima:</span>
          <span class="os-num" style="font-size:13px;">{rachaTotal}d</span>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:6px;">
        {habitos.map((h) => (
          <div style="display:flex;align-items:center;gap:12px;padding:0.5rem 0.75rem;border-radius:var(--os-r-sm);background:rgba(232,234,240,0.03);">
            <span style={`width:18px;height:18px;border-radius:4px;border:2px solid ${h.completado ? 'var(--os-accent)' : 'rgba(232,234,240,0.2)'};background:${h.completado ? 'var(--os-accent)' : 'transparent'};display:flex;align-items:center;justify-content:center;flex-shrink:0;`}>
              {h.completado && (
                <svg width="9" height="7" viewBox="0 0 9 7" fill="none">
                  <polyline points="1,3.5 3.5,6 8,1" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              )}
            </span>
            <span style={`font-size:13px;flex:1;${h.completado ? 'color:var(--os-text);' : 'color:var(--os-muted);'}`}>{h.label}</span>
            {h.racha > 0 && (
              <span class="os-num" style="font-size:12px;">{h.racha}d</span>
            )}
            {h.racha === 0 && !h.completado && (
              <span style="font-size:11px;color:var(--os-muted);">reiniciar</span>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>

  <style>
    @media (max-width: 820px) {
      .os-kpi-grid { grid-template-columns: 1fr 1fr !important; }
    }
  </style>
</OSLayout>
