---
import OSLayout from '../../layouts/OSLayout.astro';
import { datosHoy } from '../../os/data/hoy';
import { objetivos } from '../../os/data/objetivos';
import { datosDaily } from '../../os/data/daily';
import OSChecklist from '../../os/components/OSChecklist';

const { domino, discomfort, checklist, wins, priorities } = datosHoy;

const urgenciaColor: Record<string, string> = {
  alta: '#3B4ED9',
  media: '#6B7AE8',
  baja: '#6B7280',
};
---

<OSLayout title="Hoy">
  <div>
    <div style="margin-bottom:2rem;">
      <h1 style="font-size:1.375rem;font-weight:700;color:#F4F6F8;margin:0 0 0.25rem;">Hoy</h1>
      <p style="font-size:13px;color:#6B7280;margin:0;">{datosHoy.fecha}</p>
    </div>

    <!-- Objetivos 90 dias -->
    <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1.125rem 1.25rem;margin-bottom:1rem;">
      <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#6B7280;margin:0 0 0.75rem;">Objetivos 90 dias</p>
      <div style="display:flex;flex-direction:column;gap:8px;">
        {objetivos.map((o, i) => (
          <div style="display:flex;align-items:flex-start;gap:10px;">
            <span style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:700;color:#B5985A;min-width:18px;padding-top:1px;">{i + 1}</span>
            <div>
              <span style="font-size:13px;font-weight:600;color:#F4F6F8;">{o.titulo}</span>
              <span style="font-size:12px;color:#6B7280;margin-left:6px;">{o.descripcion}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">

      <!-- One Domino -->
      <div style="grid-column:1/-1;background:#131F4A;border:1px solid rgba(59,78,217,0.3);border-radius:12px;padding:1.25rem;">
        <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#6B7AE8;margin:0 0 0.625rem;">One Domino</p>
        <p style="font-size:1.0625rem;font-weight:600;color:#F4F6F8;margin:0 0 0.375rem;line-height:1.35;">{domino.tarea}</p>
        <p style="font-size:12px;color:#6B7280;margin:0 0 0.25rem;">{domino.proyecto}</p>
        <p style="font-size:13px;color:#E8EAF0;margin:0;line-height:1.4;">{domino.razon}</p>
      </div>

      <!-- Discomfort First -->
      <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1.25rem;">
        <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#B5985A;margin:0 0 0.625rem;">Discomfort First</p>
        <p style="font-size:14px;font-weight:500;color:#F4F6F8;margin:0 0 0.375rem;line-height:1.35;">{discomfort.tarea}</p>
        <p style="font-size:12px;color:#6B7280;margin:0;line-height:1.4;">{discomfort.contexto}</p>
      </div>

      <!-- Checklist de 3 -->
      <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1.25rem;">
        <OSChecklist items={checklist} title="Checklist del dia" client:load />
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">

      <!-- Priority stack -->
      <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1.25rem;">
        <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#6B7280;margin:0 0 0.75rem;">Priority Stack</p>
        <ol style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:6px;">
          {priorities.map((p, i) => (
            <li style="display:flex;align-items:flex-start;gap:10px;">
              <span style={`font-family:'Montserrat',sans-serif;font-size:11px;font-weight:700;color:${urgenciaColor[p.urgencia]};min-width:16px;padding-top:2px;`}>{i + 1}</span>
              <div>
                <span style="font-size:13px;color:#F4F6F8;">{p.tarea}</span>
                <span style="font-size:11px;color:#6B7280;margin-left:6px;">{p.proyecto}</span>
              </div>
            </li>
          ))}
        </ol>
      </div>

      <!-- Wins + principios de referencia -->
      <div style="display:flex;flex-direction:column;gap:1rem;">
        <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1.25rem;">
          <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#6B7280;margin:0 0 0.75rem;">Wins recientes</p>
          <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:7px;">
            {wins.map((w) => (
              <li style="display:flex;align-items:flex-start;gap:8px;">
                <span style="color:#6B7AE8;margin-top:3px;flex-shrink:0;">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                <span style="font-size:13px;color:#E8EAF0;line-height:1.4;">{w.texto}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Principios mini referencia -->
        <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1rem 1.25rem;">
          <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#6B7280;margin:0 0 0.625rem;">Principios</p>
          <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:4px;">
            {datosDaily.principios.map((p, i) => (
              <li style="display:flex;gap:8px;">
                <span style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:700;color:#3B4ED9;min-width:14px;">{i+1}</span>
                <span style="font-size:12px;color:#6B7280;line-height:1.35;">{p}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

    </div>
  </div>
</OSLayout>
