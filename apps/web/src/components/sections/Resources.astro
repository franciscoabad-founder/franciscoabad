---
// Resources — sección de la Home con 3 tarjetas: lead magnet, Growth OS, videos.
// Inputs/buttons sin handler (decorativos). En Fase 3 se conectan a Beehiiv server-side.
---

<section id="recursos" class="bg-bg-elevated py-12 md:py-20">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-8">
    <h2
      class="font-montserrat font-bold text-text-primary text-[32px] md:text-[36px] mb-14"
      data-reveal
    >
      Recursos para founders y gente ambiciosa
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {/* Col 1 — Lead magnet */}
      <div class="bg-bg-primary rounded-lg p-8 border border-ember flex flex-col" data-reveal>
        <span class="inline-block bg-ember text-white font-montserrat text-[10px] uppercase tracking-[1.5px] px-3 py-1 rounded-full mb-5 self-start">
          Gratis
        </span>
        <h3 class="font-montserrat font-semibold text-text-primary text-[20px] mb-3">
          Tu Semana de Reset
        </h3>
        <p class="font-inter text-text-secondary text-[14px] leading-relaxed mb-6 flex-1">
          7 días. Una micro-acción por día. 10 minutos o menos. Instala las bases de un sistema operativo personal.
        </p>
        <form class="flex flex-col gap-2" onsubmit="event.preventDefault();">
          <input
            type="email"
            placeholder="tu@email.com"
            class="w-full bg-bg-elevated border border-border-subtle rounded-md px-3 py-2.5 font-inter text-text-primary text-[13px] placeholder:text-text-muted-brand focus:outline-none focus:border-ember transition-colors"
          />
          <button
            type="submit"
            class="w-full bg-ember text-white font-inter font-medium text-[13px] px-4 py-2.5 rounded-md hover:bg-[hsl(14,45%,46%)] transition-colors"
          >
            Quiero la guía
          </button>
        </form>
      </div>

      {/* Col 2 — Growth OS */}
      <div class="bg-bg-primary rounded-lg p-8 border border-border-subtle flex flex-col" data-reveal>
        <span class="inline-block bg-ember text-white font-montserrat text-[10px] uppercase tracking-[1.5px] px-3 py-1 rounded-full mb-5 self-start">
          $47
        </span>
        <h3 class="font-montserrat font-semibold text-text-primary text-[20px] mb-3">
          Growth OS
        </h3>
        <p class="font-inter text-text-secondary text-[14px] leading-relaxed mb-6 flex-1">
          El sistema operativo de 90 días. Excel, manual, brief y prompts de IA incluidos.
        </p>
        {/* TODO: cuando exista la página /growth-os, restaurar href="/growth-os" y texto "Ver el Growth OS →" */}
        <a
          href="/contacto"
          class="w-full text-center bg-ember text-white font-inter font-medium text-[13px] px-4 py-2.5 rounded-md hover:bg-[hsl(14,45%,46%)] transition-colors"
        >
          Próximamente
        </a>
      </div>

      {/* Col 3 — Videos */}
      <div class="bg-bg-primary rounded-lg p-8 border border-border-subtle flex flex-col" data-reveal>
        <span class="inline-block bg-border-subtle text-text-secondary font-montserrat text-[10px] uppercase tracking-[1.5px] px-3 py-1 rounded-full mb-5 self-start">
          Videos
        </span>
        <h3 class="font-montserrat font-semibold text-text-primary text-[20px] mb-6">
          Entrevistas y charlas
        </h3>
        <div class="space-y-4 flex-1">
          {[1, 2].map(() => (
            <div>
              <div class="relative aspect-video bg-bg-elevated rounded-md border border-border-subtle flex items-center justify-center mb-2">
                <div class="w-10 h-10 rounded-full bg-ember flex items-center justify-center opacity-50">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-white ml-0.5">
                    <polygon points="6 4 20 12 6 20 6 4" />
                  </svg>
                </div>
              </div>
              <p class="font-inter text-text-muted-brand text-[12px] text-center">
                Próximamente
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
