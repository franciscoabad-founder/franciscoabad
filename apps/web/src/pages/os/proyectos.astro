---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
import { proyectos } from '../../os/data/proyectos';

const statusLabel: Record<string, string> = {
  activo: 'Activo',
  pausado: 'Pausado',
  'por-lanzar': 'Por lanzar',
  'en-curso': 'En curso',
};
const statusColor: Record<string, string> = {
  activo: '#6B7AE8',
  pausado: '#6B7280',
  'por-lanzar': '#B5985A',
  'en-curso': '#3B4ED9',
};
const tipoLabel: Record<string, string> = {
  consultora: 'Consultora',
  startup: 'Startup',
  ong: 'ONG',
  'for-profit': 'For-profit',
  cliente: 'Cliente',
  negocio: 'Negocio',
  marca: 'Marca',
};

const conMaker = proyectos.filter((p) => p.recibe_maker);
const sinMaker = proyectos.filter((p) => !p.recibe_maker);
---

<OSLayout title="Proyectos">
  <div class="os-fade-up">

    <!-- Header -->
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:0.75rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Growth OS</p>
        <h1 class="os-h1">Proyectos</h1>
      </div>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;">
        <div style="display:flex;align-items:center;gap:6px;">
          <span style="width:8px;height:8px;border-radius:2px;background:var(--os-accent);display:block;"></span>
          <span style="font-size:11px;color:var(--os-muted);">Recibe tiempo Maker</span>
        </div>
        <div style="display:flex;align-items:center;gap:6px;">
          <span style="width:8px;height:8px;border-radius:2px;background:rgba(232,234,240,0.12);display:block;"></span>
          <span style="font-size:11px;color:var(--os-muted);">Solo dias Manager</span>
        </div>
      </div>
    </div>

    <!-- Lineas con tiempo Maker -->
    <p class="os-section-title" style="display:flex;align-items:center;gap:7px;">
      <span class="material-symbols-outlined" style="font-size:15px;color:var(--os-accent-light);">bolt</span>
      Con tiempo Maker (Mie / Vie / Sab)
    </p>
    <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:1.75rem;">
      {conMaker.map((p) => (
        <div class="proj-card os-card-interactive" data-tag={p.id} data-nombre={p.nombre} style={`background:var(--os-surface-2);border:1px solid ${p.motor ? 'var(--os-line-accent)' : 'var(--os-line-soft)'};border-left:3px solid var(--os-accent);border-radius:var(--os-r-card);padding:1.125rem 1.375rem;cursor:pointer;`}>
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:0.5rem;flex-wrap:wrap;">
            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
              <span class="material-symbols-outlined" style="font-size:18px;color:var(--os-accent-light);flex-shrink:0;">folder</span>
              <h3 style="font-family:var(--os-font-display);font-size:15px;font-weight:700;color:var(--os-text);margin:0;">{p.nombre}</h3>
              {p.motor && (
                <span class="os-pill os-pill-accent">Motor</span>
              )}
              <span style={`font-size:11px;color:${statusColor[p.status]};font-weight:600;`}>{statusLabel[p.status]}</span>
              <span class="os-tag">{tipoLabel[p.tipo]}</span>
            </div>
            {p.deadline && (
              <span class="os-num" style="font-size:11px;white-space:nowrap;flex-shrink:0;">{p.deadline}</span>
            )}
          </div>
          <p style="font-size:13px;color:var(--os-muted);margin:0 0 0.625rem;line-height:1.45;">{p.descripcion}</p>
          <div style="display:flex;align-items:flex-start;gap:7px;">
            <span class="material-symbols-outlined" style="font-size:16px;color:var(--os-accent);flex-shrink:0;margin-top:1px;">chevron_right</span>
            <p style="font-size:13px;color:var(--os-text);margin:0;line-height:1.45;">{p.siguiente_accion}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Solo dias Manager -->
    {sinMaker.length > 0 && (
      <div>
        <p class="os-section-title" style="display:flex;align-items:center;gap:7px;">
          <span class="material-symbols-outlined" style="font-size:15px;color:var(--os-muted);">schedule</span>
          Solo coordinacion Manager (Lun / Mar / Jue)
        </p>
        <div style="display:flex;flex-direction:column;gap:10px;">
          {sinMaker.map((p) => (
            <div class="proj-card os-card-interactive" data-tag={p.id} data-nombre={p.nombre} style="background:var(--os-surface-2);border:1px solid var(--os-line-soft);border-left:3px solid rgba(232,234,240,0.15);border-radius:var(--os-r-card);padding:1.125rem 1.375rem;opacity:0.82;cursor:pointer;">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:0.5rem;flex-wrap:wrap;">
                <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                  <span class="material-symbols-outlined" style="font-size:18px;color:var(--os-muted);flex-shrink:0;">folder</span>
                  <h3 style="font-family:var(--os-font-display);font-size:15px;font-weight:700;color:var(--os-text);margin:0;">{p.nombre}</h3>
                  <span style={`font-size:11px;color:${statusColor[p.status]};font-weight:600;`}>{statusLabel[p.status]}</span>
                  <span class="os-tag">{tipoLabel[p.tipo]}</span>
                </div>
              </div>
              <p style="font-size:13px;color:var(--os-muted);margin:0 0 0.625rem;line-height:1.45;">{p.descripcion}</p>
              <div style="display:flex;align-items:flex-start;gap:7px;">
                <span class="material-symbols-outlined" style="font-size:16px;color:var(--os-muted);flex-shrink:0;margin-top:1px;">chevron_right</span>
                <p style="font-size:13px;color:var(--os-muted);margin:0;line-height:1.45;">{p.siguiente_accion}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>

  <!-- Modal: brief + pendientes del cerebro -->
  <div id="proj-modal" style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(7,17,50,0.82);backdrop-filter:blur(6px);padding:1.5rem;overflow:auto;" role="dialog" aria-modal="true">
    <div style="max-width:680px;margin:0 auto;background:var(--os-bg);border:1px solid var(--os-line-accent);border-radius:var(--os-r-lg);padding:1.75rem;position:relative;min-height:160px;box-shadow:var(--os-shadow-modal);">
      <button id="proj-modal-close" aria-label="Cerrar" style="position:absolute;top:14px;right:16px;background:none;border:none;color:var(--os-muted);cursor:pointer;line-height:1;padding:0;display:flex;"><span class="material-symbols-outlined" style="font-size:22px;">close</span></button>
      <div id="proj-modal-content" style="color:var(--os-text);"></div>
    </div>
  </div>

  <style>
    @media (max-width: 820px) {
      .proj-card { padding: 1rem 1.125rem !important; }
    }
  </style>
</OSLayout>

<script is:inline>
  function esc(s) {
    return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  function mdToHtml(md) {
    return esc(md)
      .replace(/^#### (.+)$/gm, '<b style="color:#6B7AE8;font-size:12px;">$1</b>')
      .replace(/^### (.+)$/gm, '<b style="color:#94A3B8;font-size:13px;">$1</b>')
      .replace(/^## (.+)$/gm, '<b style="color:#F4F6F8;font-size:14px;">$1</b>')
      .replace(/^# (.+)$/gm, '<b style="color:#F4F6F8;font-size:16px;">$1</b>')
      .replace(/\*\*(.+?)\*\*/g, '<b>$1</b>')
      .replace(/^[-*] (.+)$/gm, '<span style="display:block;padding-left:12px;">• $1</span>')
      .replace(/\n\n/g, '<br><br>')
      .replace(/\n/g, '<br>');
  }

  var modal = document.getElementById('proj-modal');
  var modalContent = document.getElementById('proj-modal-content');
  var modalClose = document.getElementById('proj-modal-close');

  function closeModal() { if (modal) modal.style.display = 'none'; }
  if (modalClose) modalClose.addEventListener('click', closeModal);
  if (modal) modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });

  function openProyecto(tag, nombre) {
    if (!modal || !modalContent) return;
    modal.style.display = 'block';
    modalContent.innerHTML = '<p style="color:#6B7280;font-size:13px;">Leyendo el cerebro...</p>';
    fetch('/api/brain/proyecto?tag=' + encodeURIComponent(tag))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.error) {
          modalContent.innerHTML = '<p style="color:#F87171;font-size:13px;">Error: ' + esc(data.error) + '</p>';
          return;
        }
        var header = '<p style="font-size:10px;color:#6B7AE8;letter-spacing:0.1em;text-transform:uppercase;font-family:Montserrat,sans-serif;margin:0 0 6px;">Proyecto · #' + esc(tag) + '</p>'
          + '<h2 style="font-size:1.25rem;font-weight:700;color:#F4F6F8;margin:0 0 1rem;font-family:Montserrat,sans-serif;">' + esc(nombre) + '</h2>';
        var pgs = data.paginas || [];
        if (!pgs.length) {
          modalContent.innerHTML = header + '<p style="color:#6B7280;font-size:13px;">No hay paginas en el cerebro con el tag <b>#' + esc(tag) + '</b> todavia. Captura notas con ese tag y apareceran aqui.</p>';
          return;
        }
        var body = pgs.map(function(p) {
          var pend = (p.pendientes || []).length
            ? '<div style="margin-top:10px;background:rgba(59,78,217,0.08);border:1px solid rgba(59,78,217,0.2);border-radius:8px;padding:10px 12px;">'
                + '<p style="font-family:Montserrat,sans-serif;font-size:9px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#6B7AE8;margin:0 0 6px;">Pendientes</p>'
                + (p.pendientes.map(function(x){ return '<div style="display:flex;gap:7px;align-items:flex-start;font-size:13px;color:#E8EAF0;line-height:1.5;margin-bottom:3px;"><span style="color:#3B4ED9;flex-shrink:0;">▸</span><span>' + esc(x) + '</span></div>'; }).join(''))
              + '</div>'
            : '';
          return '<div style="border-top:1px solid rgba(232,234,240,0.1);padding-top:14px;margin-top:14px;">'
            + '<div style="display:flex;align-items:baseline;justify-content:space-between;gap:10px;margin-bottom:6px;">'
              + '<h3 style="font-size:14px;font-weight:700;color:#F4F6F8;margin:0;font-family:Montserrat,sans-serif;">' + esc(p.titulo) + '</h3>'
              + '<span style="font-size:10px;color:rgba(107,114,128,0.7);flex-shrink:0;">' + esc(p.fecha) + '</span>'
            + '</div>'
            + (p.brief ? '<div style="font-size:13px;color:#CBD5E1;line-height:1.65;">' + mdToHtml(p.brief) + '</div>' : '<p style="font-size:12px;color:#6B7280;">Sin brief.</p>')
            + pend
            + '</div>';
        }).join('');
        modalContent.innerHTML = header + body;
      })
      .catch(function() { modalContent.innerHTML = '<p style="color:#F87171;font-size:13px;">Error al leer el cerebro.</p>'; });
  }

  document.querySelectorAll('.proj-card').forEach(function(card) {
    card.addEventListener('click', function() {
      openProyecto(this.getAttribute('data-tag'), this.getAttribute('data-nombre'));
    });
    card.addEventListener('mouseenter', function() { this.style.borderLeftColor = '#6B7AE8'; });
    card.addEventListener('mouseleave', function() { this.style.borderLeftColor = ''; });
  });
</script>
