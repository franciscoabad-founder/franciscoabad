---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';

const inputStyle = "background:rgba(232,234,240,0.05);border:1px solid rgba(232,234,240,0.12);border-radius:5px;padding:5px 10px;font-size:12px;color:#F4F6F8;font-family:'Inter',sans-serif;outline:none;";
const dateStyle = "background:#0E1738;border:1px solid rgba(232,234,240,0.12);border-radius:5px;padding:5px 10px;font-size:12px;color:#F4F6F8;font-family:'Inter',sans-serif;outline:none;color-scheme:dark;";
const btnStyle = "background:#3B4ED9;color:#fff;border:none;border-radius:5px;padding:5px 16px;font-size:12px;font-family:'Montserrat',sans-serif;font-weight:600;cursor:pointer;white-space:nowrap;flex-shrink:0;";
const cardStyle = "background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:8px;padding:0.75rem 1rem;";
const sectionTitle = "font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#6B7280;margin:0 0 0.6rem;";
---

<OSLayout title="Finanzas">
  <div>
    <!-- Header -->
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1.25rem;">
      <h1 style="font-size:1.375rem;font-weight:700;color:#F4F6F8;margin:0;">Finanzas</h1>
      <p style="font-size:11px;color:#6B7280;margin:0;">Linea base manual</p>
    </div>

    <!-- Resumen -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px;margin-bottom:1.75rem;">
      <div style={cardStyle + "display:flex;flex-direction:column;gap:4px;"}>
        <span style="font-size:10px;color:#6B7280;font-family:'Montserrat',sans-serif;letter-spacing:0.1em;text-transform:uppercase;">Total en cuentas</span>
        <span id="sum-cuentas" style="font-size:1.5rem;font-weight:700;color:#B5985A;font-family:'Montserrat',sans-serif;">—</span>
      </div>
      <div style={cardStyle + "display:flex;flex-direction:column;gap:4px;"}>
        <span style="font-size:10px;color:#6B7280;font-family:'Montserrat',sans-serif;letter-spacing:0.1em;text-transform:uppercase;">Total deudas</span>
        <span id="sum-deudas" style="font-size:1.5rem;font-weight:700;color:#B5985A;font-family:'Montserrat',sans-serif;">—</span>
      </div>
      <div style={cardStyle + "display:flex;flex-direction:column;gap:4px;border-color:rgba(59,78,217,0.3);"}>
        <span style="font-size:10px;color:#6B7280;font-family:'Montserrat',sans-serif;letter-spacing:0.1em;text-transform:uppercase;">Neto</span>
        <span id="sum-neto" style="font-size:1.5rem;font-weight:700;color:#B5985A;font-family:'Montserrat',sans-serif;">—</span>
      </div>
    </div>

    <!-- ============ CUENTAS ============ -->
    <section style="margin-bottom:2rem;">
      <p style={sectionTitle}>Cuentas — mi linea base</p>
      <form id="cuenta-form" style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-end;margin-bottom:0.75rem;background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:8px;padding:0.75rem 1rem;">
        <input name="nombre" type="text" placeholder="Nombre (ej. Tampico) *" required style={inputStyle + "flex:2;min-width:160px;"} />
        <input name="tipo" type="text" placeholder="Tipo (banco, efectivo...)" style={inputStyle + "flex:1;min-width:120px;"} />
        <input name="saldo" type="number" step="any" placeholder="Saldo" style={inputStyle + "width:110px;"} />
        <input name="moneda" type="text" placeholder="MXN" maxlength="6" style={inputStyle + "width:70px;"} />
        <button type="submit" style={btnStyle}>+ Cuenta</button>
        <p id="cuenta-form-msg" style="font-size:11px;color:#F87171;width:100%;margin:0;display:none;"></p>
      </form>
      <div id="cuentas-list" style="display:flex;flex-direction:column;gap:4px;"></div>
    </section>

    <!-- ============ DEUDAS ============ -->
    <section style="margin-bottom:2rem;">
      <p style={sectionTitle}>Deudas</p>
      <form id="deuda-form" style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-end;margin-bottom:0.75rem;background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:8px;padding:0.75rem 1rem;">
        <input name="acreedor" type="text" placeholder="Acreedor *" required style={inputStyle + "flex:2;min-width:150px;"} />
        <input name="monto" type="number" step="any" placeholder="Monto" style={inputStyle + "width:110px;"} />
        <input name="cuota" type="number" step="any" placeholder="Cuota" style={inputStyle + "width:100px;"} />
        <input name="fecha_limite" type="date" style={dateStyle} />
        <button type="submit" style={btnStyle}>+ Deuda</button>
        <p id="deuda-form-msg" style="font-size:11px;color:#F87171;width:100%;margin:0;display:none;"></p>
      </form>
      <div id="deudas-list" style="display:flex;flex-direction:column;gap:4px;"></div>
    </section>

    <!-- ============ GASTOS ============ -->
    <section style="margin-bottom:2rem;">
      <p style={sectionTitle}>Gastos</p>
      <form id="gasto-form" style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-end;margin-bottom:0.75rem;background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:8px;padding:0.75rem 1rem;">
        <input name="fecha" type="date" style={dateStyle} />
        <input name="categoria" type="text" placeholder="Categoria" style={inputStyle + "flex:1;min-width:120px;"} />
        <input name="descripcion" type="text" placeholder="Descripcion" style={inputStyle + "flex:2;min-width:160px;"} />
        <input name="monto" type="number" step="any" placeholder="Monto" style={inputStyle + "width:110px;"} />
        <button type="submit" style={btnStyle}>+ Gasto</button>
        <p id="gasto-form-msg" style="font-size:11px;color:#F87171;width:100%;margin:0;display:none;"></p>
      </form>
      <!-- Filtros -->
      <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:0.75rem;align-items:center;">
        <div style="display:flex;gap:4px;align-items:center;">
          <span style="font-size:10px;color:#6B7280;font-family:'Montserrat',sans-serif;letter-spacing:0.08em;text-transform:uppercase;">Mes</span>
          <input id="filtro-mes" type="month" style={dateStyle} />
          <button id="filtro-mes-clear" type="button" style="font-size:10px;color:#6B7280;background:none;border:1px solid rgba(232,234,240,0.12);border-radius:4px;padding:3px 8px;cursor:pointer;font-family:'Montserrat',sans-serif;">Todos</button>
        </div>
        <div style="display:flex;gap:4px;align-items:center;flex:1;min-width:140px;">
          <span style="font-size:10px;color:#6B7280;font-family:'Montserrat',sans-serif;letter-spacing:0.08em;text-transform:uppercase;">Categoria</span>
          <select id="filtro-cat" style={dateStyle + "flex:1;"}>
            <option value="">Todas</option>
          </select>
        </div>
        <span id="gastos-total" style="font-size:12px;color:#B5985A;font-family:'Montserrat',sans-serif;font-weight:600;margin-left:auto;"></span>
      </div>
      <div id="gastos-list" style="display:flex;flex-direction:column;gap:4px;"></div>
    </section>

    <!-- ============ PRESUPUESTOS ============ -->
    <section style="margin-bottom:2rem;">
      <p style={sectionTitle}>Presupuestos — limite mensual por categoria</p>
      <form id="presupuesto-form" style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-end;margin-bottom:0.75rem;background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:8px;padding:0.75rem 1rem;">
        <input name="categoria" type="text" placeholder="Categoria *" required style={inputStyle + "flex:2;min-width:160px;"} />
        <input name="limite_mensual" type="number" step="any" placeholder="Limite mensual" style={inputStyle + "width:140px;"} />
        <button type="submit" style={btnStyle}>+ Presupuesto</button>
        <p id="presupuesto-form-msg" style="font-size:11px;color:#F87171;width:100%;margin:0;display:none;"></p>
      </form>
      <div id="presupuestos-list" style="display:flex;flex-direction:column;gap:6px;"></div>
    </section>
  </div>
</OSLayout>

<script is:inline>
var cuentas = [], deudas = [], gastos = [], presupuestos = [];

function esc(s) {
  return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function money(n, moneda) {
  var v = Number(n) || 0;
  return v.toLocaleString('es-MX', { minimumFractionDigits: 0, maximumFractionDigits: 2 }) + (moneda ? ' ' + moneda : '');
}
function thisMonth() { return new Date().toISOString().slice(0, 7); }
function dlDisplay(dl) {
  if (!dl) return '';
  var today = new Date().toISOString().slice(0,10);
  var color = dl < today ? '#F87171' : '#6B7280';
  var label = new Date(dl + 'T12:00:00').toLocaleDateString('es',{day:'numeric',month:'short',year:'numeric'});
  return '<span style="font-size:11px;color:' + color + ';">' + esc(label) + '</span>';
}
function delBtn(fn, id) {
  return '<button onclick="' + fn + '(\'' + id + '\')" title="Eliminar" style="background:none;border:none;color:rgba(107,114,128,0.4);cursor:pointer;font-size:15px;padding:0;line-height:1;flex-shrink:0;">x</button>';
}

// ---- Resumen ----
function renderResumen() {
  var totCuentas = cuentas.reduce(function(s,c){ return s + (Number(c.saldo)||0); }, 0);
  var totDeudas = deudas.reduce(function(s,d){ return d.estado === 'pagada' ? s : s + (Number(d.monto)||0); }, 0);
  var moneda = cuentas[0] ? cuentas[0].moneda : 'MXN';
  document.getElementById('sum-cuentas').textContent = money(totCuentas, moneda);
  document.getElementById('sum-deudas').textContent = money(totDeudas, moneda);
  document.getElementById('sum-neto').textContent = money(totCuentas - totDeudas, moneda);
}

// ---- CUENTAS ----
function renderCuentas() {
  var list = document.getElementById('cuentas-list');
  if (!cuentas.length) { list.innerHTML = '<div style="color:#6B7280;font-size:12px;padding:0.5rem 0;">Sin cuentas aun.</div>'; return; }
  list.innerHTML = cuentas.map(function(c) {
    return '<div style="display:flex;align-items:center;gap:10px;background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:6px;padding:0.55rem 0.875rem;">'
      + '<p style="font-size:13px;color:#F4F6F8;margin:0;flex:1;min-width:0;">' + esc(c.nombre) + (c.tipo ? ' <span style="color:#6B7280;font-size:11px;">· ' + esc(c.tipo) + '</span>' : '') + '</p>'
      + '<button onclick="editSaldo(\'' + c.id + '\',' + (Number(c.saldo)||0) + ')" style="font-size:13px;color:#B5985A;font-family:Montserrat,sans-serif;font-weight:600;background:none;border:none;cursor:pointer;">' + esc(money(c.saldo, c.moneda)) + '</button>'
      + delBtn('delCuenta', c.id)
      + '</div>';
  }).join('');
}
async function editSaldo(id, current) {
  var val = prompt('Nuevo saldo:', current);
  if (val === null) return;
  await patch('cuentas', id, { saldo: Number(val) || 0 });
}
async function delCuenta(id) {
  if (!confirm('Eliminar esta cuenta?')) return;
  await del('cuentas', id);
}

// ---- DEUDAS ----
function renderDeudas() {
  var list = document.getElementById('deudas-list');
  if (!deudas.length) { list.innerHTML = '<div style="color:#6B7280;font-size:12px;padding:0.5rem 0;">Sin deudas registradas.</div>'; return; }
  list.innerHTML = deudas.map(function(d) {
    var pagada = d.estado === 'pagada';
    return '<div style="display:flex;align-items:center;gap:10px;background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:6px;padding:0.55rem 0.875rem;opacity:' + (pagada ? '0.55' : '1') + ';">'
      + '<p style="font-size:13px;color:#F4F6F8;margin:0;flex:1;min-width:0;text-decoration:' + (pagada ? 'line-through' : 'none') + ';">' + esc(d.acreedor) + '</p>'
      + (d.cuota ? '<span style="font-size:11px;color:#6B7280;">cuota ' + esc(money(d.cuota)) + '</span>' : '')
      + (d.fecha_limite ? dlDisplay(d.fecha_limite) : '')
      + '<span style="font-size:13px;color:#B5985A;font-family:Montserrat,sans-serif;font-weight:600;">' + esc(money(d.monto)) + '</span>'
      + '<button onclick="toggleDeuda(\'' + d.id + '\',\'' + esc(d.estado) + '\')" title="Marcar pagada/activa" style="font-size:10px;color:' + (pagada ? '#22c55e' : '#6B7280') + ';background:none;border:1px solid rgba(232,234,240,0.12);border-radius:4px;padding:2px 7px;cursor:pointer;font-family:Montserrat,sans-serif;white-space:nowrap;">' + (pagada ? 'pagada' : 'activa') + '</button>'
      + delBtn('delDeuda', d.id)
      + '</div>';
  }).join('');
}
async function toggleDeuda(id, estado) {
  await patch('deudas', id, { estado: estado === 'pagada' ? 'activa' : 'pagada' });
}
async function delDeuda(id) {
  if (!confirm('Eliminar esta deuda?')) return;
  await del('deudas', id);
}

// ---- GASTOS ----
function rebuildCatFilter() {
  var sel = document.getElementById('filtro-cat');
  var cur = sel.value;
  var cats = {};
  gastos.forEach(function(g){ if (g.categoria) cats[g.categoria] = true; });
  sel.innerHTML = '<option value="">Todas</option>' + Object.keys(cats).sort().map(function(c){
    return '<option value="' + esc(c) + '">' + esc(c) + '</option>';
  }).join('');
  sel.value = cur;
}
function filteredGastos() {
  var mes = document.getElementById('filtro-mes').value;
  var cat = document.getElementById('filtro-cat').value;
  return gastos.filter(function(g) {
    if (mes && (g.fecha || '').slice(0,7) !== mes) return false;
    if (cat && g.categoria !== cat) return false;
    return true;
  });
}
function renderGastos() {
  rebuildCatFilter();
  var list = document.getElementById('gastos-list');
  var rows = filteredGastos();
  var total = rows.reduce(function(s,g){ return s + (Number(g.monto)||0); }, 0);
  document.getElementById('gastos-total').textContent = rows.length ? (rows.length + ' gastos · ' + money(total)) : '';
  if (!rows.length) { list.innerHTML = '<div style="color:#6B7280;font-size:12px;padding:0.5rem 0;">Sin gastos con estos filtros.</div>'; return; }
  list.innerHTML = rows.map(function(g) {
    var fecha = g.fecha ? new Date(g.fecha + 'T12:00:00').toLocaleDateString('es',{day:'numeric',month:'short'}) : '';
    return '<div style="display:flex;align-items:center;gap:10px;background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:6px;padding:0.5rem 0.875rem;">'
      + '<span style="font-size:11px;color:#6B7280;width:54px;flex-shrink:0;">' + esc(fecha) + '</span>'
      + (g.categoria ? '<span style="font-size:10px;color:#6B7AE8;background:rgba(107,122,232,0.12);padding:1px 7px;border-radius:4px;flex-shrink:0;">' + esc(g.categoria) + '</span>' : '')
      + '<p style="font-size:13px;color:#F4F6F8;margin:0;flex:1;min-width:0;">' + esc(g.descripcion || '') + '</p>'
      + '<span style="font-size:13px;color:#B5985A;font-family:Montserrat,sans-serif;font-weight:600;">' + esc(money(g.monto)) + '</span>'
      + delBtn('delGasto', g.id)
      + '</div>';
  }).join('');
}
async function delGasto(id) {
  if (!confirm('Eliminar este gasto?')) return;
  await del('gastos', id);
}

// ---- PRESUPUESTOS ----
function gastadoEsteMes(categoria) {
  var mes = thisMonth();
  return gastos.reduce(function(s,g) {
    if (g.categoria === categoria && (g.fecha || '').slice(0,7) === mes) return s + (Number(g.monto)||0);
    return s;
  }, 0);
}
function renderPresupuestos() {
  var list = document.getElementById('presupuestos-list');
  if (!presupuestos.length) { list.innerHTML = '<div style="color:#6B7280;font-size:12px;padding:0.5rem 0;">Sin presupuestos definidos.</div>'; return; }
  list.innerHTML = presupuestos.map(function(p) {
    var limite = Number(p.limite_mensual) || 0;
    var usado = gastadoEsteMes(p.categoria);
    var pct = limite > 0 ? Math.min(100, (usado / limite) * 100) : 0;
    var over = limite > 0 && usado > limite;
    var barColor = over ? '#F87171' : (pct > 80 ? '#FB923C' : '#3B4ED9');
    return '<div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:8px;padding:0.7rem 0.875rem;">'
      + '<div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;">'
        + '<p style="font-size:13px;color:#F4F6F8;margin:0;flex:1;font-weight:500;">' + esc(p.categoria) + '</p>'
        + '<span style="font-size:12px;color:' + (over ? '#F87171' : '#B5985A') + ';font-family:Montserrat,sans-serif;font-weight:600;">' + esc(money(usado)) + ' / ' + esc(money(limite)) + '</span>'
        + '<button onclick="editLimite(\'' + p.id + '\',' + limite + ')" style="font-size:10px;color:#6B7280;background:none;border:1px solid rgba(232,234,240,0.12);border-radius:4px;padding:2px 7px;cursor:pointer;font-family:Montserrat,sans-serif;">editar</button>'
        + delBtn('delPresupuesto', p.id)
      + '</div>'
      + '<div style="height:6px;background:rgba(232,234,240,0.08);border-radius:99px;overflow:hidden;">'
        + '<div style="height:100%;width:' + pct + '%;background:' + barColor + ';border-radius:99px;transition:width .3s;"></div>'
      + '</div>'
      + (over ? '<p style="font-size:10px;color:#F87171;margin:5px 0 0;">Excedido por ' + esc(money(usado - limite)) + ' este mes</p>' : '')
      + '</div>';
  }).join('');
}
async function editLimite(id, current) {
  var val = prompt('Nuevo limite mensual:', current);
  if (val === null) return;
  await patch('presupuestos', id, { limite_mensual: Number(val) || 0 });
}
async function delPresupuesto(id) {
  if (!confirm('Eliminar este presupuesto?')) return;
  await del('presupuestos', id);
}

// ---- shared API helpers ----
async function patch(tabla, id, body) {
  try {
    var res = await fetch('/api/os/' + tabla + '?id=' + encodeURIComponent(id), {
      method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
    });
    if (!res.ok) throw new Error(String(res.status));
    await loadAll();
  } catch(e) { alert('Error: ' + e.message); }
}
async function del(tabla, id) {
  try {
    var res = await fetch('/api/os/' + tabla + '?id=' + encodeURIComponent(id), { method: 'DELETE' });
    if (!res.ok) throw new Error(String(res.status));
    await loadAll();
  } catch(e) { alert('Error: ' + e.message); }
}

function wireForm(formId, tabla, msgId) {
  var form = document.getElementById(formId);
  if (!form) return;
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    var msg = document.getElementById(msgId);
    if (msg) msg.style.display = 'none';
    var fd = new FormData(form);
    var body = {};
    fd.forEach(function(v, k){ body[k] = v; });
    try {
      var res = await fetch('/api/os/' + tabla, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
      });
      var jsonR = await res.json();
      if (!res.ok) throw new Error(jsonR.error || String(res.status));
      form.reset();
      await loadAll();
    } catch(err) {
      if (msg) { msg.textContent = 'Error: ' + err.message; msg.style.display = 'block'; }
    }
  });
}

async function loadAll() {
  try {
    var results = await Promise.all([
      fetch('/api/os/cuentas').then(function(r){ return r.json(); }),
      fetch('/api/os/deudas').then(function(r){ return r.json(); }),
      fetch('/api/os/gastos').then(function(r){ return r.json(); }),
      fetch('/api/os/presupuestos').then(function(r){ return r.json(); }),
    ]);
    cuentas = results[0].cuentas || [];
    deudas = results[1].deudas || [];
    gastos = results[2].gastos || [];
    presupuestos = results[3].presupuestos || [];
    renderResumen();
    renderCuentas();
    renderDeudas();
    renderGastos();
    renderPresupuestos();
  } catch(e) {
    var cl = document.getElementById('cuentas-list');
    if (cl) cl.innerHTML = '<div style="color:#F87171;font-size:12px;padding:1rem;">Error cargando datos: ' + esc(e.message) + '</div>';
  }
}

wireForm('cuenta-form', 'cuentas', 'cuenta-form-msg');
wireForm('deuda-form', 'deudas', 'deuda-form-msg');
wireForm('gasto-form', 'gastos', 'gasto-form-msg');
wireForm('presupuesto-form', 'presupuestos', 'presupuesto-form-msg');

document.getElementById('filtro-mes').addEventListener('change', renderGastos);
document.getElementById('filtro-cat').addEventListener('change', renderGastos);
document.getElementById('filtro-mes-clear').addEventListener('click', function(){
  document.getElementById('filtro-mes').value = '';
  renderGastos();
});

loadAll();
</script>
