---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
import { datosDaily } from '../../os/data/daily';
import OSChecklist from '../../os/components/OSChecklist';

const { principios, semana, rutina_am, check_10min, pm_close, reglas } = datosDaily;

const tipoColor: Record<string, string> = {
  maker:   'var(--os-accent)',
  manager: 'var(--os-muted)',
  off:     'var(--os-muted)',
};
const tipoBg: Record<string, string> = {
  maker:   'rgba(59,78,217,0.15)',
  manager: 'rgba(232,234,240,0.06)',
  off:     'rgba(232,234,240,0.03)',
};
const tipoLabel: Record<string, string> = {
  maker:   'Maker',
  manager: 'Manager',
  off:     'Off',
};
---

<OSLayout title="Daily OS">
  <div class="os-fade-up">

    <!-- Header -->
    <div style="margin-bottom:1.5rem;">
      <p class="os-eyebrow" style="margin-bottom:6px;">Sistema diario</p>
      <h1 class="os-h1">Daily OS</h1>
    </div>

    <!-- Principios -->
    <div class="os-card-2" style="margin-bottom:1rem;">
      <p class="os-section-title">Mis principios</p>
      <ol style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:6px;">
        {principios.map((p, i) => (
          <li style="display:flex;align-items:flex-start;gap:10px;">
            <span class="os-mono" style="font-size:11px;font-weight:700;color:var(--os-accent);min-width:16px;padding-top:2px;">{i + 1}</span>
            <span style="font-size:14px;color:var(--os-text);line-height:1.4;">{p}</span>
          </li>
        ))}
      </ol>
    </div>

    <!-- Semana Maker / Manager -->
    <div class="os-card-2" style="margin-bottom:1rem;">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:0.875rem;">
        <span class="material-symbols-outlined" style="font-size:18px;color:var(--os-accent-light);">calendar_view_week</span>
        <p class="os-section-title" style="margin:0;">Mi semana Maker / Manager</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:6px;">
        {semana.map((d) => (
          <div style={`background:${tipoBg[d.tipo]};border:1px solid ${d.tipo === 'maker' ? 'var(--os-line-accent)' : 'var(--os-line-soft)'};border-radius:var(--os-r-md);padding:0.625rem 0.5rem;text-align:center;`}>
            <p style="font-family:var(--os-font-display);font-size:10px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;color:var(--os-muted);margin:0 0 4px;">{d.dia.slice(0,3)}</p>
            <p style={`font-family:var(--os-font-display);font-size:9px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:${tipoColor[d.tipo]};margin:0 0 4px;`}>{tipoLabel[d.tipo]}</p>
            <p style="font-size:10px;color:var(--os-muted);margin:0;line-height:1.3;">{d.descripcion}</p>
          </div>
        ))}
      </div>
      <div style="margin-top:0.75rem;display:flex;flex-wrap:wrap;gap:1.5rem;">
        <div style="display:flex;align-items:center;gap:5px;">
          <span style="width:8px;height:8px;border-radius:2px;background:var(--os-accent);display:block;"></span>
          <span style="font-size:11px;color:var(--os-muted);">Maker: crear y entregar (Mie, Vie, Sab)</span>
        </div>
        <div style="display:flex;align-items:center;gap:5px;">
          <span style="width:8px;height:8px;border-radius:2px;background:rgba(232,234,240,0.2);display:block;"></span>
          <span style="font-size:11px;color:var(--os-muted);">Manager: reuniones y tramites (Lun, Mar, Jue)</span>
        </div>
      </div>
    </div>

    <!-- Mi dia + rutinas -->
    <div class="os-2col" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">

      <!-- Rutina AM -->
      <div class="os-card-2">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:0.875rem;">
          <span class="material-symbols-outlined" style="font-size:18px;color:var(--os-champagne);">wb_sunny</span>
          <p class="os-section-title" style="margin:0;">Ancla AM</p>
        </div>
        <OSChecklist items={rutina_am} client:load />
      </div>

      <!-- Check 10 min + PM Close + reglas -->
      <div style="display:flex;flex-direction:column;gap:1rem;">
        <div class="os-card-2">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:0.75rem;">
            <span class="material-symbols-outlined" style="font-size:18px;color:var(--os-accent-light);">timer</span>
            <p class="os-section-title" style="margin:0;">Check de 10 min</p>
          </div>
          <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:7px;">
            {check_10min.map((q) => (
              <li style="display:flex;align-items:flex-start;gap:8px;">
                <span class="material-symbols-outlined" style="font-size:16px;color:var(--os-accent-light);flex-shrink:0;margin-top:1px;">help</span>
                <span style="font-size:13px;color:var(--os-text);line-height:1.4;">{q}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="os-card-2">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:0.875rem;">
            <span class="material-symbols-outlined" style="font-size:18px;color:var(--os-accent-light);">bedtime</span>
            <p class="os-section-title" style="margin:0;">Cierre PM</p>
          </div>
          <OSChecklist items={pm_close} client:load />
        </div>

        <!-- Reglas innegociables -->
        <div class="os-card-2 os-card-accent">
          <p class="os-eyebrow" style="margin:0 0 0.625rem;">Reglas</p>
          <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:6px;">
            {reglas.map((r) => (
              <li style="font-size:13px;color:var(--os-text);line-height:1.4;padding-left:14px;position:relative;">
                <span style="position:absolute;left:0;top:7px;width:5px;height:1px;background:var(--os-accent);display:block;"></span>
                {r}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <style>
    @media (max-width: 820px) {
      .os-2col { grid-template-columns: 1fr !important; }
    }
  </style>
</OSLayout>
