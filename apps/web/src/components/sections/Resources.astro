---
// Resources — sección del Home. Único recurso activo: Kit IA para tus finanzas.
---

<section id="recursos" class="bg-bg-elevated py-12 md:py-20">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-8">
    <h2
      class="font-montserrat font-bold text-text-primary text-[32px] md:text-[36px] mb-14"
      data-reveal
    >
      Recursos
    </h2>

    <div class="max-w-[600px]" data-reveal>
      <div class="bg-bg-primary rounded-lg p-8 border border-ember flex flex-col gap-5">
        <span class="inline-block bg-ember text-white font-montserrat text-[10px] uppercase tracking-[1.5px] px-3 py-1 rounded-full self-start">
          Gratis
        </span>
        <div>
          <h3 class="font-montserrat font-semibold text-text-primary text-[22px] mb-2">
            Kit IA para tus finanzas
          </h3>
          <p class="font-inter text-text-secondary text-[15px] leading-relaxed">
            Prompts, plantillas y metodología para ordenar tus finanzas personales o de negocio con inteligencia artificial. Workbook Excel, biblioteca de prompts, skills para Claude y checklists de cierre.
          </p>
        </div>
        <a
          href="/kit"
          class="inline-block self-start font-inter font-medium text-[14px] text-white bg-ember px-6 py-3 rounded-md hover:brightness-110 transition-colors"
        >
          Descarga gratis →
        </a>
      </div>
    </div>
  </div>
</section>
