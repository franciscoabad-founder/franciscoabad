    <div class="mt-8 flex flex-col items-center gap-2">
      <div class="w-8 h-px" style="background-color: hsl(var(--accent-cobalt)); opacity: 0.6;"></div>
      <p class="font-inter font-medium text-text-muted-brand text-[11px] uppercase tracking-[3px]">
        Francisco Abad
      </p>
    </div>

  </div>
</section>
