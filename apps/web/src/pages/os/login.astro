---
export const prerender = false;

const error = Astro.url.searchParams.get('error');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Acceso — OS · Francisco Abad</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#060C1E" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="OS Pancho" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;900&family=Inter:wght@400;500;600&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: #071132;
        color: #E8EAF0;
        font-family: 'Inter', sans-serif;
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
        -webkit-font-smoothing: antialiased;
        background-image:
          radial-gradient(ellipse 70% 55% at 50% 30%, rgba(59,78,217,0.14) 0%, transparent 70%),
          linear-gradient(rgba(59,78,217,0.025) 1px, transparent 1px),
          linear-gradient(90deg, rgba(59,78,217,0.025) 1px, transparent 1px);
        background-size: auto, 36px 36px, 36px 36px;
        padding: 1rem;
      }
      .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
      @keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.5;} }
      .mode {
        display: inline-flex; align-items: center; gap: 6px; margin-bottom: 1.5rem;
      }
      .mode .material-symbols-outlined { font-size: 17px; color: #6B7AE8; animation: pulse 2.4s cubic-bezier(0.4,0,0.6,1) infinite; }
      .mode span:last-child {
        font-family: 'Montserrat', sans-serif; font-size: 9px; font-weight: 700;
        letter-spacing: 0.2em; text-transform: uppercase; color: #6B7AE8;
      }
      .card {
        position: relative;
        background: rgba(26,43,107,0.55);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(59,78,217,0.30);
        border-radius: 16px;
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 372px;
        box-shadow: 0 18px 48px rgba(14,23,56,0.40);
      }
      h1 { font-family: 'Montserrat', sans-serif; font-size: 1.25rem; font-weight: 700; color: #E8EAF0; margin-bottom: 0.375rem; }
      .sub { font-size: 13px; color: #6B7280; margin-bottom: 2rem; line-height: 1.45; }
      .field-label {
        font-family: 'Montserrat', sans-serif; font-size: 9px; font-weight: 600;
        letter-spacing: 0.12em; text-transform: uppercase; color: #6B7280;
        display: block; margin-bottom: 6px;
      }
      input[type="password"] {
        width: 100%;
        background: rgba(232,234,240,0.05);
        border: 1px solid rgba(232,234,240,0.12);
        border-radius: 8px;
        padding: 0.75rem 1rem;
        font-size: 14px; color: #E8EAF0; font-family: 'Inter', sans-serif;
        outline: none; margin-bottom: 1rem; transition: border-color 0.15s;
      }
      input[type="password"]:focus { border-color: rgba(59,78,217,0.55); }
      button[type="submit"] {
        width: 100%;
        background: #3B4ED9; border: none; border-radius: 8px;
        padding: 0.8rem 1rem;
        font-family: 'Montserrat', sans-serif; font-size: 12px; font-weight: 700;
        letter-spacing: 0.1em; text-transform: uppercase; color: #fff;
        cursor: pointer; transition: background 0.15s, transform 0.12s;
        display: inline-flex; align-items: center; justify-content: center; gap: 7px;
      }
      button[type="submit"]:hover { background: #4a5fea; }
      button[type="submit"]:active { transform: scale(0.98); }
      .error-msg {
        font-size: 12px; color: #ffb4ab; margin-bottom: 1rem;
        padding: 0.5rem 0.75rem; background: rgba(147,0,10,0.18);
        border-radius: 6px; border: 1px solid rgba(255,180,171,0.25);
      }
      .back-link { display: block; margin-top: 1.5rem; font-size: 11px; color: #6B7280; text-decoration: none; text-align: center; letter-spacing: 0.03em; }
      .back-link:hover { color: #E8EAF0; }
    </style>
  </head>
  <body>
    <div class="card">
      <span class="mode">
        <span class="material-symbols-outlined">bolt</span>
        <span>OS · Francisco Abad</span>
      </span>
      <h1>Acceso restringido</h1>
      <p class="sub">Sistema operativo personal. Solo para uso del titular.</p>
      {error && (
        <p class="error-msg">Contrasena incorrecta. Intenta de nuevo.</p>
      )}
      <form method="POST" action="/api/os-auth">
        <label class="field-label" for="password">Contrasena</label>
        <input type="password" id="password" name="password" placeholder="••••••••••••" autofocus required />
        <button type="submit">
          <span class="material-symbols-outlined" style="font-size:16px;">lock_open</span>
          Entrar al OS
        </button>
      </form>
      <a href="/" class="back-link">franciscoabad.com</a>
    </div>
  </body>
</html>
