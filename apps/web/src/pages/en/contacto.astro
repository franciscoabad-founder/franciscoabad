---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { useTranslations } from "../../i18n/utils";

const lang = "en";
const t = useTranslations(lang);

const subjects = ["Consulting", "Speaking", "Products", "Other"];

const inputClass =
  "w-full bg-bg-primary border border-border-subtle rounded-md px-4 py-3 font-inter text-text-primary text-[14px] placeholder:text-text-muted-brand focus:outline-none focus:border-ember transition-colors duration-300";

const labelClass =
  "block font-montserrat font-semibold text-text-secondary text-[11px] uppercase tracking-[1.5px] mb-2";
---

<BaseLayout
  title={t("page.contacto.title")}
  description={t("page.contacto.desc")}
>
  <Navbar />

  <div class="bg-bg-primary min-h-screen">
    <section class="pt-32 pb-24">
      <div class="max-w-[800px] mx-auto px-6 lg:px-8">
        <div class="mb-12">
          <h1 class="font-montserrat font-bold text-text-primary text-[40px] md:text-[52px] leading-tight mb-6">
            Let's talk.
          </h1>
          <p class="font-inter text-text-secondary text-[16px] leading-relaxed">
            {t("page.contacto.desc")}
          </p>
        </div>

        <div class="mb-8">
          <a
            href="mailto:francisco@franciscoabad.com"
            class="inline-flex items-center gap-3 font-inter text-text-primary text-[16px] hover:text-ember transition-colors duration-300"
          >
            <span class="text-ember">✉</span>
            francisco@franciscoabad.com
          </a>
        </div>

        <form class="space-y-6" onsubmit="event.preventDefault();">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label class={labelClass}>Name</label>
              <input type="text" placeholder="Your name" class={inputClass} />
            </div>
            <div>
              <label class={labelClass}>Email</label>
              <input type="email" placeholder="your@email.com" class={inputClass} />
            </div>
          </div>

          <div>
            <label class={labelClass}>Subject</label>
            <select class={inputClass}>
              {subjects.map((s) => <option value={s.toLowerCase()}>{s}</option>)}
            </select>
          </div>

          <div>
            <label class={labelClass}>Message</label>
            <textarea rows={5} placeholder="Tell me what you're working on..." class={inputClass} />
          </div>

          <button
            type="submit"
            class="w-full bg-ember text-white font-montserrat font-semibold text-[13px] uppercase tracking-[1.5px] py-4 rounded-md hover:opacity-90 transition-opacity duration-300"
          >
            Send message
          </button>
        </form>
      </div>
    </section>
  </div>
  <Footer lang={lang} />
</BaseLayout>
