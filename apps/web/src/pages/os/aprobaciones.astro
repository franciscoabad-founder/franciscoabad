---
export const prerender = false;

import OSLayout from '../../layouts/OSLayout.astro';
import OSAprobaciones from '../../os/components/OSAprobaciones';
import { aprobacionesDefault } from '../../os/data/sistema';
---

<OSLayout title="Aprobaciones">
  <div class="os-fade-up">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:0.75rem;margin-bottom:1.5rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Gate</p>
        <h1 class="os-h1">Aprobaciones</h1>
      </div>
      <a class="os-btn os-btn-ghost" href="/os/sistema" style="text-decoration:none;">
        <span class="material-symbols-outlined" style="font-size:16px;">account_tree</span>
        Mi Sistema
      </a>
    </div>

    <div class="os-card os-card-accent" style="margin-bottom:1rem;">
      <p class="os-section-title">Como opera</p>
      <p style="font-size:13px;color:var(--os-text-2);line-height:1.6;margin:0;">
        Las decisiones sensibles pasan por este gate. Si `APPROVAL_WEBHOOK_URL` esta configurado, cada aprobacion se envia a n8n para que Hermes ejecute el siguiente paso.
      </p>
    </div>

    <OSAprobaciones initialApprovals={aprobacionesDefault} client:load />
  </div>
</OSLayout>
