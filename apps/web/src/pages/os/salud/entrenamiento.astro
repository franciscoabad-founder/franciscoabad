import OSSaludEntrenamiento from '../../../os/components/salud/OSSaludEntrenamiento';
import OSSaludNav from '../../../os/components/salud/OSSaludNav.astro';
---

<OSLayout title="Entrenamiento">
  <div class="os-fade-up">
    <div style="margin-bottom:1rem;">
      <p class="os-eyebrow" style="margin-bottom:6px;">Salud · Entrenamiento</p>
