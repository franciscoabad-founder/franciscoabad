---
export const prerender = false;

import OSLayout from '../../layouts/OSLayout.astro';
import { datosHoy } from '../../os/data/hoy';
import { objetivos } from '../../os/data/objetivos';
import { datosDaily } from '../../os/data/daily';
import { kpis } from '../../os/data/kpis';
import { notas } from '../../os/data/cerebro';
import OSChecklist from '../../os/components/OSChecklist';
import OSOnboarding from '../../os/components/OSOnboarding';

const { domino, discomfort, checklist, wins, priorities } = datosHoy;

const urgenciaColor: Record<string, string> = { alta: '#3B4ED9', media: '#6B7AE8', baja: '#6B7280' };
const tipoColor: Record<string, string> = { maker: '#6B7AE8', manager: '#6B7280', off: '#6B7280' };
const tipoBg: Record<string, string>    = { maker: 'rgba(59,78,217,0.15)', manager: 'rgba(232,234,240,0.06)', off: 'rgba(232,234,240,0.03)' };
const tipoLabel: Record<string, string> = { maker: 'Maker', manager: 'Manager', off: 'Off' };

const trendIcon: Record<string, string> = {
  up:   '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>',
  down: '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 17 13.5 8.5 8.5 13.5 2 7"/><polyline points="16 17 22 17 22 11"/></svg>',
  flat: '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>',
};

const fechaLarga = new Date().toLocaleDateString('es-EC', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
});
---

<OSLayout title="Hoy">
  <OSOnboarding client:load />
  <div class="os-fade-up">

    <!-- Header -->
    <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.5rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Cockpit</p>
        <h1 class="os-h1">Hoy</h1>
      </div>
      <span style="font-size:12px;color:var(--os-muted);text-transform:capitalize;">{fechaLarga}</span>
    </div>

    <!-- KPI strip -->
    <div class="os-kpi-grid" style="margin-bottom:1.25rem;">
      {kpis.slice(0, 6).map((k) => (
        <div class="os-kpi">
          <p class="os-kpi-label">{k.label}</p>
          <p class="os-kpi-value">{k.valor}</p>
          <div style="display:flex;align-items:center;gap:4px;">
            <span set:html={trendIcon[k.tendencia]} />
            <span style="font-size:10px;color:var(--os-muted);">{k.cambio}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- One Domino -->
    <div class="os-domino" style="margin-bottom:1rem;">
      <p class="os-eyebrow" style="margin-bottom:0.5rem;">One Domino</p>
      <p style="font-size:1.125rem;font-weight:600;color:var(--os-text);margin:0 0 0.375rem;line-height:1.3;">{domino.tarea}</p>
      <p style="font-size:12px;color:var(--os-accent-light);margin:0 0 0.5rem;">{domino.proyecto}</p>
      <div style="display:flex;align-items:center;gap:6px;color:var(--os-text-2);">
        <span class="material-symbols-outlined" style="font-size:16px;color:var(--os-accent-light);">lightbulb</span>
        <span style="font-size:13px;font-style:italic;line-height:1.4;">{domino.razon}</span>
      </div>
    </div>

    <!-- 2-col: priorities/wins + checklist/discomfort/principios -->
    <div class="os-2col" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">

      <div style="display:flex;flex-direction:column;gap:1rem;">
        <div class="os-card" style="flex:1;">
          <p class="os-section-title">Priority Stack</p>
          <ol style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:8px;">
            {priorities.map((p, i) => (
              <li style="display:flex;align-items:flex-start;gap:10px;">
                <span class="os-mono" style={`font-size:10px;font-weight:700;color:${urgenciaColor[p.urgencia]};min-width:16px;padding-top:2px;`}>{i + 1}</span>
                <div>
                  <span style="font-size:13px;color:var(--os-text);">{p.tarea}</span>
                  <span style="font-size:11px;color:var(--os-muted);margin-left:6px;">{p.proyecto}</span>
                </div>
              </li>
            ))}
          </ol>
        </div>

        <div class="os-card">
          <p class="os-section-title">Wins recientes</p>
          <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:7px;">
            {wins.map((w) => (
              <li style="display:flex;align-items:flex-start;gap:8px;">
                <span class="material-symbols-outlined" style="font-size:15px;color:var(--os-accent-light);flex-shrink:0;margin-top:1px;">check_circle</span>
                <span style="font-size:13px;color:var(--os-text-2);line-height:1.4;">{w.texto}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div style="display:flex;flex-direction:column;gap:1rem;">
        <div class="os-card">
          <OSChecklist items={checklist} title="Checklist del dia" client:load />
        </div>

        <div class="os-card" style="border-color:rgba(255,180,171,0.22);background:linear-gradient(180deg,rgba(147,0,10,0.10),var(--os-surface));">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:0.625rem;">
            <span class="material-symbols-outlined" style="font-size:18px;color:var(--os-warn);">priority_high</span>
            <p class="os-eyebrow" style="color:var(--os-warn);margin:0;">Discomfort First</p>
          </div>
          <p style="font-size:14px;font-weight:600;color:var(--os-text);margin:0 0 0.375rem;line-height:1.35;">{discomfort.tarea}</p>
          <p style="font-size:12px;color:var(--os-muted);margin:0;line-height:1.4;">{discomfort.contexto}</p>
        </div>

        <div class="os-card">
          <p class="os-section-title">Principios</p>
          <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:5px;">
            {datosDaily.principios.map((p, i) => (
              <li style="display:flex;gap:8px;">
                <span class="os-mono" style="font-size:9px;font-weight:700;color:var(--os-accent);min-width:14px;padding-top:2px;">{i + 1}</span>
                <span style="font-size:12px;color:var(--os-muted);line-height:1.35;">{p}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Semana + objetivos -->
    <div class="os-2col" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
      <div class="os-card">
        <p class="os-section-title">Semana Maker / Manager</p>
        <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:5px;">
          {datosDaily.semana.map((d) => (
            <div style={`background:${tipoBg[d.tipo]};border:1px solid ${d.tipo === 'maker' ? 'rgba(59,78,217,0.18)' : 'rgba(232,234,240,0.06)'};border-radius:6px;padding:0.5rem 0.25rem;text-align:center;`}>
              <p style="font-family:var(--os-font-display);font-size:8px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;color:var(--os-muted);margin:0 0 3px;">{d.dia.slice(0,3)}</p>
              <p style={`font-family:var(--os-font-display);font-size:7px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:${tipoColor[d.tipo]};margin:0;`}>{tipoLabel[d.tipo]}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="os-card os-card-accent">
        <p class="os-eyebrow" style="margin-bottom:0.75rem;">Norte · 90 dias</p>
        <div style="display:flex;flex-direction:column;gap:9px;">
          {objetivos.map((o, i) => (
            <div style="display:flex;align-items:flex-start;gap:10px;">
              <span class="os-num" style="font-size:11px;min-width:18px;padding-top:1px;">{i + 1}</span>
              <div>
                <span style="font-size:13px;font-weight:600;color:var(--os-text);">{o.titulo}.</span>
                <span style="font-size:12px;color:var(--os-muted);margin-left:5px;">{o.descripcion}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Brain feed -->
    <div class="os-card">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.875rem;">
        <p class="os-section-title" style="margin:0;">Cerebro · ultimas notas</p>
        <a href="/os/cerebro" style="font-size:11px;color:var(--os-accent-light);text-decoration:none;font-family:var(--os-font-display);letter-spacing:0.06em;">ver todo</a>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:8px;">
        {notas.slice(0, 4).map((n) => (
          <div style="padding:0.875rem;border-radius:8px;background:rgba(232,234,240,0.03);border:1px solid var(--os-line-soft);">
            <p style="font-size:12px;font-weight:600;color:var(--os-text);margin:0 0 0.375rem;line-height:1.3;">{n.titulo}</p>
            <p style="font-size:11px;color:var(--os-muted);margin:0;line-height:1.4;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">{n.resumen}</p>
          </div>
        ))}
      </div>
    </div>

  </div>

  <style>
    @media (max-width: 820px) {
      .os-2col { grid-template-columns: 1fr !important; }
    }
  </style>
</OSLayout>
