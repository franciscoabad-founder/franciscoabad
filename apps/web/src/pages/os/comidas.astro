---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';

const inputStyle = "background:rgba(232,234,240,0.05);border:1px solid var(--os-line);border-radius:var(--os-r-sm);padding:6px 11px;font-size:12px;color:var(--os-text);font-family:var(--os-font-body);outline:none;";
const selStyle = "background:var(--os-bg-sunken);border:1px solid var(--os-line);border-radius:var(--os-r-sm);padding:6px 11px;font-size:12px;color:var(--os-text);font-family:var(--os-font-body);outline:none;color-scheme:dark;";
const btnStyle = "background:var(--os-accent);color:#fff;border:none;border-radius:var(--os-r-sm);padding:6px 16px;font-size:12px;font-family:var(--os-font-display);font-weight:700;letter-spacing:0.02em;cursor:pointer;white-space:nowrap;flex-shrink:0;display:inline-flex;align-items:center;gap:5px;";
const macroInputStyle = "background:rgba(232,234,240,0.05);border:1px solid var(--os-line);border-radius:var(--os-r-sm);padding:6px 8px;font-size:12px;color:var(--os-text);font-family:var(--os-font-body);outline:none;width:100%;";
---

<OSLayout title="Comidas">
  <div class="os-fade-up">

    <!-- Header con navegacion de dia -->
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:0.5rem;flex-wrap:wrap;gap:0.5rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Bitacora</p>
        <h1 class="os-h1">Comidas</h1>
      </div>
      <div style="display:flex;align-items:center;gap:8px;">
        <button id="dia-prev" title="Dia anterior" style="background:var(--os-surface-2);border:1px solid var(--os-line);color:var(--os-text);border-radius:var(--os-r-sm);width:28px;height:28px;cursor:pointer;font-size:14px;">‹</button>
        <p id="dia-label" class="os-num" style="font-size:12px;margin:0;min-width:120px;text-align:center;">Cargando...</p>
        <button id="dia-next" title="Dia siguiente" style="background:var(--os-surface-2);border:1px solid var(--os-line);color:var(--os-text);border-radius:var(--os-r-sm);width:28px;height:28px;cursor:pointer;font-size:14px;">›</button>
        <button id="dia-hoy" style="background:none;border:1px solid var(--os-line);color:var(--os-muted);border-radius:var(--os-r-sm);padding:5px 10px;font-size:11px;cursor:pointer;">Hoy</button>
      </div>
    </div>
    <p style="font-size:12px;color:var(--os-muted);margin:0 0 1.25rem;line-height:1.5;">Bitacora de que y cuando como. Registra calorias y macros para ver tu progreso del dia.</p>

    <!-- Tarjeta Hoy: anillo + macros -->
    <div class="os-card-2" style="display:flex;gap:1.5rem;align-items:center;flex-wrap:wrap;padding:1.25rem;margin-bottom:1.5rem;">
      <div style="position:relative;width:120px;height:120px;flex-shrink:0;">
        <svg viewBox="0 0 120 120" width="120" height="120" style="transform:rotate(-90deg);">
          <circle cx="60" cy="60" r="52" fill="none" stroke="var(--os-line)" stroke-width="10" />
          <circle id="anillo-kcal" cx="60" cy="60" r="52" fill="none" stroke="var(--os-accent)" stroke-width="10" stroke-linecap="round" stroke-dasharray="0 326.7" />
        </svg>
        <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;">
          <p id="kcal-restante" class="os-num" style="font-size:22px;margin:0;line-height:1;">-</p>
          <p style="font-size:9px;color:var(--os-muted);margin:2px 0 0;text-transform:uppercase;letter-spacing:0.08em;">kcal rest.</p>
        </div>
      </div>
      <div style="flex:1;min-width:220px;display:flex;flex-direction:column;gap:10px;">
        <div id="macro-proteina" class="macro-bar-row"></div>
        <div id="macro-carbos" class="macro-bar-row"></div>
        <div id="macro-grasa" class="macro-bar-row"></div>
      </div>
    </div>

    <!-- Quick-add -->
    <form id="comida-form" class="os-card-2" style="display:flex;flex-direction:column;gap:8px;margin-bottom:1.5rem;padding:0.875rem 1rem;">
      <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-end;">
        <select name="momento" style={selStyle}>
          <option value="desayuno">Desayuno</option>
          <option value="almuerzo">Almuerzo</option>
          <option value="cena">Cena</option>
          <option value="snack">Snack</option>
        </select>
        <input name="descripcion" type="text" placeholder="Que comiste *" required style={inputStyle + "flex:2;min-width:180px;"} />
        <input name="notas" type="text" placeholder="Nota (como me senti, contexto...)" style={inputStyle + "flex:1;min-width:140px;"} />
        <input name="foto_url" type="url" placeholder="URL de foto (opcional)" style={inputStyle + "flex:1;min-width:140px;"} />
        <input name="fecha" type="datetime-local" style={selStyle} />
        <button type="submit" style={btnStyle}><span class="material-symbols-outlined" style="font-size:15px;">add</span>Registrar</button>
      </div>
      <details>
        <summary style="font-size:11px;color:var(--os-muted);cursor:pointer;user-select:none;">Macros (opcional)</summary>
        <div style="display:flex;gap:8px;margin-top:8px;flex-wrap:wrap;">
          <div style="flex:1;min-width:80px;">
            <label style="font-size:9px;color:var(--os-muted);text-transform:uppercase;letter-spacing:0.06em;">Kcal</label>
            <input name="kcal" type="number" min="0" step="1" style={macroInputStyle} />
          </div>
          <div style="flex:1;min-width:80px;">
            <label style="font-size:9px;color:var(--os-muted);text-transform:uppercase;letter-spacing:0.06em;">Proteina g</label>
            <input name="proteina_g" type="number" min="0" step="0.1" style={macroInputStyle} />
          </div>
          <div style="flex:1;min-width:80px;">
            <label style="font-size:9px;color:var(--os-muted);text-transform:uppercase;letter-spacing:0.06em;">Carbos g</label>
            <input name="carbos_g" type="number" min="0" step="0.1" style={macroInputStyle} />
          </div>
          <div style="flex:1;min-width:80px;">
            <label style="font-size:9px;color:var(--os-muted);text-transform:uppercase;letter-spacing:0.06em;">Grasa g</label>
            <input name="grasa_g" type="number" min="0" step="0.1" style={macroInputStyle} />
          </div>
        </div>
      </details>
      <p id="comida-form-msg" style="font-size:11px;color:var(--os-error);width:100%;margin:0;display:none;"></p>
    </form>

    <!-- Comidas del dia por momento -->
    <div id="comidas-dia" style="display:flex;flex-direction:column;gap:1rem;margin-bottom:1.5rem;">
      <div class="os-card-2" style="color:var(--os-muted);font-size:13px;">Cargando...</div>
    </div>

    <!-- Historial -->
    <details>
      <summary style="font-size:12px;color:var(--os-muted);cursor:pointer;user-select:none;margin-bottom:0.75rem;">Historial</summary>
      <div id="comidas-list" style="display:flex;flex-direction:column;gap:1.5rem;">
        <div class="os-card-2" style="color:var(--os-muted);font-size:13px;">Cargando...</div>
      </div>
    </details>
  </div>
</OSLayout>

<style>
  .macro-bar-row { display:flex; flex-direction:column; gap:3px; }
</style>

<script is:inline>
var comidas = [];
var diaActual = null;
var MOMENTO_LABEL = { desayuno:'Desayuno', almuerzo:'Almuerzo', cena:'Cena', snack:'Snack' };
var MOMENTO_COLOR = { desayuno:'#B5985A', almuerzo:'#6B7AE8', cena:'#3B4ED9', snack:'#6B7AE8' };
var MOMENTO_ORDEN = ['desayuno', 'almuerzo', 'cena', 'snack'];

function esc(s) {
  return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function dayKey(iso) { return new Date(iso).toISOString().slice(0,10); }
function hoyGuayaquil() {
  var now = new Date();
  return now.toLocaleDateString('en-CA', { timeZone: 'America/Guayaquil' });
}
function dayLabel(key) {
  var today = hoyGuayaquil();
  var d = new Date(key + 'T12:00:00');
  var label = d.toLocaleDateString('es', { weekday:'long', day:'numeric', month:'long' });
  label = label.charAt(0).toUpperCase() + label.slice(1);
  if (key === today) return 'Hoy · ' + label;
  return label;
}
function timeLabel(iso) {
  return new Date(iso).toLocaleTimeString('es', { hour:'2-digit', minute:'2-digit' });
}
function addDias(key, n) {
  var d = new Date(key + 'T12:00:00');
  d.setDate(d.getDate() + n);
  return d.toISOString().slice(0,10);
}

async function delComida(id) {
  if (!confirm('Eliminar este registro?')) return;
  try {
    var res = await fetch('/api/os/comidas?id=' + encodeURIComponent(id), { method:'DELETE' });
    if (!res.ok) throw new Error(String(res.status));
    await loadDia(diaActual);
    await loadHistorial();
  } catch(e) { alert('Error: ' + e.message); }
}

function itemsLine(c) {
  if (!Array.isArray(c.items) || !c.items.length) return '';
  var nombres = c.items.map(function(i) { return typeof i === 'string' ? i : (i.nombre || ''); }).filter(Boolean);
  if (!nombres.length) return '';
  return '<p style="font-size:10px;color:var(--os-muted);margin:2px 0 0;line-height:1.4;">' + esc(nombres.join(', ')) + '</p>';
}

function renderAnillo(totales, meta) {
  var kcalConsumidas = totales.kcal || 0;
  var kcalObjetivo = meta && meta.kcal_objetivo != null ? meta.kcal_objetivo : null;
  var restante = kcalObjetivo != null ? kcalObjetivo - kcalConsumidas : null;
  var circle = document.getElementById('anillo-kcal');
  var perimetro = 2 * Math.PI * 52;
  var pct = kcalObjetivo ? Math.min(kcalConsumidas / kcalObjetivo, 1) : 0;
  circle.setAttribute('stroke-dasharray', (perimetro * pct).toFixed(1) + ' ' + perimetro.toFixed(1));
  circle.style.stroke = (restante != null && restante < 0) ? 'var(--os-error)' : 'var(--os-accent)';

  var kcalEl = document.getElementById('kcal-restante');
  if (restante == null) {
    kcalEl.textContent = Math.round(kcalConsumidas);
    kcalEl.nextElementSibling.textContent = 'kcal hoy';
  } else {
    kcalEl.textContent = Math.round(restante);
    kcalEl.nextElementSibling.textContent = 'kcal rest.';
  }

  function macroBar(elId, label, consumido, objetivo) {
    var el = document.getElementById(elId);
    var pctM = objetivo ? Math.min(consumido / objetivo, 1) : 0;
    var texto = objetivo != null
      ? Math.round(consumido) + 'g / ' + Math.round(objetivo) + 'g'
      : Math.round(consumido) + 'g';
    el.innerHTML = '<div style="display:flex;justify-content:space-between;font-size:10px;">'
      + '<span style="color:var(--os-muted);text-transform:uppercase;letter-spacing:0.06em;">' + label + '</span>'
      + '<span style="color:var(--os-text);font-family:var(--os-font-mono);">' + texto + '</span>'
      + '</div>'
      + '<div style="height:5px;background:var(--os-line-soft);border-radius:3px;overflow:hidden;">'
      + '<div style="height:100%;width:' + (pctM * 100).toFixed(0) + '%;background:var(--os-accent);"></div>'
      + '</div>';
  }
  macroBar('macro-proteina', 'Proteina', totales.proteina_g || 0, meta && meta.proteina_g_objetivo);
  macroBar('macro-carbos', 'Carbos', totales.carbos_g || 0, meta && meta.carbos_g_objetivo);
  macroBar('macro-grasa', 'Grasa', totales.grasa_g || 0, meta && meta.grasa_g_objetivo);
}

function entradaHtml(c) {
  var mom = c.momento || 'snack';
  var color = MOMENTO_COLOR[mom] || '#6B7280';
  var foto = c.foto_url
    ? '<a href="' + esc(c.foto_url) + '" target="_blank" rel="noopener" style="flex-shrink:0;"><img src="' + esc(c.foto_url) + '" alt="" style="width:40px;height:40px;object-fit:cover;border-radius:6px;border:1px solid var(--os-line);" /></a>'
    : '';
  return '<div style="display:flex;align-items:center;gap:10px;background:var(--os-surface-2);border:1px solid var(--os-line-soft);border-radius:var(--os-r-card);padding:0.55rem 0.75rem;">'
    + foto
    + '<div style="flex:1;min-width:0;">'
      + '<div style="display:flex;align-items:center;gap:8px;">'
        + '<span style="font-size:10px;color:var(--os-muted);font-family:var(--os-font-mono);">' + esc(timeLabel(c.fecha)) + '</span>'
        + (c.kcal != null ? '<span style="font-size:11px;color:' + color + ';font-family:var(--os-font-mono);font-weight:600;">' + Math.round(c.kcal) + ' kcal</span>' : '')
      + '</div>'
      + '<p style="font-size:13px;color:var(--os-text);margin:2px 0 0;line-height:1.4;">' + esc(c.descripcion || '') + '</p>'
      + (c.notas ? '<p style="font-size:11px;color:var(--os-muted);margin:2px 0 0;line-height:1.4;">' + esc(c.notas) + '</p>' : '')
      + itemsLine(c)
    + '</div>'
    + '<button onclick="delComida(\'' + c.id + '\')" title="Eliminar" style="background:none;border:none;color:var(--os-muted);cursor:pointer;font-size:16px;padding:0;line-height:1;flex-shrink:0;" class="material-symbols-outlined">close</button>'
    + '</div>';
}

function renderComidasDia(entradas) {
  var wrap = document.getElementById('comidas-dia');
  if (!entradas.length) {
    wrap.innerHTML = '<div class="os-card-2" style="color:var(--os-muted);font-size:12px;text-align:center;">Sin registros este dia. Anota tu primera comida arriba.</div>';
    return;
  }
  var porMomento = {};
  entradas.forEach(function(c) {
    var mom = c.momento || 'snack';
    if (!porMomento[mom]) porMomento[mom] = [];
    porMomento[mom].push(c);
  });
  wrap.innerHTML = MOMENTO_ORDEN.filter(function(m) { return porMomento[m] && porMomento[m].length; }).map(function(mom) {
    var items = porMomento[mom];
    var subtotal = items.reduce(function(s, c) { return s + (Number(c.kcal) || 0); }, 0);
    var color = MOMENTO_COLOR[mom];
    return '<div>'
      + '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">'
        + '<span style="font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:' + color + ';font-family:Montserrat,sans-serif;">' + esc(MOMENTO_LABEL[mom]) + '</span>'
        + (subtotal > 0 ? '<span style="font-size:11px;color:var(--os-muted);font-family:var(--os-font-mono);">' + Math.round(subtotal) + ' kcal</span>' : '')
      + '</div>'
      + '<div style="display:flex;flex-direction:column;gap:6px;">' + items.map(entradaHtml).join('') + '</div>'
      + '</div>';
  }).join('');
}

function renderHistorial(lista) {
  var list = document.getElementById('comidas-list');
  if (!lista.length) {
    list.innerHTML = '<div class="os-card-2" style="color:var(--os-muted);font-size:12px;text-align:center;">Sin registros aun.</div>';
    return;
  }
  var byDay = {};
  lista.forEach(function(c) {
    var k = dayKey(c.fecha);
    if (!byDay[k]) byDay[k] = [];
    byDay[k].push(c);
  });
  var days = Object.keys(byDay).sort().reverse();
  list.innerHTML = days.map(function(k) {
    var items = byDay[k].slice().sort(function(a,b){ return new Date(b.fecha) - new Date(a.fecha); });
    var subtotal = items.reduce(function(s, c) { return s + (Number(c.kcal) || 0); }, 0);
    return '<div>'
      + '<p style="font-family:Montserrat,sans-serif;font-size:10px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--os-muted);margin:0 0 8px;">' + esc(dayLabel(k)) + (subtotal > 0 ? ' · ' + Math.round(subtotal) + ' kcal' : '') + '</p>'
      + '<div style="display:flex;flex-direction:column;gap:6px;">' + items.map(entradaHtml).join('') + '</div></div>';
  }).join('');
}

async function loadDia(dia) {
  diaActual = dia;
  document.getElementById('dia-label').textContent = dayLabel(dia);
  try {
    var res = await fetch('/api/os/comidas?dia=' + encodeURIComponent(dia));
    if (!res.ok) throw new Error(String(res.status));
    var data = await res.json();
    renderComidasDia(data.comidas || []);
    renderAnillo(data.totales || { kcal:0, proteina_g:0, carbos_g:0, grasa_g:0 }, data.meta);
  } catch(e) {
    var wrap = document.getElementById('comidas-dia');
    wrap.innerHTML = '<div style="color:var(--os-error);font-size:12px;padding:1rem;">Error: ' + esc(e.message) + '</div>';
  }
}

async function loadHistorial() {
  try {
    var res = await fetch('/api/os/comidas?historial=1');
    if (!res.ok) throw new Error(String(res.status));
    var data = await res.json();
    comidas = data.comidas || [];
    renderHistorial(comidas);
  } catch(e) {
    var list = document.getElementById('comidas-list');
    if (list) list.innerHTML = '<div style="color:var(--os-error);font-size:12px;padding:1rem;">Error: ' + esc(e.message) + '</div>';
  }
}

document.getElementById('dia-prev').addEventListener('click', function() { loadDia(addDias(diaActual, -1)); });
document.getElementById('dia-next').addEventListener('click', function() { loadDia(addDias(diaActual, 1)); });
document.getElementById('dia-hoy').addEventListener('click', function() { loadDia(hoyGuayaquil()); });

var form = document.getElementById('comida-form');
if (form) {
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    var msg = document.getElementById('comida-form-msg');
    if (msg) msg.style.display = 'none';
    var fd = new FormData(form);
    var fechaVal = fd.get('fecha');
    function num(name) {
      var v = fd.get(name);
      return v === '' || v == null ? null : Number(v);
    }
    var body = {
      momento: fd.get('momento'),
      descripcion: fd.get('descripcion'),
      notas: fd.get('notas') || null,
      foto_url: fd.get('foto_url') || null,
      fecha: fechaVal ? new Date(fechaVal).toISOString() : null,
      kcal: num('kcal'),
      proteina_g: num('proteina_g'),
      carbos_g: num('carbos_g'),
      grasa_g: num('grasa_g'),
    };
    try {
      var res = await fetch('/api/os/comidas', {
        method:'POST', headers:{ 'Content-Type':'application/json' }, body: JSON.stringify(body),
      });
      var jsonR = await res.json();
      if (!res.ok) throw new Error(jsonR.error || String(res.status));
      form.reset();
      await loadDia(diaActual);
      await loadHistorial();
    } catch(err) {
      if (msg) { msg.textContent = 'Error: ' + err.message; msg.style.display = 'block'; }
    }
  });
}

loadDia(hoyGuayaquil());
loadHistorial();
</script>
