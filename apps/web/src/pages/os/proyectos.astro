---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
import OSProyectos from '../../os/components/OSProyectos';
---

<OSLayout title="Proyectos">
  <div class="os-fade-up">

    <!-- Header -->
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:0.75rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Growth OS</p>
        <h1 class="os-h1">Proyectos</h1>
      </div>
      <div style="display:flex;align-items:center;gap:6px;">
        <span class="material-symbols-outlined" style="font-size:15px;color:var(--os-accent-light);">bolt</span>
        <span style="font-size:11px;color:var(--os-muted);">Recibe tiempo Maker</span>
      </div>
    </div>

    <p style="font-size:12.5px;color:var(--os-muted);margin:0 0 1.25rem;line-height:1.5;">
      El Project Stack ordena por prioridad, no por orden de llegada. Un proyecto pausado no
      recibe atencion a proposito: esa es la funcion del stack.
    </p>

    <OSProyectos client:load />
  </div>
</OSLayout>
