---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const sessions = [
  {
    title: "Sesión de Diagnóstico",
    price: "$297",
    duration: "90 min · Zoom",
    includes: [
      "Diagnóstico estructurado",
      "Plan de 90 días",
      "Excel configurado",
      "Resumen ejecutivo",
    ],
    cta: "Aplicar a esta sesión →",
    href: "/contacto?tipo=advisory",
  },
  {
    title: "Sesión + Seguimiento",
    price: "$497",
    duration: "90 min + 2 check-ins de 30 min",
    includes: [
      "Todo lo de la Sesión de Diagnóstico",
      "2 check-ins de seguimiento",
      "Ajustes en tiempo real",
    ],
    cta: "Aplicar a esta sesión →",
    href: "/contacto?tipo=advisory",
  },
  {
    title: "Sistema Completo",
    price: "Desde $997",
    duration: "Done-For-You",
    includes: [
      "Para founders que quieren que el sistema esté instalado, no solo explicado",
    ],
    cta: "Solicitar información →",
    href: "/contacto?tipo=advisory",
  },
];

const speakingTopics = [
  "Systems thinking aplicado",
  "Transformación institucional",
  "Liderazgo y toma de decisiones bajo presión",
  "Ejecución estratégica",
];
---

<BaseLayout
  title="Trabaja Conmigo · Francisco Abad"
  description="Advisory, consultoría estratégica y productos digitales para founders y organizaciones en LATAM. Construyo desde adentro, codo a codo."
>
  <Navbar />

  <div class="bg-bg-primary min-h-screen">
    {/* Hero */}
    <section class="bg-bg-primary pt-32 pb-12 md:pt-40 md:pb-24">
      <div class="max-w-[760px] mx-auto px-6 lg:px-8">
        <h1 class="font-montserrat font-bold text-text-primary text-[40px] md:text-[56px] leading-tight mb-5">
          Trabajemos juntos.
        </h1>
        <p class="font-inter text-text-secondary text-[17px] leading-relaxed mb-5">
          Tres formas de trabajar conmigo, según lo que necesitas resolver ahora.
        </p>
        <p class="font-inter text-text-secondary text-[16px] leading-relaxed">
          He liderado organizaciones con 32.000 personas y $10 billones en activos. He construido programas en 15 países con presupuesto casi cero. La diferencia entre los dos contextos no fue el recurso: fue el sistema. Si estás construyendo algo y el crecimiento se siente trabado, probablemente el problema no está donde crees. Eso es lo que diagnostico y lo que diseño.
        </p>
      </div>
    </section>

    {/* Speaking hero image */}
    <div class="relative w-full overflow-hidden" style="max-height: 480px;">
      <img
        src="/Speaking/speaking-banner.webp"
        alt="Francisco Abad hablando en Innovaxion 2024"
        width="1600"
        height="900"
        loading="lazy"
        decoding="async"
        style="width: 100%; height: 480px; object-fit: cover; object-position: center 30%; display: block; filter: brightness(0.85) contrast(1.1) saturate(0.9);"
      />
      <div
        class="absolute inset-0"
        style="background: linear-gradient(to bottom, transparent 60%, rgba(20,20,20,0.8) 100%);"
      ></div>
      <p
        class="absolute font-montserrat uppercase m-0"
        style="bottom: 20px; left: 24px; color: #fff; font-size: 12px; letter-spacing: 0.12em;"
      >
        PONENCIA DE APERTURA, INNOVAXION 2024
      </p>
    </div>

    {/* Sección A — Recurso gratuito */}
    <section class="bg-bg-primary py-12 md:py-20 border-t border-border-subtle">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-8">
        <p class="font-montserrat text-[11px] uppercase tracking-[2px] text-ultra-light mb-3">
          Empieza aquí
        </p>
        <h2 class="font-montserrat font-bold text-text-primary text-[32px] md:text-[38px] leading-tight mb-10">
          Herramientas que puedes usar hoy
        </h2>

        <div class="max-w-[560px] bg-bg-elevated border border-ember rounded-lg p-8">
          <span class="inline-block bg-ember text-white font-montserrat text-[10px] uppercase tracking-[1.5px] px-3 py-1 rounded-full mb-4">
            Gratis
          </span>
          <p class="font-montserrat font-bold text-text-primary text-[22px] mb-2">
            Kit IA para tus finanzas
          </p>
          <p class="font-inter text-text-secondary text-[14px] leading-relaxed mb-6">
            Prompts, plantillas y metodología para ordenar tus finanzas personales o de negocio con inteligencia artificial. Workbook Excel, biblioteca de prompts, skills para Claude y checklists de cierre.
          </p>
          <a
            href="/kit"
            class="inline-block font-montserrat font-semibold text-[13px] uppercase tracking-[1.5px] text-white bg-ember px-7 py-3.5 rounded-md hover:opacity-90 transition-opacity duration-300"
          >
            Descarga gratis →
          </a>
        </div>
      </div>
    </section>

    {/* Sección B — Sesiones 1:1 */}
    <section class="bg-bg-elevated py-12 md:py-20 border-t border-border-subtle">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-8">
        <p class="font-montserrat text-[11px] uppercase tracking-[2px] text-ember mb-3">
          Para founders y executives
        </p>
        <h2 class="font-montserrat font-bold text-text-primary text-[32px] md:text-[38px] leading-tight mb-3">
          Trabajemos directamente
        </h2>
        <p class="font-inter text-text-secondary text-[15px] mb-12">
          Aplica primero. Si hay fit, agendamos.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {sessions.map((s) => (
            <div class="bg-bg-primary border border-border-subtle hover:border-ember rounded-lg p-8 flex flex-col transition-colors duration-300">
              <p class="font-montserrat font-bold text-ember text-[28px] mb-1">
                {s.price}
              </p>
              <p class="font-montserrat font-semibold text-text-primary text-[18px] mb-1">
                {s.title}
              </p>
              <p class="font-inter text-text-muted-brand text-[12px] mb-6">
                {s.duration}
              </p>
              <ul class="space-y-2 mb-8 flex-1">
                {s.includes.map((item) => (
                  <li class="font-inter text-text-secondary text-[14px] flex items-start gap-2 leading-snug">
                    <span class="text-ember flex-shrink-0 mt-[2px]">·</span>
                    {item}
                  </li>
                ))}
              </ul>
              <a
                href={s.href}
                class="font-montserrat font-semibold text-[13px] uppercase tracking-[1.5px] text-ultra-light border border-ember px-5 py-3 rounded-md text-center hover:bg-ember hover:text-white transition-all duration-300"
              >
                {s.cta}
              </a>
            </div>
          ))}
        </div>

        <div class="mt-10 pt-10 border-t border-border-subtle max-w-[480px]">
          <p class="font-montserrat font-light italic text-text-secondary text-[15px] leading-relaxed">
            "El trabajo que hacemos juntos no es solo resolver el problema de hoy, es construir la arquitectura para que no vuelva a aparecer."
          </p>
        </div>
      </div>
    </section>

    {/* Sección C — Speaking & Talleres */}
    <section class="bg-bg-primary py-12 md:py-20 border-t border-border-subtle">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
          <div>
            <p class="font-montserrat text-[11px] uppercase tracking-[2px] text-ember mb-3">
              Para empresas y eventos
            </p>
            <h2 class="font-montserrat font-bold text-text-primary text-[32px] md:text-[38px] leading-tight mb-6">
              ¿Quieres que hable en tu evento?
            </h2>
            <p class="font-inter text-text-secondary text-[16px] leading-relaxed mb-8 max-w-[480px]">
              Keynotes y workshops diseñados para equipos directivos, conferencias y programas corporativos. Sesiones construidas desde la experiencia real de haber transformado instituciones y organizaciones.
            </p>
            <a
              href="/contacto?tipo=speaking"
              class="inline-block font-montserrat font-semibold text-[13px] uppercase tracking-[1.5px] text-ultra-light border border-ember px-7 py-3.5 rounded-md hover:bg-ember hover:text-white transition-all duration-300"
            >
              Cotizar una charla →
            </a>
          </div>

          <div>
            <p class="font-montserrat font-semibold text-text-muted-brand text-[11px] uppercase tracking-[2px] mb-6">
              Temas
            </p>
            <div class="space-y-4">
              {speakingTopics.map((topic, i) => (
                <div class="flex items-center gap-5 bg-bg-elevated border border-border-subtle rounded-md px-6 py-4">
                  <span class="font-montserrat font-bold text-ember text-[13px] opacity-50 w-5 flex-shrink-0">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <span class="font-inter text-text-primary text-[15px]">
                    {topic}
                  </span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Bottom CTA */}
    <section class="bg-bg-elevated border-t border-border-subtle py-12 md:py-20">
      <div class="max-w-[760px] mx-auto px-6 lg:px-8 text-center">
        <h3 class="font-montserrat font-bold text-text-primary text-[28px] md:text-[34px] mb-4">
          ¿No sabes por dónde empezar?
        </h3>
        <p class="font-inter text-text-secondary text-[16px] leading-relaxed mb-8">
          Escríbeme y te ayudo a encontrar el formato correcto.
        </p>
        <a
          href="/contacto"
          class="inline-block font-montserrat font-semibold text-[13px] uppercase tracking-[1.5px] text-white bg-ember px-8 py-4 rounded-md hover:opacity-90 transition-opacity duration-300"
        >
          Escríbeme →
        </a>
      </div>
    </section>
  </div>

  <Footer lang="es" />
</BaseLayout>
