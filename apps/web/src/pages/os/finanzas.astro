---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
import { datosFinanzas } from '../../os/data/finanzas';

const { mes, ingresos_total, gastos_total, balance, transacciones, metas } = datosFinanzas;

const fmt = (n: number) =>
  '$' + n.toLocaleString('es-EC', { minimumFractionDigits: 0 });

const ingresos = transacciones.filter((t) => t.tipo === 'ingreso');
const gastos = transacciones.filter((t) => t.tipo === 'gasto');
---

<OSLayout title="Finanzas">
  <div>
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1.75rem;">
      <h1 style="font-size:1.375rem;font-weight:700;color:#F4F6F8;margin:0;">Finanzas</h1>
      <p style="font-size:12px;color:#6B7280;margin:0;">{mes}</p>
    </div>

    <!-- Resumen top -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:1.5rem;">
      {[
        { label: 'Ingresos', valor: ingresos_total, color: '#6B7AE8' },
        { label: 'Gastos', valor: gastos_total, color: '#B5985A' },
        { label: 'Balance', valor: balance, color: '#F4F6F8' },
      ].map(({ label, valor, color }) => (
        <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1.125rem;">
          <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#6B7280;margin:0 0 0.375rem;">{label}</p>
          <p style={`font-family:'Montserrat',sans-serif;font-size:1.5rem;font-weight:700;color:${color === '#F4F6F8' ? '#B5985A' : color};margin:0;`}>{fmt(valor)}</p>
        </div>
      ))}
    </div>

    <!-- Metas -->
    <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1.25rem;margin-bottom:1.25rem;">
      <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#6B7280;margin:0 0 1rem;">Metas del mes</p>
      <div style="display:flex;flex-direction:column;gap:0.875rem;">
        {metas.map((m) => {
          const pct = Math.min(100, Math.round((m.actual / m.meta) * 100));
          return (
            <div>
              <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:5px;">
                <span style="font-size:13px;color:#E8EAF0;">{m.label}</span>
                <span style="font-family:'Montserrat',sans-serif;font-size:12px;font-weight:600;color:#B5985A;">
                  {m.unidad === 'USD' ? fmt(m.actual) : m.actual + m.unidad}
                  <span style="color:#6B7280;font-weight:400;"> / {m.unidad === 'USD' ? fmt(m.meta) : m.meta + m.unidad}</span>
                </span>
              </div>
              <div style="height:4px;background:rgba(232,234,240,0.08);border-radius:2px;overflow:hidden;">
                <div style={`height:100%;width:${pct}%;background:${pct >= 100 ? '#6B7AE8' : '#3B4ED9'};border-radius:2px;transition:width 0.3s;`}></div>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Transacciones -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
      <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1.125rem;">
        <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#6B7AE8;margin:0 0 0.75rem;">Ingresos</p>
        <div style="display:flex;flex-direction:column;gap:6px;">
          {ingresos.map((t) => (
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">
              <span style="font-size:12px;color:#E8EAF0;line-height:1.3;">{t.descripcion}</span>
              <span style="font-family:'Montserrat',sans-serif;font-size:12px;font-weight:600;color:#B5985A;white-space:nowrap;">{fmt(t.monto)}</span>
            </div>
          ))}
        </div>
      </div>
      <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1.125rem;">
        <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#6B7280;margin:0 0 0.75rem;">Gastos</p>
        <div style="display:flex;flex-direction:column;gap:6px;">
          {gastos.map((t) => (
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">
              <div>
                <span style="font-size:12px;color:#E8EAF0;line-height:1.3;">{t.descripcion}</span>
                <span style="font-size:10px;color:#6B7280;display:block;">{t.categoria}</span>
              </div>
              <span style="font-family:'Montserrat',sans-serif;font-size:12px;font-weight:500;color:#6B7280;white-space:nowrap;">{fmt(t.monto)}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</OSLayout>
