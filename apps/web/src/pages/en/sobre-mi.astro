---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { useTranslations } from "../../i18n/utils";

const lang = "en";
const t = useTranslations(lang);

const values = [
  {
    label: "Clarity over complexity",
    desc: "Simple, clear systems always outperform complex ones. If you can't explain it in one sentence, it's not ready.",
  },
  {
    label: "Experience over theory",
    desc: "I build from what I've lived, not from what I've read. Experience leaves marks that theory cannot replicate.",
  },
  {
    label: "Systems over hacks",
    desc: "Hacks solve today's problem. Systems prevent tomorrow's.",
  },
  {
    label: "Candor with warmth",
    desc: "Truth delivered with respect is the most valuable gift you can give someone.",
  },
  {
    label: "Building in public",
    desc: "Building visibly accelerates learning and builds real trust.",
  },
];

const timeline = [
  {
    period: "2026 · Present",
    event: "Founder · Board President",
    detail:
      "Leading BrainTech, an AI-native business transformation firm. Chairing the board of CODEIS/ELAB, a social innovation organization and entrepreneurship school present in more than 15 countries.",
  },
  {
    period: "Jun 2025 · Dec 2025",
    event: "Director General, IESS",
    detail:
      "Top authority at Ecuador's largest public institution: $10 billion in managed funds, 32,000 staff, 13 million beneficiaries. Budget execution: 36% to 78% in six months.",
  },
  {
    period: "2022",
    event: "Young Leaders of the Americas Initiative Fellow",
    detail:
      "Selected by the U.S. Department of State from entrepreneurs across 37 countries in Latin America and the Caribbean. YLAI is the State Department's flagship program for emerging business and social leaders in the Western Hemisphere.",
  },
  {
    period: "2016 · 2025",
    event: "Founder and Executive Director, CODEIS",
    detail:
      "Built a social innovation organization from scratch across more than 15 countries. Over 18,000 entrepreneurs trained. Partnerships with IDB Lab, USAID, GIZ, World Bank. The World Change Makers program won the international Better Together challenge from IDB Lab and was recognized by the United Nations among the 50 best youth projects in the world.",
  },
  {
    period: "Jan 2019 · Apr 2019",
    event: "Global Competitiveness Leadership Program, Georgetown University",
    detail:
      "Full scholarship. Top 10 projects in the program among participants from over 40 countries. Coursework in adaptive leadership, finance, open innovation and executive negotiation.",
  },
  {
    period: "2014 · 2016",
    event: "MPA International Development, London School of Economics",
    detail:
      "Academic merit. Applied econometrics, impact evaluation, public policy and development finance. Founded the Social Innovation Society at LSE.",
  },
  {
    period: "2011",
    event: "One Young World · Delegate Speaker and Ambassador, Zurich",
    detail:
      "First Ecuadorian to represent the country at One Young World, the annual gathering of the world's most outstanding young leaders. The 2011 Zurich Summit brought together delegates from 190 countries under mentors including Desmond Tutu, Bob Geldof and Kofi Annan. The selection process receives over 50,000 applications per year.",
  },
  {
    period: "2012",
    event: "Graduated with Highest Honors, East Texas Baptist University",
    detail:
      "Double major: Political Science and International Studies. Minor in Leadership. GPA 3.87/4.0 Summa Cum Laude with Distinction in Political Science. First Latino to chair the Student Government Association. Top 5 Speakers at the National Debate Tournament. Starting Block Fellow.",
  },
  {
    period: "2007",
    event: "Youth Ambassador, U.S. Department of State Program",
    detail:
      "Selected from secondary school students in Ecuador for the leadership exchange program of the Bureau of Educational and Cultural Affairs, U.S. Department of State. The program selects high-potential young leaders throughout Latin America and the Caribbean.",
  },
];
---

<BaseLayout
  title={t("page.sobre_mi.title")}
  description={t("page.sobre_mi.desc")}
>
  <Navbar />

  <div class="bg-bg-primary min-h-screen">
    <section class="pt-32 pb-16 bg-bg-primary">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
          <img
            src="/francisco-abad-about.jpg"
            alt="Francisco Abad, Founder, Operator, Strategist"
            width="720"
            height="960"
            loading="eager"
            class="w-full max-w-[360px] aspect-[3/4] object-cover rounded-lg shadow-2xl"
          />

          <div class="space-y-8 pt-4">
            <h1 class="font-montserrat font-bold text-text-primary text-[36px] md:text-[44px]">
              My story
            </h1>
            <div class="space-y-4 font-inter text-text-secondary text-[16px] leading-relaxed">
              <p>
                I design and operate systems to make the impossible achievable. In people, in companies, in institutions.
              </p>
              <p>
                I founded{" "}
                <strong class="text-text-primary">CODEIS</strong> over 10 years ago and built it to reach more than{" "}
                <strong class="text-text-primary">18,000 entrepreneurs in more than 15 countries</strong>. I led the{" "}
                <strong class="text-text-primary">IESS</strong>, Ecuador's largest public institution, and raised its operational efficiency from{" "}
                <strong class="text-text-primary">36 to 78 percent in six months</strong>.
              </p>
              <p>
                Today I lead{" "}
                <strong class="text-text-primary">BrainTech</strong>, an AI-native business transformation firm, and chair the board of{" "}
                <strong class="text-text-primary">CODEIS/ELAB</strong>.
              </p>
              <p>
                Building from the inside, side by side, with measurable results.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-12 md:py-16 border-t border-border-subtle bg-bg-primary">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-8">
        <h2 class="font-montserrat font-bold text-text-primary text-[28px] mb-10">
          What I believe
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {values.map((v) => (
            <div class="flex gap-4">
              <div class="mt-1.5 w-1.5 h-1.5 rounded-full bg-ember flex-shrink-0"></div>
              <div>
                <p class="font-montserrat font-semibold text-text-primary text-[15px] mb-1">
                  {v.label}
                </p>
                <p class="font-inter text-text-secondary text-[14px] leading-relaxed">
                  {v.desc}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-12 md:py-20 border-t border-border-subtle bg-bg-primary">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-8">
        <h2 class="font-montserrat font-bold text-text-primary text-[32px] mb-14">
          Timeline
        </h2>
        <div class="relative">
          <div class="absolute left-[7px] top-2 bottom-2 w-px bg-border-subtle hidden md:block"></div>
          <div class="space-y-0 md:space-y-10">
            {timeline.map((item, i) => (
              <div class="relative">
                <details
                  class="md:hidden border-b border-border-subtle group"
                  open={i === 0}
                >
                  <summary class="w-full flex items-center justify-between py-3 text-left list-none cursor-pointer">
                    <div class="pr-4">
                      <span class="font-montserrat font-bold text-[11px] block mb-0.5 timeline-date">
                        {item.period}
                      </span>
                      <span class="font-montserrat font-semibold text-text-primary text-[14px] leading-snug">
                        {item.event}
                      </span>
                    </div>
                    <span class="timeline-date flex-shrink-0 text-[10px] transition-transform duration-200 group-open:rotate-180">
                      ▼
                    </span>
                  </summary>
                  <p class="font-inter text-text-secondary text-[14px] leading-relaxed pb-4 pr-4">
                    {item.detail}
                  </p>
                </details>

                <div class="hidden md:flex gap-8 pl-8">
                  <div class="absolute left-0 top-1.5 w-3.5 h-3.5 rounded-full bg-ember border-2 border-bg-primary"></div>
                  <div class="flex-shrink-0 font-montserrat font-bold text-[13px] w-36 pt-0.5 leading-snug timeline-date">
                    {item.period}
                  </div>
                  <div>
                    <p class="font-montserrat font-semibold text-text-primary text-[16px] mb-1">
                      {item.event}
                    </p>
                    <p class="font-inter text-text-secondary text-[14px] leading-relaxed">
                      {item.detail}
                    </p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </div>

  <Footer lang={lang} />
</BaseLayout>

<style>
  details > summary::-webkit-details-marker {
    display: none;
  }
  details > summary {
    list-style: none;
  }
</style>
