---
// PENDIENTE: Crea cuenta en formspree.io → New Form → copia el endpoint y pégalo aquí.
// Ejemplo: "https://formspree.io/f/xabc1234"
const FORM_ENDPOINT = "https://formspree.io/f/PENDIENTE";

import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Kit gratuito: IA para tus finanzas · Francisco Abad"
  description="Prompts, plantillas y metodología para ordenar tus finanzas personales y de negocio con inteligencia artificial. Acceso anticipado gratuito."
>
  <Navbar />

  <main class="bg-bg-primary min-h-screen">

    {/* Hero */}
    <section class="pt-32 pb-16 px-6">
      <div class="max-w-[680px] mx-auto text-center">
        <p class="font-montserrat text-[11px] uppercase tracking-[2px] text-champagne mb-5">
          Kit gratuito · Lista de acceso anticipado
        </p>
        <h1 class="font-montserrat font-bold text-text-primary text-[34px] md:text-[46px] leading-[1.12] mb-6">
          IA para organizar tus finanzas personales y de negocio
        </h1>
        <p class="font-inter text-text-secondary text-[17px] leading-relaxed max-w-[520px] mx-auto mb-10">
          Prompts probados, plantillas listas y una metodología de 20 minutos semanales para ordenar ingresos, gastos, metas y seguimiento.
        </p>
        <a href="#registro" class="kit-cta">
          Quiero el kit gratuito
        </a>
        <p class="font-inter text-text-muted text-[13px] mt-4">
          Sin spam. Te lo envío en los próximos 3 días.
        </p>
      </div>
    </section>

    {/* Qué incluye */}
    <section class="py-16 border-t border-border-subtle px-6">
      <div class="max-w-[680px] mx-auto">
        <h2 class="font-montserrat font-bold text-text-primary text-[22px] mb-8">
          ¿Qué incluye el kit?
        </h2>
        <ul class="space-y-4">
          {[
            "10 prompts para ordenar ingresos, gastos y metas",
            "Plantilla para separar finanzas personales y del negocio",
            "Prompt para revisar tu presupuesto mensual en 10 minutos",
            "Prompt para detectar desviaciones antes de que se vuelvan problemas",
            "Ritual financiero semanal de 20 minutos con IA",
            "Guía: qué información nunca debes compartir con una IA pública",
          ].map((item) => (
            <li class="flex gap-3 items-start">
              <span class="text-ember flex-shrink-0 mt-0.5">→</span>
              <span class="font-inter text-text-secondary text-[15px] leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
        <div class="mt-8 p-4 rounded-lg border border-border-subtle bg-bg-elevated">
          <p class="font-inter text-text-muted text-[13px] leading-relaxed">
            <strong class="text-champagne">Nota:</strong> Esto es una lista de acceso anticipado. Recibirás el kit completo en los próximos 3 días, una vez que valide las preguntas del formulario para asegurar que el contenido responde a lo que realmente necesitas.
          </p>
        </div>
      </div>
    </section>

    {/* Quién soy */}
    <section class="py-12 border-t border-border-subtle px-6">
      <div class="max-w-[680px] mx-auto">
        <div class="flex gap-5 items-start">
          <img
            src="/francisco-abad.webp"
            alt="Francisco Abad"
            width="64"
            height="64"
            loading="lazy"
            class="rounded-full w-14 h-14 object-cover flex-shrink-0"
          />
          <div>
            <p class="font-montserrat font-semibold text-text-primary text-[15px] mb-1">Francisco Abad</p>
            <p class="font-inter text-text-secondary text-[14px] leading-relaxed">
              Dirigí el IESS, la institución pública más grande del Ecuador, con $10 billones en fondos y 32.000 colaboradores. Fundé CODEIS, con más de 18.000 emprendedores en 15 países. Hoy lidero BrainTech, firma AI-native de transformación de negocios. Construyo desde adentro, codo a codo.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* Formulario */}
    <section id="registro" class="py-20 border-t border-border-subtle px-6">
      <div class="max-w-[560px] mx-auto">
        <h2 class="font-montserrat font-bold text-text-primary text-[26px] mb-2 text-center">
          Regístrate para recibirlo
        </h2>
        <p class="font-inter text-text-secondary text-[14px] text-center mb-10">
          30 segundos. Sin tarjeta. Sin compromisos.
        </p>

        <form
          action={FORM_ENDPOINT}
          method="POST"
          class="space-y-5"
        >
          {/* Redirect a la página de gracias */}
          <input type="hidden" name="_next" value="https://franciscoabad.com/kit/gracias" />
          <input type="hidden" name="_subject" value="Nuevo registro: Kit IA + Finanzas" />

          <div>
            <label for="nombre" class="kit-label">Nombre</label>
            <input
              id="nombre"
              name="nombre"
              type="text"
              required
              placeholder="Tu nombre"
              class="kit-input"
            />
          </div>

          <div>
            <label for="email" class="kit-label">Correo electrónico</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              placeholder="tu@correo.com"
              class="kit-input"
            />
          </div>

          <div>
            <label for="tipo" class="kit-label">¿Qué finanzas quieres ordenar?</label>
            <select id="tipo" name="tipo_finanzas" required class="kit-input">
              <option value="" disabled selected>Selecciona una opción</option>
              <option value="personales">Finanzas personales</option>
              <option value="negocio">Finanzas de mi negocio</option>
              <option value="ambas">Ambas</option>
            </select>
          </div>

          <div>
            <label for="dificultad" class="kit-label">
              ¿Cuál es tu principal dificultad financiera? <span class="text-text-muted font-normal">(opcional)</span>
            </label>
            <textarea
              id="dificultad"
              name="dificultad_principal"
              rows={3}
              placeholder="Ej: no sé cuánto me queda libre al mes, mezclo cuentas personales y del negocio..."
              class="kit-input resize-none"
            ></textarea>
          </div>

          <div class="flex gap-3 items-start pt-1">
            <input
              id="consentimiento"
              name="consentimiento"
              type="checkbox"
              required
              class="mt-1 w-4 h-4 accent-ember flex-shrink-0"
            />
            <label for="consentimiento" class="font-inter text-text-secondary text-[13px] leading-relaxed">
              Acepto recibir el kit y contenidos educativos ocasionales de Francisco Abad. Puedo darme de baja cuando quiera.
            </label>
          </div>

          <button type="submit" class="kit-cta w-full mt-2">
            Quiero el kit gratuito
          </button>
        </form>
      </div>
    </section>

  </main>

  <Footer lang="es" />
</BaseLayout>

<style>
  .kit-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--ultramarine);
    color: #ffffff;
    font-family: var(--font-montserrat, 'Montserrat', sans-serif);
    font-weight: 700;
    font-size: 0.9375rem;
    padding: 0.875rem 2rem;
    border-radius: 0.5rem;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: background-color 0.2s, transform 0.1s;
    letter-spacing: 0.01em;
  }
  .kit-cta:hover {
    background-color: var(--ultra-light);
  }
  .kit-cta:active {
    transform: scale(0.98);
  }

  .kit-label {
    display: block;
    font-family: var(--font-montserrat, 'Montserrat', sans-serif);
    font-weight: 600;
    font-size: 0.8125rem;
    color: var(--text-primary);
    margin-bottom: 0.375rem;
    letter-spacing: 0.01em;
  }

  .kit-input {
    width: 100%;
    background-color: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: 0.375rem;
    padding: 0.6875rem 0.875rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    color: var(--text-primary);
    transition: border-color 0.15s;
    outline: none;
    appearance: none;
  }
  .kit-input::placeholder {
    color: var(--text-muted);
  }
  .kit-input:focus {
    border-color: var(--ultramarine);
    box-shadow: 0 0 0 3px oklch(from var(--ultramarine) l c h / 0.18);
  }
</style>
