---
export const prerender = false;

import OSLayout from '../../layouts/OSLayout.astro';
import OSOnboarding from '../../os/components/OSOnboarding';
import OSHoy from '../../os/components/OSHoy';

const fechaLarga = new Date().toLocaleDateString('es-EC', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
});
---

<OSLayout title="Hoy">
  <OSOnboarding client:load />
  <div class="os-fade-up">

    <!-- Header -->
    <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.5rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Cockpit</p>
        <h1 class="os-h1">Hoy</h1>
      </div>
      <span style="font-size:12px;color:var(--os-muted);text-transform:capitalize;">{fechaLarga}</span>
    </div>

    <!-- Hoy: domino, priority stack, wins, checklist, discomfort, principios, semana, norte -->
    <!-- (el KPI strip estatico se elimino: mostraba cifras inventadas de os/data/kpis.ts;
         los KPIs reales viven en /os/kpis con datos de Supabase) -->
    <OSHoy client:load />

    <!-- Salud -->
    <a href="/os/salud" class="os-card os-card-interactive" style="display:flex;align-items:center;gap:14px;margin-bottom:1rem;text-decoration:none;">
      <span class="material-symbols-outlined" style="font-size:26px;color:var(--os-accent-light);flex-shrink:0;">favorite</span>
      <div style="flex:1;min-width:0;">
        <p style="font-size:14px;font-weight:700;color:var(--os-text);margin:0;">Salud</p>
        <p style="font-size:12px;color:var(--os-muted);margin:2px 0 0;">Nutrición, ayuno, entrenamiento, cuerpo y estiramiento</p>
      </div>
      <span class="material-symbols-outlined" style="font-size:20px;color:var(--os-muted);">chevron_right</span>
    </a>

    <!-- Brain feed: notas REALES del brain (gbrain) via /api/brain/notes.
         Antes renderizaba mocks estaticos de os/data/cerebro.ts. -->
    <div class="os-card">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.875rem;">
        <p class="os-section-title" style="margin:0;">Cerebro · ultimas notas</p>
        <a href="/os/cerebro" style="font-size:11px;color:var(--os-accent-light);text-decoration:none;font-family:var(--os-font-display);letter-spacing:0.06em;">ver todo</a>
      </div>
      <div id="brain-feed" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:8px;">
        <p style="font-size:12px;color:var(--os-muted);margin:0;">Cargando notas del cerebro...</p>
      </div>
    </div>

  </div>

  <script is:inline>
    (function () {
      var cont = document.getElementById('brain-feed');
      if (!cont) return;
      function esc(s) {
        return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      }
      fetch('/api/brain/notes?limit=4')
        .then(function (r) { return r.json(); })
        .then(function (d) {
          var notas = (d && d.notes) || [];
          if (!notas.length) {
            cont.innerHTML = '<p style="font-size:12px;color:var(--os-muted);margin:0;">Sin notas todavia. Lo que guardes en el brain aparece aqui.</p>';
            return;
          }
          cont.innerHTML = notas.map(function (n) {
            return '<a href="/os/cerebro" style="display:block;padding:0.875rem;border-radius:8px;background:var(--os-fill-subtle);border:1px solid var(--os-line-soft);text-decoration:none;">'
              + '<p style="font-size:12px;font-weight:600;color:var(--os-text);margin:0 0 0.375rem;line-height:1.3;">' + esc(n.titulo) + '</p>'
              + '<p style="font-size:11px;color:var(--os-muted);margin:0;line-height:1.4;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">' + esc(n.excerpt || n.resumen || '') + '</p>'
              + '</a>';
          }).join('');
        })
        .catch(function () {
          cont.innerHTML = '<p style="font-size:12px;color:var(--os-muted);margin:0;">No se pudo cargar el cerebro. <a href="/os/cerebro" style="color:var(--os-accent-light);">Abrir modulo</a></p>';
        });
    })();
  </script>

  <style is:global>
    @media (max-width: 820px) {
      .os-2col { grid-template-columns: 1fr !important; }
    }
  </style>
</OSLayout>
