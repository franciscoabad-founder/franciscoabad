---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
---

<OSLayout title="Finanzas">
  <div class="os-fade-up">

    <!-- Header -->
    <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.5rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Money</p>
        <h1 class="os-h1">Finanzas</h1>
        <p style="font-size:var(--os-text-sm);color:var(--os-muted);margin:4px 0 0;">Linea base manual de cuentas, deudas y gastos</p>
      </div>
    </div>

    <!-- Error inline (reemplaza alert de error en patch/del) -->
    <div id="fin-error" role="alert" style="display:none;align-items:center;gap:8px;background:var(--os-fill-subtle);border:1px solid var(--os-error);border-radius:var(--os-r-sm);padding:0.6rem 0.875rem;margin-bottom:1rem;font-size:var(--os-text-sm);color:var(--os-error);">
      <span class="material-symbols-outlined" style="font-size:18px;">error</span>
      <span id="fin-error-text" style="flex:1;"></span>
      <button type="button" onclick="hideFinError()" aria-label="Cerrar" style="background:none;border:none;color:var(--os-error);cursor:pointer;padding:0;min-width:var(--os-tap-min);min-height:var(--os-tap-min);display:inline-flex;align-items:center;justify-content:center;" class="material-symbols-outlined">close</button>
    </div>

    <!-- Hero: Neto -->
    <div class="os-domino" style="margin-bottom:1.25rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
      <div style="display:flex;align-items:center;gap:0.875rem;">
        <span class="material-symbols-outlined" style="font-size:30px;color:var(--os-accent-light);">account_balance_wallet</span>
        <div>
          <p class="os-eyebrow" style="margin-bottom:4px;">Patrimonio neto</p>
          <p style="font-size:12px;color:var(--os-muted);margin:0;">Cuentas menos deudas activas</p>
        </div>
      </div>
      <span id="sum-neto" class="os-mono" style="font-size:2.25rem;font-weight:700;color:var(--os-champagne);line-height:1;white-space:nowrap;">—</span>
    </div>

    <!-- Resumen KPIs -->
    <div class="os-finance-summary" style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:1.75rem;">
      <div class="os-kpi">
        <p class="os-kpi-label">Total en cuentas</p>
        <p id="sum-cuentas" class="os-kpi-value">—</p>
      </div>
      <div class="os-kpi">
        <p class="os-kpi-label">Total deudas</p>
        <p id="sum-deudas" class="os-kpi-value">—</p>
      </div>
      <div class="os-kpi">
        <p class="os-kpi-label">Por cobrar</p>
        <p id="sum-porcobrar" class="os-kpi-value">—</p>
      </div>
      <div class="os-kpi" style="border-color:var(--os-line-accent);">
        <p class="os-kpi-label" style="color:var(--os-accent-light);">Neto</p>
        <p class="os-kpi-value" id="sum-neto-mirror" aria-hidden="true">—</p>
      </div>
    </div>

    <!-- ============ CUENTAS ============ -->
    <section style="margin-bottom:2rem;">
      <p class="os-section-title">Cuentas — mi linea base</p>
      <form id="cuenta-form" class="os-form">
        <input name="nombre" type="text" placeholder="Nombre (ej. Tampico) *" required class="os-input" style="flex:2;min-width:160px;" />
        <input name="tipo" type="text" placeholder="Tipo (banco, efectivo...)" class="os-input" style="flex:1;min-width:120px;" />
        <input name="saldo" type="number" step="any" placeholder="Saldo" class="os-input os-mono" style="width:110px;" />
        <input name="moneda" type="text" placeholder="MXN" maxlength="6" class="os-input" style="width:70px;" />
        <button type="submit" class="os-btn"><span class="material-symbols-outlined" style="font-size:16px;">add</span>Cuenta</button>
        <p id="cuenta-form-msg" style="font-size:var(--os-text-xs);color:var(--os-error);width:100%;margin:0;display:none;"></p>
      </form>
      <div id="cuentas-list" style="display:flex;flex-direction:column;gap:6px;"></div>
    </section>

    <!-- ============ DEUDAS ============ -->
    <section style="margin-bottom:2rem;">
      <p class="os-section-title">Deudas</p>
      <form id="deuda-form" class="os-form">
        <input name="acreedor" type="text" placeholder="Acreedor *" required class="os-input" style="flex:2;min-width:150px;" />
        <input name="monto" type="number" step="any" placeholder="Monto" class="os-input os-mono" style="width:110px;" />
        <input name="cuota" type="number" step="any" placeholder="Cuota" class="os-input os-mono" style="width:100px;" />
        <input name="fecha_limite" type="date" class="os-input os-date" />
        <button type="submit" class="os-btn"><span class="material-symbols-outlined" style="font-size:16px;">add</span>Deuda</button>
        <p id="deuda-form-msg" style="font-size:var(--os-text-xs);color:var(--os-error);width:100%;margin:0;display:none;"></p>
      </form>
      <div id="deudas-list" style="display:flex;flex-direction:column;gap:6px;"></div>
    </section>

    <!-- ============ POR COBRAR ============ -->
    <section style="margin-bottom:2rem;">
      <p class="os-section-title">Por cobrar — dinero por entrar</p>
      <form id="porcobrar-form" class="os-form">
        <input name="cliente" type="text" placeholder="Cliente *" required class="os-input" style="flex:2;min-width:150px;" />
        <input name="proyecto" type="text" placeholder="Proyecto" class="os-input" style="flex:1;min-width:120px;" />
        <input name="monto" type="number" step="any" placeholder="Monto" class="os-input os-mono" style="width:110px;" />
        <input name="moneda" type="text" placeholder="USD" maxlength="6" class="os-input" style="width:70px;" />
        <select name="estado" class="os-input os-date">
          <option value="aplicando">Aplicando</option>
          <option value="esperando">Esperando respuesta</option>
          <option value="aprobado_sin_pagar">Aprobado sin pagar</option>
          <option value="cobrado">Cobrado</option>
        </select>
        <input name="fecha_esperada" type="date" class="os-input os-date" />
        <button type="submit" class="os-btn"><span class="material-symbols-outlined" style="font-size:16px;">add</span>Por cobrar</button>
        <p id="porcobrar-form-msg" style="font-size:var(--os-text-xs);color:var(--os-error);width:100%;margin:0;display:none;"></p>
      </form>
      <!-- Filtros por estado -->
      <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:0.75rem;align-items:center;">
        <div style="display:flex;gap:5px;align-items:center;flex-wrap:wrap;">
          <span class="material-symbols-outlined" style="font-size:16px;color:var(--os-muted);">filter_list</span>
          <button data-fpc="todos" onclick="setPCFilter('todos')" class="os-chip os-chip-on">Todos</button>
          <button data-fpc="aplicando" onclick="setPCFilter('aplicando')" class="os-chip">Aplicando</button>
          <button data-fpc="esperando" onclick="setPCFilter('esperando')" class="os-chip">Esperando</button>
          <button data-fpc="aprobado_sin_pagar" onclick="setPCFilter('aprobado_sin_pagar')" class="os-chip">Aprobado sin pagar</button>
          <button data-fpc="cobrado" onclick="setPCFilter('cobrado')" class="os-chip">Cobrado</button>
        </div>
        <span id="porcobrar-total" class="os-mono" style="font-size:12px;color:var(--os-champagne);font-weight:700;margin-left:auto;"></span>
      </div>
      <div id="porcobrar-list" class="os-card" style="padding:0.25rem 1rem;"></div>
    </section>

    <!-- ============ GASTOS ============ -->
    <section style="margin-bottom:2rem;">
      <p class="os-section-title">Gastos</p>
      <form id="gasto-form" class="os-form">
        <input name="fecha" type="date" class="os-input os-date" />
        <input name="categoria" type="text" placeholder="Categoria" class="os-input" style="flex:1;min-width:120px;" />
        <input name="descripcion" type="text" placeholder="Descripcion" class="os-input" style="flex:2;min-width:160px;" />
        <input name="monto" type="number" step="any" placeholder="Monto" class="os-input os-mono" style="width:110px;" />
        <button type="submit" class="os-btn"><span class="material-symbols-outlined" style="font-size:16px;">add</span>Gasto</button>
        <p id="gasto-form-msg" style="font-size:var(--os-text-xs);color:var(--os-error);width:100%;margin:0;display:none;"></p>
      </form>
      <!-- Filtros -->
      <div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:0.75rem;align-items:center;">
        <div style="display:flex;gap:5px;align-items:center;">
          <span class="os-kpi-label" style="margin:0;">Mes</span>
          <input id="filtro-mes" type="month" class="os-input os-date" />
          <button id="filtro-mes-clear" type="button" class="os-chip">Todos</button>
        </div>
        <div style="display:flex;gap:5px;align-items:center;flex:1;min-width:140px;">
          <span class="os-kpi-label" style="margin:0;">Categoria</span>
          <select id="filtro-cat" class="os-input os-date" style="flex:1;">
            <option value="">Todas</option>
          </select>
        </div>
        <span id="gastos-total" class="os-mono" style="font-size:12px;color:var(--os-champagne);font-weight:700;margin-left:auto;"></span>
      </div>
      <div id="gastos-list" style="display:flex;flex-direction:column;gap:6px;"></div>
    </section>

    <!-- ============ PRESUPUESTOS ============ -->
    <section style="margin-bottom:2rem;">
      <p class="os-section-title">Presupuestos — limite mensual por categoria</p>
      <form id="presupuesto-form" class="os-form">
        <input name="categoria" type="text" placeholder="Categoria *" required class="os-input" style="flex:2;min-width:160px;" />
        <input name="limite_mensual" type="number" step="any" placeholder="Limite mensual" class="os-input os-mono" style="width:140px;" />
        <button type="submit" class="os-btn"><span class="material-symbols-outlined" style="font-size:16px;">add</span>Presupuesto</button>
        <p id="presupuesto-form-msg" style="font-size:var(--os-text-xs);color:var(--os-error);width:100%;margin:0;display:none;"></p>
      </form>
      <div id="presupuestos-list" style="display:flex;flex-direction:column;gap:8px;"></div>
    </section>
  </div>

  <style>
    .os-form {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: flex-end;
      margin-bottom: 0.875rem;
      background: var(--os-surface-2);
      border: 1px solid var(--os-line-soft);
      border-radius: var(--os-r-card);
      padding: 0.875rem 1rem;
    }
    .os-form .os-input { font-size: var(--os-text-sm); padding: 0.45rem 0.65rem; }
    .os-date { color-scheme: light dark; }
    select.os-input { cursor: pointer; }
    .os-chip {
      min-height: var(--os-tap-min);
      padding: 4px 11px;
      font-family: var(--os-font-display);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.02em;
      border-radius: var(--os-r-sm);
      border: 1px solid var(--os-line);
      background: transparent;
      color: var(--os-muted);
      cursor: pointer;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    .os-chip:hover { color: var(--os-text-2); border-color: var(--os-line-accent); }
    .os-chip-on {
      background: rgba(59, 78, 217, 0.20);
      color: var(--os-text);
      border-color: rgba(59, 78, 217, 0.5);
    }
    @media (pointer: coarse) {
      .os-chip { min-height: var(--os-tap-coarse); }
    }
    @media (max-width: 820px) {
      .os-finance-summary { grid-template-columns: 1fr 1fr !important; }
      .os-form { gap: 7px; }
      .os-form .os-input { flex: 1 1 auto !important; min-width: 0 !important; }
      .os-form .os-input[style*="width:70px"],
      .os-form .os-input[style*="width:100px"],
      .os-form .os-input[style*="width:110px"],
      .os-form .os-input[style*="width:140px"] { width: auto !important; }
      .os-form .os-btn { flex: 1 1 100%; justify-content: center; }
    }
  </style>
</OSLayout>

<script is:inline>
var cuentas = [], deudas = [], gastos = [], presupuestos = [], porCobrar = [];
var pcFilter = 'todos';
var PC_LABEL = { aplicando:'Aplicando', esperando:'Esperando', aprobado_sin_pagar:'Aprobado sin pagar', cobrado:'Cobrado' };
var PC_COLOR = { aplicando:'var(--os-muted)', esperando:'var(--os-accent-light)', aprobado_sin_pagar:'var(--os-warn)', cobrado:'var(--os-champagne)' };

// Error inline no intrusivo (reemplaza los alert() de patch/del)
function showFinError(msg) {
  var box = document.getElementById('fin-error');
  var txt = document.getElementById('fin-error-text');
  if (!box || !txt) return;
  txt.textContent = msg;
  box.style.display = 'flex';
}
function hideFinError() {
  var box = document.getElementById('fin-error');
  if (box) box.style.display = 'none';
}

function esc(s) {
  return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function money(n, moneda) {
  var v = Number(n) || 0;
  return v.toLocaleString('es-MX', { minimumFractionDigits: 0, maximumFractionDigits: 2 }) + (moneda ? ' ' + moneda : '');
}
function thisMonth() { return new Date().toISOString().slice(0, 7); }
function dlDisplay(dl) {
  if (!dl) return '';
  var today = new Date().toISOString().slice(0,10);
  var color = dl < today ? 'var(--os-error)' : 'var(--os-muted)';
  var label = new Date(dl + 'T12:00:00').toLocaleDateString('es',{day:'numeric',month:'short',year:'numeric'});
  return '<span style="font-size:11px;color:' + color + ';">' + esc(label) + '</span>';
}
function delBtn(fn, id) {
  return '<button onclick="' + fn + '(\'' + id + '\')" title="Eliminar" style="background:none;border:none;color:var(--os-muted);cursor:pointer;font-size:18px;padding:0;line-height:1;flex-shrink:0;display:inline-flex;align-items:center;justify-content:center;min-width:var(--os-tap-min);min-height:var(--os-tap-min);" class="material-symbols-outlined">close</button>';
}
function iconChip(name, color) {
  return '<span style="width:34px;height:34px;flex-shrink:0;border-radius:999px;display:inline-flex;align-items:center;justify-content:center;background:rgba(59,78,217,0.14);color:' + (color || 'var(--os-accent-light)') + ';" class="material-symbols-outlined">' + name + '</span>';
}

// ---- Resumen ----
function renderResumen() {
  var totCuentas = cuentas.reduce(function(s,c){ return s + (Number(c.saldo)||0); }, 0);
  var totDeudas = deudas.reduce(function(s,d){ return d.estado === 'pagada' ? s : s + (Number(d.monto)||0); }, 0);
  var moneda = cuentas[0] ? cuentas[0].moneda : 'MXN';
  document.getElementById('sum-cuentas').textContent = money(totCuentas, moneda);
  document.getElementById('sum-deudas').textContent = money(totDeudas, moneda);
  document.getElementById('sum-neto').textContent = money(totCuentas - totDeudas, moneda);
  var netoMirror = document.getElementById('sum-neto-mirror');
  if (netoMirror) netoMirror.textContent = money(totCuentas - totDeudas, moneda);

  var noCobrado = porCobrar.filter(function(p){ return p.estado !== 'cobrado'; });
  var totPC = noCobrado.reduce(function(s,p){ return s + (Number(p.monto)||0); }, 0);
  var monedaPC = noCobrado[0] ? noCobrado[0].moneda : (porCobrar[0] ? porCobrar[0].moneda : 'USD');
  document.getElementById('sum-porcobrar').textContent = money(totPC, monedaPC);
}

// ---- CUENTAS ----
function renderCuentas() {
  var list = document.getElementById('cuentas-list');
  if (!cuentas.length) { list.innerHTML = '<div style="color:var(--os-muted);font-size:var(--os-text-sm);padding:0.5rem 0;">Sin cuentas aun.</div>'; return; }
  list.innerHTML = cuentas.map(function(c) {
    return '<div style="display:flex;align-items:center;gap:12px;background:var(--os-glass-bg);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border:1px solid var(--os-line);border-radius:12px;padding:0.6rem 0.875rem;">'
      + iconChip('savings', 'var(--os-accent-light)')
      + '<p style="font-size:13px;color:var(--os-text);margin:0;flex:1;min-width:0;">' + esc(c.nombre) + (c.tipo ? ' <span style="color:var(--os-muted);font-size:11px;">· ' + esc(c.tipo) + '</span>' : '') + '</p>'
      + '<button onclick="editSaldo(\'' + c.id + '\',' + (Number(c.saldo)||0) + ')" style="font-size:var(--os-text-sm);min-height:var(--os-tap-min);color:var(--os-champagne);font-family:var(--os-font-mono);font-weight:700;background:none;border:none;cursor:pointer;">' + esc(money(c.saldo, c.moneda)) + '</button>'
      + delBtn('delCuenta', c.id)
      + '</div>';
  }).join('');
}
// NOTA fase 2a: los prompt()/confirm() de edicion y borrado se mantienen a proposito
// (reemplazarlos implica rehacer el flujo de edicion). Quedan: editSaldo (prompt),
// editLimite (prompt) y delCuenta/delDeuda/delPorCobrar/delGasto/delPresupuesto (confirm).
async function editSaldo(id, current) {
  var val = prompt('Nuevo saldo:', current);
  if (val === null) return;
  await patch('cuentas', id, { saldo: Number(val) || 0 });
}
async function delCuenta(id) {
  if (!confirm('Eliminar esta cuenta?')) return;
  await del('cuentas', id);
}

// ---- DEUDAS ----
function renderDeudas() {
  var list = document.getElementById('deudas-list');
  if (!deudas.length) { list.innerHTML = '<div style="color:var(--os-muted);font-size:var(--os-text-sm);padding:0.5rem 0;">Sin deudas registradas.</div>'; return; }
  list.innerHTML = deudas.map(function(d) {
    var pagada = d.estado === 'pagada';
    return '<div style="display:flex;align-items:center;gap:12px;background:var(--os-glass-bg);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border:1px solid var(--os-line);border-radius:12px;padding:0.6rem 0.875rem;opacity:' + (pagada ? '0.55' : '1') + ';">'
      + iconChip(pagada ? 'check_circle' : 'south_west', pagada ? 'var(--os-champagne)' : 'var(--os-warn)')
      + '<p style="font-size:13px;color:var(--os-text);margin:0;flex:1;min-width:0;text-decoration:' + (pagada ? 'line-through' : 'none') + ';">' + esc(d.acreedor) + '</p>'
      + (d.cuota ? '<span style="font-size:11px;color:var(--os-muted);">cuota ' + esc(money(d.cuota)) + '</span>' : '')
      + (d.fecha_limite ? dlDisplay(d.fecha_limite) : '')
      + '<span style="font-size:13px;color:var(--os-champagne);font-family:var(--os-font-mono);font-weight:700;">' + esc(money(d.monto)) + '</span>'
      + '<button onclick="toggleDeuda(\'' + d.id + '\',\'' + esc(d.estado) + '\')" title="Marcar pagada/activa" style="font-size:11px;min-height:var(--os-tap-min);color:' + (pagada ? 'var(--os-champagne)' : 'var(--os-muted)') + ';background:none;border:1px solid var(--os-line);border-radius:6px;padding:2px 8px;cursor:pointer;font-family:var(--os-font-display);font-weight:600;white-space:nowrap;">' + (pagada ? 'pagada' : 'activa') + '</button>'
      + delBtn('delDeuda', d.id)
      + '</div>';
  }).join('');
}
async function toggleDeuda(id, estado) {
  await patch('deudas', id, { estado: estado === 'pagada' ? 'activa' : 'pagada' });
}
async function delDeuda(id) {
  if (!confirm('Eliminar esta deuda?')) return;
  await del('deudas', id);
}

// ---- POR COBRAR ----
function setPCFilter(val) {
  pcFilter = val;
  document.querySelectorAll('[data-fpc]').forEach(function(b) {
    var active = b.getAttribute('data-fpc') === val;
    if (active) b.classList.add('os-chip-on'); else b.classList.remove('os-chip-on');
  });
  renderPorCobrar();
}
function renderPorCobrar() {
  var list = document.getElementById('porcobrar-list');
  var rows = porCobrar.filter(function(p){ return pcFilter === 'todos' || p.estado === pcFilter; });
  // Total por entrar: SIN contar lo ya cobrado, respetando el filtro de estado.
  var noCobrado = rows.filter(function(p){ return p.estado !== 'cobrado'; });
  var totalPorEntrar = noCobrado.reduce(function(s,p){ return s + (Number(p.monto)||0); }, 0);
  var monedaT = noCobrado[0] ? noCobrado[0].moneda : 'USD';
  var totalEl = document.getElementById('porcobrar-total');
  if (totalEl) totalEl.textContent = noCobrado.length ? ('Por entrar: ' + money(totalPorEntrar, monedaT)) : '';
  if (!rows.length) { list.innerHTML = '<div style="color:var(--os-muted);font-size:var(--os-text-sm);padding:0.75rem 0;">Sin registros con este filtro.</div>'; return; }
  list.innerHTML = rows.map(function(p, idx) {
    var color = PC_COLOR[p.estado] || 'var(--os-muted)';
    var cobrado = p.estado === 'cobrado';
    var border = idx < rows.length - 1 ? 'border-bottom:1px solid var(--os-line-soft);' : '';
    var opts = Object.keys(PC_LABEL).map(function(e) {
      return '<option value="' + e + '"' + (p.estado === e ? ' selected' : '') + '>' + PC_LABEL[e] + '</option>';
    }).join('');
    return '<div style="display:flex;align-items:center;gap:12px;padding:0.7rem 0;' + border + 'opacity:' + (cobrado ? '0.6' : '1') + ';">'
      + '<span style="width:8px;height:8px;border-radius:999px;flex-shrink:0;background:' + color + ';"></span>'
      + '<div style="flex:1;min-width:0;">'
        + '<p style="font-size:13px;color:var(--os-text);margin:0;line-height:1.35;">' + esc(p.cliente) + (p.proyecto ? ' <span style="color:var(--os-muted);font-size:11px;">· ' + esc(p.proyecto) + '</span>' : '') + '</p>'
        + (p.fecha_esperada ? '<p style="font-size:11px;color:var(--os-muted);margin:2px 0 0;">Esperada: ' + esc(new Date(p.fecha_esperada + 'T12:00:00').toLocaleDateString('es',{day:'numeric',month:'short',year:'numeric'})) + '</p>' : '')
      + '</div>'
      + '<span style="font-size:14px;color:var(--os-champagne);font-family:var(--os-font-mono);font-weight:700;white-space:nowrap;">' + esc(money(p.monto, p.moneda)) + '</span>'
      + '<select onchange="patchPCEstado(\'' + p.id + '\',this.value)" style="background:var(--os-surface);border:1px solid var(--os-line);border-radius:6px;padding:3px 7px;min-height:var(--os-tap-min);font-size:11px;font-family:var(--os-font-display);font-weight:600;color:' + color + ';cursor:pointer;outline:none;">' + opts + '</select>'
      + delBtn('delPorCobrar', p.id)
      + '</div>';
  }).join('');
}
async function patchPCEstado(id, estado) {
  await patch('por-cobrar', id, { estado: estado });
}
async function delPorCobrar(id) {
  if (!confirm('Eliminar este registro?')) return;
  await del('por-cobrar', id);
}

// ---- GASTOS ----
function rebuildCatFilter() {
  var sel = document.getElementById('filtro-cat');
  var cur = sel.value;
  var cats = {};
  gastos.forEach(function(g){ if (g.categoria) cats[g.categoria] = true; });
  sel.innerHTML = '<option value="">Todas</option>' + Object.keys(cats).sort().map(function(c){
    return '<option value="' + esc(c) + '">' + esc(c) + '</option>';
  }).join('');
  sel.value = cur;
}
function filteredGastos() {
  var mes = document.getElementById('filtro-mes').value;
  var cat = document.getElementById('filtro-cat').value;
  return gastos.filter(function(g) {
    if (mes && (g.fecha || '').slice(0,7) !== mes) return false;
    if (cat && g.categoria !== cat) return false;
    return true;
  });
}
function renderGastos() {
  rebuildCatFilter();
  var list = document.getElementById('gastos-list');
  var rows = filteredGastos();
  var total = rows.reduce(function(s,g){ return s + (Number(g.monto)||0); }, 0);
  document.getElementById('gastos-total').textContent = rows.length ? (rows.length + ' gastos · ' + money(total)) : '';
  if (!rows.length) { list.innerHTML = '<div style="color:var(--os-muted);font-size:var(--os-text-sm);padding:0.5rem 0;">Sin gastos con estos filtros.</div>'; return; }
  list.innerHTML = rows.map(function(g) {
    var fecha = g.fecha ? new Date(g.fecha + 'T12:00:00').toLocaleDateString('es',{day:'numeric',month:'short'}) : '';
    return '<div style="display:flex;align-items:center;gap:12px;background:var(--os-glass-bg);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border:1px solid var(--os-line);border-radius:12px;padding:0.55rem 0.875rem;">'
      + iconChip('payments', 'var(--os-accent-light)')
      + '<div style="flex:1;min-width:0;">'
        + '<p style="font-size:13px;color:var(--os-text);margin:0;line-height:1.3;">' + esc(g.descripcion || '') + '</p>'
        + '<div style="display:flex;align-items:center;gap:7px;margin-top:2px;">'
          + '<span style="font-size:11px;color:var(--os-muted);">' + esc(fecha) + '</span>'
          + (g.categoria ? '<span style="font-size:11px;color:var(--os-accent-light);background:rgba(107,122,232,0.12);padding:1px 7px;border-radius:4px;">' + esc(g.categoria) + '</span>' : '')
        + '</div>'
      + '</div>'
      + '<span style="font-size:13px;color:var(--os-text);font-family:var(--os-font-mono);font-weight:700;white-space:nowrap;">-' + esc(money(g.monto)) + '</span>'
      + delBtn('delGasto', g.id)
      + '</div>';
  }).join('');
}
async function delGasto(id) {
  if (!confirm('Eliminar este gasto?')) return;
  await del('gastos', id);
}

// ---- PRESUPUESTOS ----
function gastadoEsteMes(categoria) {
  var mes = thisMonth();
  return gastos.reduce(function(s,g) {
    if (g.categoria === categoria && (g.fecha || '').slice(0,7) === mes) return s + (Number(g.monto)||0);
    return s;
  }, 0);
}
function renderPresupuestos() {
  var list = document.getElementById('presupuestos-list');
  if (!presupuestos.length) { list.innerHTML = '<div style="color:var(--os-muted);font-size:var(--os-text-sm);padding:0.5rem 0;">Sin presupuestos definidos.</div>'; return; }
  list.innerHTML = presupuestos.map(function(p) {
    var limite = Number(p.limite_mensual) || 0;
    var usado = gastadoEsteMes(p.categoria);
    var pct = limite > 0 ? Math.min(100, (usado / limite) * 100) : 0;
    var over = limite > 0 && usado > limite;
    var barColor = over ? 'var(--os-error)' : (pct > 80 ? 'var(--os-warn)' : 'var(--os-accent)');
    return '<div style="background:var(--os-surface);border:1px solid var(--os-line);border-radius:12px;padding:0.8rem 1rem;">'
      + '<div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">'
        + '<p style="font-size:13px;color:var(--os-text);margin:0;flex:1;font-weight:500;">' + esc(p.categoria) + '</p>'
        + '<span style="font-size:12px;color:' + (over ? 'var(--os-error)' : 'var(--os-champagne)') + ';font-family:var(--os-font-mono);font-weight:700;">' + esc(money(usado)) + ' / ' + esc(money(limite)) + '</span>'
        + '<button onclick="editLimite(\'' + p.id + '\',' + limite + ')" style="font-size:11px;min-height:var(--os-tap-min);color:var(--os-muted);background:none;border:1px solid var(--os-line);border-radius:6px;padding:2px 8px;cursor:pointer;font-family:var(--os-font-display);font-weight:600;">editar</button>'
        + delBtn('delPresupuesto', p.id)
      + '</div>'
      + '<div style="height:6px;background:var(--os-surface-hi);border-radius:99px;overflow:hidden;">'
        + '<div style="height:100%;width:' + pct + '%;background:' + barColor + ';border-radius:99px;transition:width .3s;"></div>'
      + '</div>'
      + (over ? '<p style="font-size:11px;color:var(--os-error);margin:6px 0 0;">Excedido por ' + esc(money(usado - limite)) + ' este mes</p>' : '')
      + '</div>';
  }).join('');
}
async function editLimite(id, current) {
  var val = prompt('Nuevo limite mensual:', current);
  if (val === null) return;
  await patch('presupuestos', id, { limite_mensual: Number(val) || 0 });
}
async function delPresupuesto(id) {
  if (!confirm('Eliminar este presupuesto?')) return;
  await del('presupuestos', id);
}

// ---- shared API helpers ----
async function patch(tabla, id, body) {
  try {
    var res = await fetch('/api/os/' + tabla + '?id=' + encodeURIComponent(id), {
      method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
    });
    if (!res.ok) throw new Error(String(res.status));
    hideFinError();
    await loadAll();
  } catch(e) { showFinError('Error al guardar: ' + e.message); }
}
async function del(tabla, id) {
  try {
    var res = await fetch('/api/os/' + tabla + '?id=' + encodeURIComponent(id), { method: 'DELETE' });
    if (!res.ok) throw new Error(String(res.status));
    hideFinError();
    await loadAll();
  } catch(e) { showFinError('Error al eliminar: ' + e.message); }
}

function wireForm(formId, tabla, msgId) {
  var form = document.getElementById(formId);
  if (!form) return;
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    var msg = document.getElementById(msgId);
    if (msg) msg.style.display = 'none';
    var fd = new FormData(form);
    var body = {};
    fd.forEach(function(v, k){ body[k] = v; });
    try {
      var res = await fetch('/api/os/' + tabla, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
      });
      var jsonR = await res.json();
      if (!res.ok) throw new Error(jsonR.error || String(res.status));
      form.reset();
      await loadAll();
    } catch(err) {
      if (msg) { msg.textContent = 'Error: ' + err.message; msg.style.display = 'block'; }
    }
  });
}

async function loadAll() {
  try {
    var results = await Promise.all([
      fetch('/api/os/cuentas').then(function(r){ return r.json(); }),
      fetch('/api/os/deudas').then(function(r){ return r.json(); }),
      fetch('/api/os/gastos').then(function(r){ return r.json(); }),
      fetch('/api/os/presupuestos').then(function(r){ return r.json(); }),
      fetch('/api/os/por-cobrar').then(function(r){ return r.json(); }),
    ]);
    cuentas = results[0].cuentas || [];
    deudas = results[1].deudas || [];
    gastos = results[2].gastos || [];
    presupuestos = results[3].presupuestos || [];
    porCobrar = results[4].por_cobrar || [];
    renderResumen();
    renderCuentas();
    renderDeudas();
    renderPorCobrar();
    renderGastos();
    renderPresupuestos();
  } catch(e) {
    var cl = document.getElementById('cuentas-list');
    if (cl) cl.innerHTML = '<div style="color:var(--os-error);font-size:var(--os-text-sm);padding:1rem;">Error cargando datos: ' + esc(e.message) + '</div>';
  }
}

wireForm('cuenta-form', 'cuentas', 'cuenta-form-msg');
wireForm('deuda-form', 'deudas', 'deuda-form-msg');
wireForm('porcobrar-form', 'por-cobrar', 'porcobrar-form-msg');
wireForm('gasto-form', 'gastos', 'gasto-form-msg');
wireForm('presupuesto-form', 'presupuestos', 'presupuesto-form-msg');

document.getElementById('filtro-mes').addEventListener('change', renderGastos);
document.getElementById('filtro-cat').addEventListener('change', renderGastos);
document.getElementById('filtro-mes-clear').addEventListener('click', function(){
  document.getElementById('filtro-mes').value = '';
  renderGastos();
});

loadAll();
</script>
</OSLayout>
