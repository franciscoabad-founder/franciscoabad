---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';

const inputStyle = "background:rgba(232,234,240,0.05);border:1px solid var(--os-line);border-radius:var(--os-r-sm);padding:6px 11px;font-size:12px;color:var(--os-text);font-family:var(--os-font-body);outline:none;";
const selStyle = "background:var(--os-bg-sunken);border:1px solid var(--os-line);border-radius:var(--os-r-sm);padding:6px 11px;font-size:12px;color:var(--os-text);font-family:var(--os-font-body);outline:none;color-scheme:dark;";
const btnStyle = "background:var(--os-accent);color:#fff;border:none;border-radius:var(--os-r-sm);padding:6px 16px;font-size:12px;font-family:var(--os-font-display);font-weight:700;letter-spacing:0.02em;cursor:pointer;white-space:nowrap;flex-shrink:0;display:inline-flex;align-items:center;gap:5px;";
---

<OSLayout title="Comidas">
  <div class="os-fade-up">

    <!-- Header -->
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:0.5rem;flex-wrap:wrap;gap:0.5rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Bitacora</p>
        <h1 class="os-h1">Comidas</h1>
      </div>
      <p id="comida-count" class="os-num" style="font-size:12px;margin:0;">Cargando...</p>
    </div>
    <p style="font-size:12px;color:var(--os-muted);margin:0 0 1.25rem;line-height:1.5;">Bitacora de que y cuando como. El foco son los patrones de alimentacion, no las calorias.</p>

    <!-- Quick-add -->
    <form id="comida-form" class="os-card-2" style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-end;margin-bottom:1.5rem;padding:0.875rem 1rem;">
      <select name="momento" style={selStyle}>
        <option value="desayuno">Desayuno</option>
        <option value="almuerzo">Almuerzo</option>
        <option value="cena">Cena</option>
        <option value="snack">Snack</option>
      </select>
      <input name="descripcion" type="text" placeholder="Que comiste *" required style={inputStyle + "flex:2;min-width:180px;"} />
      <input name="notas" type="text" placeholder="Nota (como me senti, contexto...)" style={inputStyle + "flex:1;min-width:140px;"} />
      <input name="foto_url" type="url" placeholder="URL de foto (opcional)" style={inputStyle + "flex:1;min-width:140px;"} />
      <input name="fecha" type="datetime-local" style={selStyle} />
      <button type="submit" style={btnStyle}><span class="material-symbols-outlined" style="font-size:15px;">add</span>Registrar</button>
      <p id="comida-form-msg" style="font-size:11px;color:var(--os-error);width:100%;margin:0;display:none;"></p>
    </form>

    <!-- Historial agrupado por dia -->
    <div id="comidas-list" style="display:flex;flex-direction:column;gap:1.5rem;">
      <div class="os-card-2" style="color:var(--os-muted);font-size:13px;">Cargando...</div>
    </div>
  </div>
</OSLayout>

<script is:inline>
var comidas = [];
var MOMENTO_LABEL = { desayuno:'Desayuno', almuerzo:'Almuerzo', cena:'Cena', snack:'Snack' };
var MOMENTO_COLOR = { desayuno:'#B5985A', almuerzo:'#6B7AE8', cena:'#3B4ED9', snack:'#6B7AE8' };

function esc(s) {
  return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function dayKey(iso) { return new Date(iso).toISOString().slice(0,10); }
function dayLabel(key) {
  var today = new Date().toISOString().slice(0,10);
  var d = new Date(key + 'T12:00:00');
  var label = d.toLocaleDateString('es', { weekday:'long', day:'numeric', month:'long' });
  if (key === today) return 'Hoy · ' + label;
  return label.charAt(0).toUpperCase() + label.slice(1);
}
function timeLabel(iso) {
  return new Date(iso).toLocaleTimeString('es', { hour:'2-digit', minute:'2-digit' });
}

async function delComida(id) {
  if (!confirm('Eliminar este registro?')) return;
  try {
    var res = await fetch('/api/os/comidas?id=' + encodeURIComponent(id), { method:'DELETE' });
    if (!res.ok) throw new Error(String(res.status));
    await loadComidas();
  } catch(e) { alert('Error: ' + e.message); }
}

function render() {
  var list = document.getElementById('comidas-list');
  if (!comidas.length) {
    list.innerHTML = '<div style="background:var(--os-surface-2);border:1px solid var(--os-line-soft);border-radius:var(--os-r-card);padding:1.5rem;text-align:center;color:var(--os-muted);font-size:12px;">Sin registros aun. Anota tu primera comida arriba.</div>';
    return;
  }
  var byDay = {};
  comidas.forEach(function(c) {
    var k = dayKey(c.fecha);
    if (!byDay[k]) byDay[k] = [];
    byDay[k].push(c);
  });
  var days = Object.keys(byDay).sort().reverse();
  list.innerHTML = days.map(function(k) {
    var items = byDay[k].slice().sort(function(a,b){ return new Date(b.fecha) - new Date(a.fecha); });
    return '<div>'
      + '<p style="font-family:Montserrat,sans-serif;font-size:10px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--os-muted);margin:0 0 8px;">' + esc(dayLabel(k)) + '</p>'
      + '<div style="display:flex;flex-direction:column;gap:6px;">'
      + items.map(function(c) {
          var mom = c.momento || 'snack';
          var color = MOMENTO_COLOR[mom] || '#6B7280';
          var foto = c.foto_url
            ? '<a href="' + esc(c.foto_url) + '" target="_blank" rel="noopener" style="flex-shrink:0;"><img src="' + esc(c.foto_url) + '" alt="" style="width:46px;height:46px;object-fit:cover;border-radius:6px;border:1px solid var(--os-line);" /></a>'
            : '';
          return '<div style="display:flex;align-items:center;gap:12px;background:var(--os-surface-2);border:1px solid var(--os-line-soft);border-left:3px solid ' + color + ';border-radius:var(--os-r-card);padding:0.65rem 0.875rem;">'
            + foto
            + '<div style="flex:1;min-width:0;">'
              + '<div style="display:flex;align-items:center;gap:8px;margin-bottom:2px;">'
                + '<span style="font-size:9px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:' + color + ';font-family:Montserrat,sans-serif;">' + esc(MOMENTO_LABEL[mom] || mom) + '</span>'
                + '<span style="font-size:10px;color:var(--os-muted);font-family:var(--os-font-mono);">' + esc(timeLabel(c.fecha)) + '</span>'
              + '</div>'
              + '<p style="font-size:13px;color:var(--os-text);margin:0;line-height:1.4;">' + esc(c.descripcion || '') + '</p>'
              + (c.notas ? '<p style="font-size:11px;color:var(--os-muted);margin:3px 0 0;line-height:1.4;">' + esc(c.notas) + '</p>' : '')
            + '</div>'
            + '<button onclick="delComida(\'' + c.id + '\')" title="Eliminar" style="background:none;border:none;color:var(--os-muted);cursor:pointer;font-size:18px;padding:0;line-height:1;flex-shrink:0;" class="material-symbols-outlined">close</button>'
            + '</div>';
        }).join('')
      + '</div></div>';
  }).join('');
}

async function loadComidas() {
  try {
    var res = await fetch('/api/os/comidas');
    if (!res.ok) throw new Error(String(res.status));
    var data = await res.json();
    comidas = data.comidas || [];
    var countEl = document.getElementById('comida-count');
    if (countEl) countEl.textContent = comidas.length + ' registros';
    render();
  } catch(e) {
    var list = document.getElementById('comidas-list');
    if (list) list.innerHTML = '<div style="color:var(--os-error);font-size:12px;padding:1rem;">Error: ' + esc(e.message) + '</div>';
  }
}

var form = document.getElementById('comida-form');
if (form) {
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    var msg = document.getElementById('comida-form-msg');
    if (msg) msg.style.display = 'none';
    var fd = new FormData(form);
    var fechaVal = fd.get('fecha');
    var body = {
      momento: fd.get('momento'),
      descripcion: fd.get('descripcion'),
      notas: fd.get('notas') || null,
      foto_url: fd.get('foto_url') || null,
      fecha: fechaVal ? new Date(fechaVal).toISOString() : null,
    };
    try {
      var res = await fetch('/api/os/comidas', {
        method:'POST', headers:{ 'Content-Type':'application/json' }, body: JSON.stringify(body),
      });
      var jsonR = await res.json();
      if (!res.ok) throw new Error(jsonR.error || String(res.status));
      form.reset();
      await loadComidas();
    } catch(err) {
      if (msg) { msg.textContent = 'Error: ' + err.message; msg.style.display = 'block'; }
    }
  });
}

loadComidas();
</script>
