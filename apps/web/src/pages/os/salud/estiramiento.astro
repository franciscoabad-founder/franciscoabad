import OSSaludEstiramiento from '../../../os/components/salud/OSSaludEstiramiento';
import OSSaludNav from '../../../os/components/salud/OSSaludNav.astro';
---

<OSLayout title="Estiramiento">
  <div class="os-fade-up">
    <div style="margin-bottom:1rem;">
      <p class="os-eyebrow" style="margin-bottom:6px;">Salud · Estiramiento</p>
