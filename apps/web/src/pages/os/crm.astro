---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
import { leads } from '../../os/data/crm';
import type { CRMEtapa } from '../../os/data/types';

const etapas: CRMEtapa[] = ['prospecto', 'contacto', 'propuesta', 'negociacion', 'cerrado'];
const etapaLabel: Record<CRMEtapa, string> = {
  prospecto: 'Prospecto',
  contacto: 'Contacto',
  propuesta: 'Propuesta',
  negociacion: 'Negociacion',
  cerrado: 'Cerrado',
};
const etapaColor: Record<CRMEtapa, string> = {
  prospecto: '#6B7280',
  contacto: '#6B7AE8',
  propuesta: '#3B4ED9',
  negociacion: '#B5985A',
  cerrado: '#6B7AE8',
};

const byEtapa = (e: CRMEtapa) => leads.filter((l) => l.etapa === e);
---

<OSLayout title="CRM">
  <div>
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1.75rem;">
      <h1 style="font-size:1.375rem;font-weight:700;color:#F4F6F8;margin:0;">CRM</h1>
      <p style="font-size:12px;color:#6B7280;margin:0;">{leads.length} leads activos</p>
    </div>

    <!-- Kanban scroll horizontal -->
    <div style="display:flex;gap:12px;overflow-x:auto;padding-bottom:1rem;min-height:400px;">
      {etapas.map((etapa) => {
        const cols = byEtapa(etapa);
        return (
          <div style="min-width:220px;flex-shrink:0;display:flex;flex-direction:column;gap:8px;">
            <div style={`display:flex;align-items:center;gap:6px;padding:0 2px;margin-bottom:4px;`}>
              <span style={`width:8px;height:8px;border-radius:50%;background:${etapaColor[etapa]};flex-shrink:0;`}></span>
              <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#6B7280;margin:0;">{etapaLabel[etapa]}</p>
              <span style="font-size:11px;color:#6B7280;margin-left:auto;">{cols.length}</span>
            </div>

            {cols.length === 0 && (
              <div style="background:#131F4A;border:1px dashed rgba(232,234,240,0.1);border-radius:8px;padding:1.25rem;text-align:center;">
                <p style="font-size:12px;color:#6B7280;margin:0;">Sin leads</p>
              </div>
            )}

            {cols.map((lead) => (
              <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:8px;padding:0.875rem;">
                <p style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600;color:#F4F6F8;margin:0 0 2px;">{lead.empresa}</p>
                <p style="font-size:11px;color:#6B7280;margin:0 0 0.5rem;">{lead.contacto}</p>
                {lead.valor && (
                  <p style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:700;color:#B5985A;margin:0 0 0.5rem;">{lead.valor}</p>
                )}
                <p style="font-size:11px;color:#E8EAF0;margin:0 0 0.375rem;line-height:1.35;">{lead.siguiente_accion}</p>
                <p style="font-size:10px;color:#6B7280;margin:0;">{lead.ultimo_contacto}</p>
              </div>
            ))}
          </div>
        );
      })}
    </div>
  </div>
</OSLayout>
