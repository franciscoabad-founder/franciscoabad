---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
import OSHabitos from '../../os/components/OSHabitos';
import OSPaletteSwitch from '../../os/components/OSPaletteSwitch.astro';
import '../../styles/os-conductual.css';
---

<OSLayout title="Hábitos">
  <div class="os-fade-up" data-modulo="habitos" data-palette="marca-light">
    <OSPaletteSwitch />
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:1rem;position:relative;z-index:2;">
      <div>
        <p class="m-eyebrow">Sistema // Hábitos</p>
        <h1 class="m-h1">Hábitos</h1>
      </div>
      <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap;">
        <a
          href="/os/juego"
          style="font-size:14px;color:var(--m-accent);text-decoration:none;font-family:var(--m-font-rounded);font-weight:700;white-space:nowrap;"
        >
          Juego →
        </a>
        <a
          href="/os/habitos/journeys"
          style="font-size:14px;color:var(--m-accent);text-decoration:none;font-family:var(--m-font-rounded);font-weight:700;white-space:nowrap;"
        >
          Ver journeys →
        </a>
      </div>
    </div>
    <div style="position:relative;z-index:2;">
      <OSHabitos client:load />
    </div>
  </div>
</OSLayout>
