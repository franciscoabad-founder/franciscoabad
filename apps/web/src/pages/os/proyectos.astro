---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
import OSProyectos from '../../os/components/OSProyectos';
import PageHeader from '../../os/components/ui/PageHeader';
---

<OSLayout title="Proyectos">
  <div class="os-fade-up">

    <PageHeader
      eyebrow="Growth OS"
      title="Proyectos"
      subtitle="El Project Stack ordena por prioridad, no por orden de llegada. Un proyecto pausado no recibe atencion a proposito: esa es la funcion del stack."
    />

    <OSProyectos client:load />
  </div>
</OSLayout>
