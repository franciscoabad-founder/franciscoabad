---
import OSLayout from '../../layouts/OSLayout.astro';
import { datosSalud } from '../../os/data/salud';

const { pasos, pasos_meta, sueno_horas, sueno_meta, peso_kg, agua_litros, agua_meta, habitos, fecha } = datosSalud;

const pct = (actual: number, meta: number) => Math.min(100, Math.round((actual / meta) * 100));

const metricas = [
  { label: 'Pasos', valor: pasos.toLocaleString('es-EC'), meta: pasos_meta.toLocaleString('es-EC'), p: pct(pasos, pasos_meta), unidad: 'pasos' },
  { label: 'Sueno', valor: sueno_horas + 'h', meta: sueno_meta + 'h', p: pct(sueno_horas, sueno_meta), unidad: 'horas' },
  { label: 'Agua', valor: agua_litros + 'L', meta: agua_meta + 'L', p: pct(agua_litros, agua_meta), unidad: 'litros' },
  { label: 'Peso', valor: peso_kg + ' kg', meta: '--', p: 100, unidad: 'kg' },
];
---

<OSLayout title="Salud">
  <div>
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1.75rem;">
      <h1 style="font-size:1.375rem;font-weight:700;color:#F4F6F8;margin:0;">Salud</h1>
      <p style="font-size:12px;color:#6B7280;margin:0;">{fecha}</p>
    </div>

    <!-- Metricas -->
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px;margin-bottom:1.5rem;">
      {metricas.map((m) => (
        <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1rem 1.125rem;">
          <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#6B7280;margin:0 0 0.375rem;">{m.label}</p>
          <p style="font-family:'Montserrat',sans-serif;font-size:1.375rem;font-weight:700;color:#B5985A;margin:0 0 0.25rem;">{m.valor}</p>
          <p style="font-size:11px;color:#6B7280;margin:0 0 0.5rem;">meta: {m.meta}</p>
          {m.meta !== '--' && (
            <div style="height:3px;background:rgba(232,234,240,0.08);border-radius:2px;overflow:hidden;">
              <div style={`height:100%;width:${m.p}%;background:${m.p >= 100 ? '#6B7AE8' : '#3B4ED9'};border-radius:2px;`}></div>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Habitos y rachas -->
    <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1.25rem;">
      <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#6B7280;margin:0 0 0.875rem;">Habitos de hoy</p>
      <div style="display:flex;flex-direction:column;gap:6px;">
        {habitos.map((h) => (
          <div style="display:flex;align-items:center;gap:12px;padding:0.5rem 0.75rem;border-radius:6px;background:rgba(232,234,240,0.03);">
            <span style={`width:18px;height:18px;border-radius:4px;border:2px solid ${h.completado ? '#3B4ED9' : 'rgba(232,234,240,0.2)'};background:${h.completado ? '#3B4ED9' : 'transparent'};display:flex;align-items:center;justify-content:center;flex-shrink:0;`}>
              {h.completado && (
                <svg width="9" height="7" viewBox="0 0 9 7" fill="none">
                  <polyline points="1,3.5 3.5,6 8,1" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              )}
            </span>
            <span style={`font-size:13px;flex:1;${h.completado ? 'color:#E8EAF0;' : 'color:#6B7280;'}`}>{h.label}</span>
            {h.racha > 0 && (
              <span style="font-family:'Montserrat',sans-serif;font-size:12px;font-weight:700;color:#B5985A;">{h.racha}d</span>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</OSLayout>
