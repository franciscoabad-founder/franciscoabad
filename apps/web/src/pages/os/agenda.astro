---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
import { eventos } from '../../os/data/agenda';

const fallbackEventos = JSON.stringify(eventos);
---

<OSLayout title="Agenda">
  <div class="os-fade-up">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:1.25rem;flex-wrap:wrap;gap:0.75rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Calendario</p>
        <h1 class="os-h1">Agenda</h1>
        <p style="font-size:var(--os-text-sm);color:var(--os-muted);margin:4px 0 0;">Eventos y recordatorios por dia</p>
      </div>
      <p id="agenda-count" class="os-num" style="font-size:12px;margin:0;">Cargando...</p>
    </div>

    <form id="agenda-form" class="os-card-2" style="display:grid;grid-template-columns:minmax(180px,1.4fr) minmax(150px,1fr) minmax(150px,1fr);gap:8px;align-items:end;margin-bottom:1.25rem;padding:0.875rem 1rem;">
      <input name="titulo" type="text" placeholder="Titulo del evento *" required
        class="os-input" style="font-size:var(--os-text-sm);padding:6px 11px;" />
      <input name="inicio" type="datetime-local" required
        class="os-input" style="font-size:var(--os-text-sm);padding:6px 11px;color-scheme:light dark;" />
      <input name="fin" type="datetime-local" required
        class="os-input" style="font-size:var(--os-text-sm);padding:6px 11px;color-scheme:light dark;" />
      <input name="ubicacion" type="text" placeholder="Ubicacion"
        class="os-input" style="font-size:var(--os-text-sm);padding:6px 11px;" />
      <input name="descripcion" type="text" placeholder="Descripcion"
        class="os-input" style="font-size:var(--os-text-sm);padding:6px 11px;" />
      <button type="submit" class="os-btn" style="padding:6px 16px;font-size:var(--os-text-sm);justify-content:center;">
        <span class="material-symbols-outlined" style="font-size:16px;">add</span>
        Crear evento
      </button>
      <p id="agenda-form-msg" style="font-size:var(--os-text-xs);color:var(--os-error);grid-column:1 / -1;margin:0;display:none;"></p>
    </form>

    <div id="agenda-list" style="display:flex;flex-direction:column;gap:1.5rem;">
      <div class="os-card-2" style="padding:1rem;color:var(--os-muted);font-size:13px;">Cargando...</div>
    </div>
  </div>

  <style>
    @media (max-width: 900px) {
      #agenda-form { grid-template-columns: 1fr; }
      #agenda-form > button[type="submit"] { width: 100%; }
    }
  </style>
</OSLayout>

<script is:inline define:vars={{ fallbackEventos }}>
var fallbackAgenda = JSON.parse(fallbackEventos);
var agendaEventos = [];

function esc(s) {
  return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function toIso(value) {
  if (!value) return '';
  var date = new Date(value);
  return Number.isNaN(date.getTime()) ? value : date.toISOString();
}
function pad(n) {
  return String(n).padStart(2, '0');
}
function fallbackToEvento(e) {
  var inicio = e.fecha + 'T' + e.hora + ':00';
  return {
    id: e.id,
    titulo: e.titulo,
    inicio: inicio,
    fin: inicio,
    ubicacion: e.con || '',
    descripcion: e.duracion || '',
    tipo: e.tipo || 'reunion',
  };
}
function normalizeEvento(e) {
  if (e.inicio) return e;
  return fallbackToEvento(e);
}
function eventDate(e) {
  return String(e.inicio || '').slice(0, 10) || 'Sin fecha';
}
function timeLabel(iso) {
  if (!iso) return '';
  var d = new Date(iso);
  if (Number.isNaN(d.getTime())) return String(iso).slice(11, 16);
  return pad(d.getHours()) + ':' + pad(d.getMinutes());
}
function durationLabel(e) {
  var start = new Date(e.inicio);
  var end = new Date(e.fin);
  if (Number.isNaN(start.getTime()) || Number.isNaN(end.getTime())) return '';
  var mins = Math.max(0, Math.round((end.getTime() - start.getTime()) / 60000));
  if (!mins) return '';
  if (mins < 60) return mins + ' min';
  var hours = Math.floor(mins / 60);
  var rest = mins % 60;
  return hours + ' h' + (rest ? ' ' + rest + ' min' : '');
}
function dateLabel(fecha) {
  if (fecha === 'Sin fecha') return fecha;
  var today = new Date().toISOString().slice(0, 10);
  var tomorrow = new Date();
  tomorrow.setDate(tomorrow.getDate() + 1);
  var tomorrowStr = tomorrow.toISOString().slice(0, 10);
  var d = new Date(fecha + 'T12:00:00');
  var label = d.toLocaleDateString('es', { weekday:'short', day:'numeric', month:'short' });
  if (fecha === today) return 'Hoy, ' + label;
  if (fecha === tomorrowStr) return 'Manana, ' + label;
  return label;
}
function tipoMeta(e) {
  var titulo = String(e.titulo || '').toLowerCase();
  if (titulo.indexOf('deadline') >= 0) return { color:'var(--os-champagne)', icon:'notifications', label:'Recordatorio' };
  return { color:'var(--os-accent)', icon:'groups', label:'Evento' };
}
function renderAgenda(eventos, usingFallback) {
  var list = document.getElementById('agenda-list');
  var count = document.getElementById('agenda-count');
  if (!list) return;
  var normalized = eventos.map(normalizeEvento).sort(function(a, b) {
    return String(a.inicio || '').localeCompare(String(b.inicio || ''));
  });
  if (count) {
    count.textContent = normalized.length + (normalized.length === 1 ? ' evento' : ' eventos') + (usingFallback ? ' de muestra' : '');
  }
  if (!normalized.length) {
    list.innerHTML = '<div class="os-card-2" style="padding:1.75rem;text-align:center;color:var(--os-muted);font-size:var(--os-text-sm);">Sin eventos para el rango consultado.</div>';
    return;
  }
  var byDate = {};
  normalized.forEach(function(e) {
    var fecha = eventDate(e);
    if (!byDate[fecha]) byDate[fecha] = [];
    byDate[fecha].push(e);
  });
  list.innerHTML = Object.keys(byDate).sort().map(function(fecha) {
    return '<div>'
      + '<p class="os-section-title" style="margin:0 0 0.625rem;">' + esc(dateLabel(fecha)) + '</p>'
      + '<div style="display:flex;flex-direction:column;gap:6px;">'
      + byDate[fecha].map(function(e) {
          var meta = tipoMeta(e);
          var details = [e.ubicacion, e.descripcion].filter(Boolean).join(' · ');
          return '<div class="os-card-2 os-card-interactive" style="display:flex;align-items:flex-start;gap:12px;padding:0.75rem 1rem;">'
            + '<div style="min-width:48px;text-align:right;flex-shrink:0;">'
            + '<p class="os-mono" style="font-size:13px;font-weight:700;color:var(--os-text);margin:0;">' + esc(timeLabel(e.inicio)) + '</p>'
            + '<p style="font-size:11px;color:var(--os-muted);margin:1px 0 0;">' + esc(durationLabel(e)) + '</p>'
            + '</div>'
            + '<div style="width:2px;min-width:2px;border-radius:2px;background:' + meta.color + ';align-self:stretch;flex-shrink:0;"></div>'
            + '<div style="flex:1;min-width:0;">'
            + '<p style="font-size:14px;font-weight:500;color:var(--os-text);margin:0 0 2px;line-height:1.3;">' + esc(e.titulo) + '</p>'
            + (details ? '<p style="font-size:12px;color:var(--os-muted);margin:0;">' + esc(details) + '</p>' : '')
            + '</div>'
            + '<span style="display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:700;color:' + meta.color + ';flex-shrink:0;font-family:var(--os-font-display);letter-spacing:0.05em;text-transform:uppercase;white-space:nowrap;">'
            + '<span class="material-symbols-outlined" style="font-size:14px;color:' + meta.color + ';">' + meta.icon + '</span>'
            + esc(meta.label)
            + '</span>'
            + '</div>';
        }).join('')
      + '</div></div>';
  }).join('');
}
async function loadAgenda() {
  try {
    var res = await fetch('/api/os/agenda');
    var data = await res.json();
    if (!res.ok) throw new Error(data.error || String(res.status));
    agendaEventos = Array.isArray(data.eventos) ? data.eventos : [];
    if (agendaEventos.length) {
      renderAgenda(agendaEventos, false);
    } else {
      renderAgenda(fallbackAgenda, true);
    }
  } catch(e) {
    renderAgenda(fallbackAgenda, true);
  }
}

var form = document.getElementById('agenda-form');
if (form) {
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    var msg = document.getElementById('agenda-form-msg');
    if (msg) msg.style.display = 'none';
    var fd = new FormData(form);
    var body = {
      titulo: fd.get('titulo'),
      inicio: toIso(fd.get('inicio')),
      fin: toIso(fd.get('fin')),
      ubicacion: fd.get('ubicacion') || undefined,
      descripcion: fd.get('descripcion') || undefined,
    };
    try {
      var res = await fetch('/api/os/agenda', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      var json = await res.json();
      if (!res.ok || json.ok === false) throw new Error(json.error || String(res.status));
      form.reset();
      await loadAgenda();
    } catch(err) {
      if (msg) {
        msg.textContent = 'Error: ' + err.message;
        msg.style.display = 'block';
      }
    }
  });
}

loadAgenda();
</script>
