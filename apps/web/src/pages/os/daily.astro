---
import OSLayout from '../../layouts/OSLayout.astro';
import { datosDaily } from '../../os/data/daily';
import OSChecklist from '../../os/components/OSChecklist';

const { principios, semana, rutina_am, check_10min, pm_close, reglas } = datosDaily;

const tipoColor: Record<string, string> = {
  maker:   '#3B4ED9',
  manager: '#6B7280',
  off:     '#6B7280',
};
const tipoBg: Record<string, string> = {
  maker:   'rgba(59,78,217,0.15)',
  manager: 'rgba(232,234,240,0.06)',
  off:     'rgba(232,234,240,0.03)',
};
const tipoLabel: Record<string, string> = {
  maker:   'Maker',
  manager: 'Manager',
  off:     'Off',
};
---

<OSLayout title="Daily OS">
  <div>
    <h1 style="font-size:1.375rem;font-weight:700;color:#F4F6F8;margin:0 0 1.75rem;">Daily OS</h1>

    <!-- Principios -->
    <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1.25rem;margin-bottom:1rem;">
      <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#6B7280;margin:0 0 0.875rem;">Mis principios</p>
      <ol style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:6px;">
        {principios.map((p, i) => (
          <li style="display:flex;align-items:flex-start;gap:10px;">
            <span style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:700;color:#3B4ED9;min-width:16px;padding-top:2px;">{i + 1}</span>
            <span style="font-size:14px;color:#E8EAF0;line-height:1.4;">{p}</span>
          </li>
        ))}
      </ol>
    </div>

    <!-- Semana Maker / Manager -->
    <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1.25rem;margin-bottom:1rem;">
      <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#6B7280;margin:0 0 0.875rem;">Mi semana Maker / Manager</p>
      <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:6px;">
        {semana.map((d) => (
          <div style={`background:${tipoBg[d.tipo]};border:1px solid ${d.tipo === 'maker' ? 'rgba(59,78,217,0.2)' : 'rgba(232,234,240,0.07)'};border-radius:8px;padding:0.625rem 0.5rem;text-align:center;`}>
            <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;color:#6B7280;margin:0 0 4px;">{d.dia.slice(0,3)}</p>
            <p style={`font-family:'Montserrat',sans-serif;font-size:9px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:${tipoColor[d.tipo]};margin:0 0 4px;`}>{tipoLabel[d.tipo]}</p>
            <p style="font-size:10px;color:#6B7280;margin:0;line-height:1.3;">{d.descripcion}</p>
          </div>
        ))}
      </div>
      <div style="margin-top:0.75rem;display:flex;gap:1.5rem;">
        <div style="display:flex;align-items:center;gap:5px;">
          <span style="width:8px;height:8px;border-radius:2px;background:#3B4ED9;display:block;"></span>
          <span style="font-size:11px;color:#6B7280;">Maker: crear y entregar (Mie, Vie, Sab)</span>
        </div>
        <div style="display:flex;align-items:center;gap:5px;">
          <span style="width:8px;height:8px;border-radius:2px;background:rgba(232,234,240,0.2);display:block;"></span>
          <span style="font-size:11px;color:#6B7280;">Manager: reuniones y tramites (Lun, Mar, Jue)</span>
        </div>
      </div>
    </div>

    <!-- Mi dia + rutinas -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">

      <!-- Rutina AM -->
      <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1.25rem;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:0.875rem;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#B5985A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
          <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#6B7280;margin:0;">Ancla AM</p>
        </div>
        <OSChecklist items={rutina_am} client:load />
      </div>

      <!-- Check 10 min + PM Close + reglas -->
      <div style="display:flex;flex-direction:column;gap:1rem;">
        <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1.25rem;">
          <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#6B7280;margin:0 0 0.75rem;">Check de 10 min</p>
          <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:7px;">
            {check_10min.map((q) => (
              <li style="display:flex;align-items:flex-start;gap:8px;">
                <span style="color:#6B7AE8;flex-shrink:0;margin-top:2px;">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                </span>
                <span style="font-size:13px;color:#E8EAF0;line-height:1.4;">{q}</span>
              </li>
            ))}
          </ul>
        </div>

        <div style="background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:12px;padding:1.25rem;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:0.875rem;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6B7AE8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
            <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#6B7280;margin:0;">Cierre PM</p>
          </div>
          <OSChecklist items={pm_close} client:load />
        </div>

        <!-- Reglas innegociables -->
        <div style="background:#131F4A;border:1px solid rgba(59,78,217,0.2);border-radius:12px;padding:1rem 1.25rem;">
          <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#6B7AE8;margin:0 0 0.625rem;">Reglas</p>
          <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:6px;">
            {reglas.map((r) => (
              <li style="font-size:13px;color:#E8EAF0;line-height:1.4;padding-left:14px;position:relative;">
                <span style="position:absolute;left:0;top:7px;width:5px;height:1px;background:#3B4ED9;display:block;"></span>
                {r}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</OSLayout>
