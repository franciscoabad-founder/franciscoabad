---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
import { proyectos } from '../../os/data/proyectos';

const statusLabel: Record<string, string> = {
  activo: 'Activo',
  pausado: 'Pausado',
  'por-lanzar': 'Por lanzar',
  'en-curso': 'En curso',
};
const statusColor: Record<string, string> = {
  activo: '#6B7AE8',
  pausado: '#6B7280',
  'por-lanzar': '#B5985A',
  'en-curso': '#3B4ED9',
};
const tipoLabel: Record<string, string> = {
  consultora: 'Consultora',
  startup: 'Startup',
  ong: 'ONG',
  'for-profit': 'For-profit',
  cliente: 'Cliente',
  negocio: 'Negocio',
  marca: 'Marca',
};

const conMaker = proyectos.filter((p) => p.recibe_maker);
const sinMaker = proyectos.filter((p) => !p.recibe_maker);
---

<OSLayout title="Proyectos">
  <div>
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1.75rem;flex-wrap:wrap;gap:0.5rem;">
      <h1 style="font-size:1.375rem;font-weight:700;color:#F4F6F8;margin:0;">Proyectos</h1>
      <div style="display:flex;gap:1rem;">
        <div style="display:flex;align-items:center;gap:5px;">
          <span style="width:8px;height:8px;border-radius:2px;background:#3B4ED9;display:block;"></span>
          <span style="font-size:11px;color:#6B7280;">Recibe tiempo Maker</span>
        </div>
        <div style="display:flex;align-items:center;gap:5px;">
          <span style="width:8px;height:8px;border-radius:2px;background:rgba(232,234,240,0.12);display:block;"></span>
          <span style="font-size:11px;color:#6B7280;">Solo dias Manager</span>
        </div>
      </div>
    </div>

    <!-- Lineas con tiempo Maker -->
    <p style="font-family:'Montserrat',sans-serif;font-size:9px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:#6B7280;margin:0 0 0.5rem;">Con tiempo Maker (Mie / Vie / Sab)</p>
    <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:1.5rem;">
      {conMaker.map((p) => (
        <div class="proj-card" data-tag={p.id} data-nombre={p.nombre} style={`background:#131F4A;border:1px solid ${p.motor ? 'rgba(59,78,217,0.3)' : 'rgba(232,234,240,0.09)'};border-left:3px solid #3B4ED9;border-radius:12px;padding:1rem 1.25rem;cursor:pointer;transition:border-color .15s;`}>
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:0.4rem;flex-wrap:wrap;">
            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
              <h3 style="font-family:'Montserrat',sans-serif;font-size:15px;font-weight:700;color:#F4F6F8;margin:0;">{p.nombre}</h3>
              {p.motor && (
                <span style="font-family:'Montserrat',sans-serif;font-size:9px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;background:rgba(59,78,217,0.2);color:#6B7AE8;padding:2px 7px;border-radius:4px;">Motor</span>
              )}
              <span style={`font-size:11px;color:${statusColor[p.status]};font-weight:500;`}>{statusLabel[p.status]}</span>
              <span style="font-size:11px;color:#6B7280;">{tipoLabel[p.tipo]}</span>
            </div>
            {p.deadline && (
              <span style="font-size:11px;color:#B5985A;white-space:nowrap;flex-shrink:0;">{p.deadline}</span>
            )}
          </div>
          <p style="font-size:13px;color:#6B7280;margin:0 0 0.5rem;line-height:1.4;">{p.descripcion}</p>
          <div style="display:flex;align-items:flex-start;gap:8px;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#3B4ED9" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><polyline points="9 18 15 12 9 6"/></svg>
            <p style="font-size:13px;color:#E8EAF0;margin:0;line-height:1.4;">{p.siguiente_accion}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Solo dias Manager -->
    {sinMaker.length > 0 && (
      <div>
        <p style="font-family:'Montserrat',sans-serif;font-size:9px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:#6B7280;margin:0 0 0.5rem;">Solo coordinacion Manager (Lun / Mar / Jue)</p>
        <div style="display:flex;flex-direction:column;gap:8px;">
          {sinMaker.map((p) => (
            <div class="proj-card" data-tag={p.id} data-nombre={p.nombre} style="background:#131F4A;border:1px solid rgba(232,234,240,0.07);border-left:3px solid rgba(232,234,240,0.15);border-radius:12px;padding:1rem 1.25rem;opacity:0.8;cursor:pointer;transition:border-color .15s;">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:0.4rem;flex-wrap:wrap;">
                <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                  <h3 style="font-family:'Montserrat',sans-serif;font-size:15px;font-weight:700;color:#F4F6F8;margin:0;">{p.nombre}</h3>
                  <span style={`font-size:11px;color:${statusColor[p.status]};font-weight:500;`}>{statusLabel[p.status]}</span>
                  <span style="font-size:11px;color:#6B7280;">{tipoLabel[p.tipo]}</span>
                </div>
              </div>
              <p style="font-size:13px;color:#6B7280;margin:0 0 0.5rem;line-height:1.4;">{p.descripcion}</p>
              <div style="display:flex;align-items:flex-start;gap:8px;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><polyline points="9 18 15 12 9 6"/></svg>
                <p style="font-size:13px;color:#6B7280;margin:0;line-height:1.4;">{p.siguiente_accion}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>

  <!-- Modal: brief + pendientes del cerebro -->
  <div id="proj-modal" style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(10,16,32,0.82);backdrop-filter:blur(4px);padding:1.5rem;overflow:auto;" role="dialog" aria-modal="true">
    <div style="max-width:680px;margin:0 auto;background:#0E1738;border:1px solid rgba(59,78,217,0.3);border-radius:14px;padding:1.75rem;position:relative;min-height:160px;">
      <button id="proj-modal-close" aria-label="Cerrar" style="position:absolute;top:14px;right:16px;background:none;border:none;color:#6B7280;font-size:22px;cursor:pointer;line-height:1;padding:0;">x</button>
      <div id="proj-modal-content" style="color:#F4F6F8;"></div>
    </div>
  </div>
</OSLayout>

<script is:inline>
  function esc(s) {
    return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  function mdToHtml(md) {
    return esc(md)
      .replace(/^#### (.+)$/gm, '<b style="color:#6B7AE8;font-size:12px;">$1</b>')
      .replace(/^### (.+)$/gm, '<b style="color:#94A3B8;font-size:13px;">$1</b>')
      .replace(/^## (.+)$/gm, '<b style="color:#F4F6F8;font-size:14px;">$1</b>')
      .replace(/^# (.+)$/gm, '<b style="color:#F4F6F8;font-size:16px;">$1</b>')
      .replace(/\*\*(.+?)\*\*/g, '<b>$1</b>')
      .replace(/^[-*] (.+)$/gm, '<span style="display:block;padding-left:12px;">• $1</span>')
      .replace(/\n\n/g, '<br><br>')
      .replace(/\n/g, '<br>');
  }

  var modal = document.getElementById('proj-modal');
  var modalContent = document.getElementById('proj-modal-content');
  var modalClose = document.getElementById('proj-modal-close');

  function closeModal() { if (modal) modal.style.display = 'none'; }
  if (modalClose) modalClose.addEventListener('click', closeModal);
  if (modal) modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });

  function openProyecto(tag, nombre) {
    if (!modal || !modalContent) return;
    modal.style.display = 'block';
    modalContent.innerHTML = '<p style="color:#6B7280;font-size:13px;">Leyendo el cerebro...</p>';
    fetch('/api/brain/proyecto?tag=' + encodeURIComponent(tag))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.error) {
          modalContent.innerHTML = '<p style="color:#F87171;font-size:13px;">Error: ' + esc(data.error) + '</p>';
          return;
        }
        var header = '<p style="font-size:10px;color:#6B7AE8;letter-spacing:0.1em;text-transform:uppercase;font-family:Montserrat,sans-serif;margin:0 0 6px;">Proyecto · #' + esc(tag) + '</p>'
          + '<h2 style="font-size:1.25rem;font-weight:700;color:#F4F6F8;margin:0 0 1rem;font-family:Montserrat,sans-serif;">' + esc(nombre) + '</h2>';
        var pgs = data.paginas || [];
        if (!pgs.length) {
          modalContent.innerHTML = header + '<p style="color:#6B7280;font-size:13px;">No hay paginas en el cerebro con el tag <b>#' + esc(tag) + '</b> todavia. Captura notas con ese tag y apareceran aqui.</p>';
          return;
        }
        var body = pgs.map(function(p) {
          var pend = (p.pendientes || []).length
            ? '<div style="margin-top:10px;background:rgba(59,78,217,0.08);border:1px solid rgba(59,78,217,0.2);border-radius:8px;padding:10px 12px;">'
                + '<p style="font-family:Montserrat,sans-serif;font-size:9px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#6B7AE8;margin:0 0 6px;">Pendientes</p>'
                + (p.pendientes.map(function(x){ return '<div style="display:flex;gap:7px;align-items:flex-start;font-size:13px;color:#E8EAF0;line-height:1.5;margin-bottom:3px;"><span style="color:#3B4ED9;flex-shrink:0;">▸</span><span>' + esc(x) + '</span></div>'; }).join(''))
              + '</div>'
            : '';
          return '<div style="border-top:1px solid rgba(232,234,240,0.1);padding-top:14px;margin-top:14px;">'
            + '<div style="display:flex;align-items:baseline;justify-content:space-between;gap:10px;margin-bottom:6px;">'
              + '<h3 style="font-size:14px;font-weight:700;color:#F4F6F8;margin:0;font-family:Montserrat,sans-serif;">' + esc(p.titulo) + '</h3>'
              + '<span style="font-size:10px;color:rgba(107,114,128,0.7);flex-shrink:0;">' + esc(p.fecha) + '</span>'
            + '</div>'
            + (p.brief ? '<div style="font-size:13px;color:#CBD5E1;line-height:1.65;">' + mdToHtml(p.brief) + '</div>' : '<p style="font-size:12px;color:#6B7280;">Sin brief.</p>')
            + pend
            + '</div>';
        }).join('');
        modalContent.innerHTML = header + body;
      })
      .catch(function() { modalContent.innerHTML = '<p style="color:#F87171;font-size:13px;">Error al leer el cerebro.</p>'; });
  }

  document.querySelectorAll('.proj-card').forEach(function(card) {
    card.addEventListener('click', function() {
      openProyecto(this.getAttribute('data-tag'), this.getAttribute('data-nombre'));
    });
    card.addEventListener('mouseenter', function() { this.style.borderColor = 'rgba(59,78,217,0.55)'; });
    card.addEventListener('mouseleave', function() { this.style.borderColor = ''; });
  });
</script>
