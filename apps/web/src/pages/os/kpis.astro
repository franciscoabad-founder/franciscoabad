---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
import OSKpis from '../../os/components/OSKpis';
import PageHeader from '../../os/components/ui/PageHeader';
---

<OSLayout title="KPIs">
  <div class="os-fade-up">

    <PageHeader eyebrow="Tablero" title="KPIs" subtitle="Metricas reales, registradas a mano o por API. Sin cifras inventadas." />

    <OSKpis client:load />

    <!-- Nota sobre los numeros -->
    <div style="margin-top:2rem;">
      <p class="os-section-title">Nota sobre los numeros</p>
      <div class="os-card-2 os-card-accent">
        <div style="display:flex;align-items:flex-start;gap:10px;">
          <span class="material-symbols-outlined" style="font-size:18px;color:var(--os-accent-light);flex-shrink:0;margin-top:1px;">info</span>
          <p style="font-size:13px;color:var(--os-text-2);margin:0;line-height:1.6;">
            Los valores en <span style="color:var(--os-champagne);font-weight:600;">champagne</span> son el ultimo valor registrado por KPI. Las tendencias comparan contra el registro anterior. Registra un valor nuevo desde cada tarjeta cuando tengas el numero real.
          </p>
        </div>
      </div>
    </div>
  </div>
</OSLayout>
