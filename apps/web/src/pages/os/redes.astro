---
export const prerender = false;

import OSLayout from '../../layouts/OSLayout.astro';
import OSContenidoEditor from '../../os/components/OSContenidoEditor';

const redLabel: Record<string, string> = { instagram: 'Instagram', facebook: 'Facebook', tiktok: 'TikTok', linkedin: 'LinkedIn', youtube: 'YouTube', x: 'X' };
const redColor: Record<string, string> = { instagram: 'var(--os-accent-light)', facebook: 'var(--os-accent)', tiktok: 'var(--os-text)', linkedin: 'var(--os-accent)', youtube: 'var(--os-muted)', x: 'var(--os-text)' };
const redIcon: Record<string, string>  = { instagram: 'photo_camera', facebook: 'thumb_up', tiktok: 'music_note', linkedin: 'work', youtube: 'smart_display', x: 'tag' };
const PLATAFORMAS = ['instagram', 'tiktok', 'linkedin', 'facebook', 'youtube', 'x'];

const trendIcon: Record<string, string> = {
  up:   '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--os-champagne)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>',
  down: '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#D4537E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 17 13.5 8.5 8.5 13.5 2 7"/><polyline points="16 17 22 17 22 11"/></svg>',
  flat: '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--os-muted)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>',
};
---

<OSLayout title="Redes">
  <div class="os-fade-up">

    <!-- Header -->
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:0.5rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Distribucion</p>
        <h1 class="os-h1">Redes y Contenido</h1>
      </div>
      <span id="redes-estado-pill" class="os-pill os-tag" style="background:var(--os-fill-subtle);">Cargando...</span>
    </div>

    <!-- Social insight cards -->
    <div id="redes-social-grid" class="os-social-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:10px;margin-bottom:1.5rem;">
      <div class="os-card-2" style="color:var(--os-muted);font-size:12px;">Cargando...</div>
    </div>

    <!-- Top posts -->
    <div class="os-card-2" style="margin-bottom:1.5rem;padding:1.25rem;">
      <p class="os-section-title" style="margin:0 0 0.875rem;">Top posts (30 dias)</p>
      <div id="redes-top-posts" style="display:flex;flex-direction:column;gap:8px;">
        <p style="font-size:12px;color:var(--os-muted);margin:0;">Cargando...</p>
      </div>
    </div>

    <!-- Content editor -->
    <OSContenidoEditor client:load />
  </div>

  <style>
    @media (max-width: 820px) {
      .os-social-grid { grid-template-columns: 1fr !important; }
    }
  </style>
</OSLayout>

<script is:inline define:vars={{ redLabel, redColor, redIcon, PLATAFORMAS }}>
var trendIconMap = {
  up:   '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--os-champagne)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>',
  down: '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#D4537E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 17 13.5 8.5 8.5 13.5 2 7"/><polyline points="16 17 22 17 22 11"/></svg>',
  flat: '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--os-muted)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>',
};

function esc(s) {
  return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function fmt(n) {
  return (Number(n) || 0).toLocaleString('es-EC');
}

function sparkline(serie) {
  if (!serie || serie.length < 2) return '';
  var vals = serie.map(function(p) { return Number(p.seguidores) || 0; });
  var min = Math.min.apply(null, vals);
  var max = Math.max.apply(null, vals);
  var w = 220, h = 32;
  var pts = vals.map(function(v, i) {
    var x = vals.length > 1 ? (i / (vals.length - 1)) * w : 0;
    var y = max === min ? h / 2 : h - ((v - min) / (max - min)) * h;
    return x.toFixed(1) + ',' + y.toFixed(1);
  }).join(' ');
  return '<svg viewBox="0 0 ' + w + ' ' + h + '" width="100%" height="' + h + '" preserveAspectRatio="none">'
    + '<polyline points="' + pts + '" fill="none" stroke="var(--os-accent)" stroke-width="1.5" />'
    + '</svg>';
}

function deltaVs7dias(serie) {
  if (!serie || serie.length < 2) return { valor: 0, tendencia: 'flat' };
  var actual = Number(serie[serie.length - 1].seguidores) || 0;
  var idx = Math.max(0, serie.length - 8);
  var anterior = Number(serie[idx].seguidores) || 0;
  var valor = actual - anterior;
  var tendencia = valor > 0 ? 'up' : (valor < 0 ? 'down' : 'flat');
  return { valor: valor, tendencia: tendencia };
}

function cardVacia(red) {
  return '<div class="os-card-2" style="border-top:2px solid var(--os-line);opacity:0.6;">'
    + '<div style="display:flex;align-items:center;gap:6px;margin-bottom:0.75rem;">'
      + '<span class="material-symbols-outlined" style="font-size:15px;color:var(--os-muted);">' + esc(redIcon[red]) + '</span>'
      + '<p style="font-family:var(--os-font-display);font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--os-muted);margin:0;">' + esc(redLabel[red]) + '</p>'
    + '</div>'
    + '<p style="font-size:12px;color:var(--os-muted);margin:0;">Sin conectar</p>'
    + '</div>';
}

function cardRed(red, info) {
  var color = redColor[red];
  var actual = info.actual || {};
  var delta = deltaVs7dias(info.serie);
  var deltaColor = delta.tendencia === 'up' ? 'var(--os-champagne)' : (delta.tendencia === 'down' ? '#D4537E' : 'var(--os-muted)');
  var deltaSigno = delta.valor > 0 ? '+' : '';
  return '<div class="os-card-2" style="border-top:2px solid ' + color + ';">'
    + '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.875rem;">'
      + '<p style="display:flex;align-items:center;gap:6px;font-family:var(--os-font-display);font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:' + color + ';margin:0;">'
        + '<span class="material-symbols-outlined" style="font-size:15px;">' + esc(redIcon[red]) + '</span>'
        + esc(redLabel[red])
      + '</p>'
    + '</div>'
    + '<div style="display:flex;align-items:flex-end;gap:8px;margin-bottom:6px;">'
      + '<p class="os-num" style="font-size:1.5rem;margin:0;line-height:1;">' + fmt(actual.seguidores) + '</p>'
      + '<span style="display:flex;align-items:center;gap:3px;font-size:11px;color:' + deltaColor + ';font-family:var(--os-font-mono);margin-bottom:2px;">'
        + trendIconMap[delta.tendencia]
        + deltaSigno + fmt(delta.valor)
      + '</span>'
    + '</div>'
    + '<p class="os-kpi-label" style="margin:0 0 0.75rem;">Seguidores</p>'
    + '<div style="margin-bottom:0.75rem;">' + sparkline(info.serie) + '</div>'
    + '<div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;padding-top:0.75rem;border-top:1px solid var(--os-line-soft);">'
      + '<div>'
        + '<p class="os-kpi-label" style="margin:0 0 3px;">Alcance</p>'
        + '<p class="os-num" style="font-size:1rem;margin:0;">' + fmt(actual.alcance) + '</p>'
      + '</div>'
      + '<div>'
        + '<p class="os-kpi-label" style="margin:0 0 3px;">Interacciones</p>'
        + '<p class="os-num" style="font-size:1rem;margin:0;">' + fmt(actual.interacciones) + '</p>'
      + '</div>'
    + '</div>'
    + '</div>';
}

function renderGrid(plataformas) {
  var wrap = document.getElementById('redes-social-grid');
  wrap.innerHTML = PLATAFORMAS.map(function(red) {
    return plataformas[red] ? cardRed(red, plataformas[red]) : cardVacia(red);
  }).join('');

  var hayDatos = Object.keys(plataformas).length > 0;
  var pill = document.getElementById('redes-estado-pill');
  pill.textContent = hayDatos ? 'En vivo' : 'Conectar APIs';
}

function postHtml(p) {
  var interacciones = (Number(p.likes) || 0) + (Number(p.comentarios) || 0) + (Number(p.compartidos) || 0);
  var titulo = p.titulo || p.url || p.post_id;
  var contenido = p.url
    ? '<a href="' + esc(p.url) + '" target="_blank" rel="noopener" style="color:var(--os-text);text-decoration:none;">' + esc(titulo) + '</a>'
    : esc(titulo);
  return '<div style="display:flex;align-items:center;justify-content:space-between;gap:10px;background:var(--os-surface-2);border:1px solid var(--os-line-soft);border-radius:var(--os-r-card);padding:0.6rem 0.8rem;">'
    + '<div style="min-width:0;flex:1;">'
      + '<p style="font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--os-muted);margin:0 0 3px;">' + esc(redLabel[p.plataforma] || p.plataforma) + '</p>'
      + '<p style="font-size:12px;margin:0;line-height:1.4;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + contenido + '</p>'
    + '</div>'
    + '<div style="display:flex;gap:12px;flex-shrink:0;font-family:var(--os-font-mono);font-size:11px;color:var(--os-muted);">'
      + '<span>' + fmt(p.likes) + ' likes</span>'
      + '<span>' + fmt(p.comentarios) + ' com.</span>'
      + '<span>' + fmt(p.compartidos) + ' comp.</span>'
    + '</div>'
    + '</div>';
}

function renderPosts(posts) {
  var wrap = document.getElementById('redes-top-posts');
  if (!posts.length) {
    wrap.innerHTML = '<p style="font-size:12px;color:var(--os-muted);margin:0;">Sin posts registrados aun.</p>';
    return;
  }
  wrap.innerHTML = posts.map(postHtml).join('');
}

async function cargarRedes() {
  try {
    var res = await fetch('/api/os/redes-metricas?dias=30');
    if (!res.ok) throw new Error(String(res.status));
    var data = await res.json();
    renderGrid(data.plataformas || {});
    renderPosts(data.posts_top || []);
  } catch (e) {
    document.getElementById('redes-social-grid').innerHTML = '<div style="color:var(--os-error);font-size:12px;padding:1rem;">Error: ' + esc(e.message) + '</div>';
    document.getElementById('redes-estado-pill').textContent = 'Conectar APIs';
  }
}

cargarRedes();
</script>
