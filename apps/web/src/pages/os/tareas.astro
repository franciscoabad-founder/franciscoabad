---
import OSLayout from '../../layouts/OSLayout.astro';
import { tareas } from '../../os/data/tareas';

const proyectos = [...new Set(tareas.map((t) => t.proyecto))];

const prioridadColor: Record<string, string> = {
  alta: '#3B4ED9',
  media: '#6B7AE8',
  baja: '#6B7280',
};
const statusColor: Record<string, string> = {
  pendiente: '#6B7280',
  'en-curso': '#6B7AE8',
  completada: '#B5985A',
};
const statusLabel: Record<string, string> = {
  pendiente: 'Pendiente',
  'en-curso': 'En curso',
  completada: 'Completada',
};
---

<OSLayout title="Tareas">
  <div>
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1.75rem;">
      <h1 style="font-size:1.375rem;font-weight:700;color:#F4F6F8;margin:0;">Tareas</h1>
      <p style="font-size:12px;color:#6B7280;margin:0;">{tareas.filter(t => t.status !== 'completada').length} pendientes</p>
    </div>

    <div style="display:flex;flex-direction:column;gap:1.5rem;">
      {proyectos.map((proyecto) => {
        const tareasProyecto = tareas.filter((t) => t.proyecto === proyecto);
        return (
          <div>
            <p style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#6B7280;margin:0 0 0.5rem;">{proyecto}</p>
            <div style="display:flex;flex-direction:column;gap:4px;">
              {tareasProyecto.map((t) => (
                <div style="display:flex;align-items:flex-start;gap:10px;background:#131F4A;border:1px solid rgba(232,234,240,0.09);border-radius:6px;padding:0.625rem 0.875rem;">
                  <span style={`width:3px;height:3px;border-radius:50%;background:${prioridadColor[t.prioridad]};flex-shrink:0;margin-top:7px;`}></span>
                  <div style="flex:1;min-width:0;">
                    <p style={`font-size:13px;color:${t.status === 'completada' ? '#6B7280' : '#F4F6F8'};margin:0;line-height:1.4;text-decoration:${t.status === 'completada' ? 'line-through' : 'none'};`}>{t.label}</p>
                    {t.deadline && (
                      <p style="font-size:11px;color:#B5985A;margin:2px 0 0;">{t.deadline}</p>
                    )}
                  </div>
                  <span style={`font-size:10px;font-weight:600;color:${statusColor[t.status]};flex-shrink:0;font-family:'Montserrat',sans-serif;letter-spacing:0.05em;`}>
                    {statusLabel[t.status]}
                  </span>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</OSLayout>
