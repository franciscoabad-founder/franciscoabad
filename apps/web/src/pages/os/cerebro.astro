---
export const prerender = false;

import OSLayout from '../../layouts/OSLayout.astro';
import OSGraphBrain from '../../os/components/OSGraphBrain';
---

<OSLayout title="Cerebro">
  <div class="os-fade-up">

    <!-- Header -->
    <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.75rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Conocimiento</p>
        <h1 class="os-h1">Cerebro</h1>
      </div>
      <p id="nota-count" class="os-num" style="font-size:13px;margin:0;">Cargando...</p>
    </div>

    <!-- Search -->
    <div class="os-glass" style="position:relative;display:flex;align-items:center;margin-bottom:1.25rem;padding:0 0.5rem 0 1rem;">
      <span class="material-symbols-outlined" style="font-size:20px;color:var(--os-muted);pointer-events:none;flex-shrink:0;">search</span>
      <input
        id="brain-search"
        type="text"
        placeholder="Buscar en gbrain..."
        autocomplete="off"
        style="flex:1;background:transparent;border:none;padding:0.875rem 0.625rem;font-size:14px;color:var(--os-text);font-family:var(--os-font-body);box-sizing:border-box;outline:none;"
      />
    </div>

    <!-- Search results -->
    <div id="search-results" style="display:none;margin-bottom:1.5rem;"></div>

    <!-- Force graph -->
    <div class="os-card os-card-accent graph-card" style="margin-bottom:1.5rem;box-shadow:var(--os-shadow-card);">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:1rem;">
        <span class="material-symbols-outlined" style="font-size:18px;color:var(--os-accent-light);">hub</span>
        <p class="os-section-title" style="margin:0;">Grafo de ideas</p>
      </div>
      <OSGraphBrain client:load />
    </div>

    <!-- Notes grid -->
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:0.875rem;">
      <span class="material-symbols-outlined" style="font-size:18px;color:var(--os-accent-light);">psychology</span>
      <p class="os-section-title" style="margin:0;">Notas indexadas</p>
      <span id="notes-meta" style="font-size:11px;color:var(--os-muted);margin-left:auto;"></span>
    </div>
    <div id="notes-tags" style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:0.875rem;"></div>
    <div id="notes-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px;">
      <div class="os-card" style="color:var(--os-muted);font-size:13px;">
        Cargando notas...
      </div>
    </div>
    <nav id="notes-pager" aria-label="Paginacion de notas" style="display:none;justify-content:center;align-items:center;gap:4px;flex-wrap:wrap;margin-top:1.25rem;"></nav>
  </div>

  <!-- Note modal -->
  <div id="note-modal" style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(7,17,50,0.82);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);padding:1.5rem;overflow:auto;" role="dialog" aria-modal="true">
    <div id="note-modal-inner" class="os-glass" style="max-width:680px;margin:0 auto;border-color:var(--os-line-accent);padding:1.75rem;position:relative;min-height:200px;box-shadow:var(--os-shadow-modal);">
      <button id="note-modal-close" aria-label="Cerrar" style="position:absolute;top:14px;right:16px;background:none;border:none;color:var(--os-muted);font-size:22px;cursor:pointer;line-height:1;padding:0;">x</button>
      <div id="note-modal-content" style="color:var(--os-text);"></div>
    </div>
  </div>

  <style>
    .nota-card:hover { border-color: var(--os-line-accent) !important; }
    .result-card:hover { border-color: var(--os-line-accent) !important; }
    #brain-search::placeholder { color: var(--os-muted); }

    @media (max-width: 820px) {
      #notes-grid { grid-template-columns: 1fr !important; }
      .graph-card { padding: 0.875rem !important; }
    }
  </style>
</OSLayout>

<script is:inline>
  // ---- helpers ----
  function esc(s) {
    return String(s || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function mdToHtml(md) {
    return md
      .replace(/^#### (.+)$/gm, '<b style="color:var(--os-accent-light);font-size:12px;">$1</b>')
      .replace(/^### (.+)$/gm, '<b style="color:var(--os-text-2);font-size:13px;">$1</b>')
      .replace(/^## (.+)$/gm, '<b style="color:var(--os-text);font-size:14px;">$1</b>')
      .replace(/^# (.+)$/gm, '<b style="color:var(--os-text);font-size:16px;">$1</b>')
      .replace(/\*\*(.+?)\*\*/g, '<b>$1</b>')
      .replace(/`(.+?)`/g, '<code style="background:rgba(59,78,217,0.18);padding:1px 5px;border-radius:3px;font-size:12px;">$1</code>')
      .replace(/^- (.+)$/gm, '<span style="display:block;padding-left:12px;">• $1</span>')
      .replace(/^\d+\. (.+)$/gm, '<span style="display:block;padding-left:12px;">$1</span>')
      .replace(/\n\n/g, '<br><br>')
      .replace(/\n/g, '<br>');
  }

  // ---- modal ----
  var modal = document.getElementById('note-modal');
  var modalContent = document.getElementById('note-modal-content');
  var modalClose = document.getElementById('note-modal-close');

  function openNote(slug) {
    if (!modal || !modalContent) return;
    modal.style.display = 'block';
    modalContent.innerHTML = '<p style="color:var(--os-muted);font-size:13px;">Cargando...</p>';
    fetch('/api/brain/note?slug=' + encodeURIComponent(slug))
      .then(function(r) { return r.json(); })
      .then(function(n) {
        if (n.error) { modalContent.innerHTML = '<p style="color:var(--os-error);">Error: ' + esc(n.error) + '</p>'; return; }
        var tagsHtml = (n.tags || []).map(function(t) {
          return '<span style="font-size:11px;color:var(--os-muted);background:var(--os-fill-subtle);padding:2px 8px;border-radius:4px;margin-right:4px;">#' + esc(t) + '</span>';
        }).join('');
        modalContent.innerHTML =
          '<p style="font-size:11px;color:var(--os-accent-light);letter-spacing:0.14em;text-transform:uppercase;font-family:var(--os-font-display);font-weight:700;margin:0 0 10px;">' + esc(n.tipo) + '</p>'
          + '<h2 style="font-size:1.1rem;font-weight:700;color:var(--os-text);margin:0 0 10px;line-height:1.3;font-family:var(--os-font-display);">' + esc(n.titulo) + '</h2>'
          + '<div style="margin-bottom:14px;flex-wrap:wrap;">' + tagsHtml + '</div>'
          + '<p style="font-size:11px;color:var(--os-muted);margin:0 0 16px;">' + esc(n.fecha) + '</p>'
          + '<div style="font-size:13px;color:var(--os-text-2);line-height:1.7;border-top:1px solid var(--os-line);padding-top:16px;">' + mdToHtml(n.contenido || '') + '</div>';
      })
      .catch(function() { modalContent.innerHTML = '<p style="color:var(--os-error);">Error al cargar la nota.</p>'; });
  }

  if (modalClose) modalClose.addEventListener('click', function() { modal.style.display = 'none'; });
  if (modal) modal.addEventListener('click', function(e) { if (e.target === modal) modal.style.display = 'none'; });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && modal) modal.style.display = 'none'; });

  // ---- notes grid (paginado + filtro por tag) ----
  var TAGS = ['braintech','cortex','taskr','rafik','arazza','codeis','kronek','fonquito','flow','os','panchoatlas','gbrain','hermes','n8n','vps','marca','personal','familia','salud','finanzas','contenido','gtm'];
  var notesState = { page: 1, tag: '' };

  function renderTagChips() {
    var wrap = document.getElementById('notes-tags');
    if (!wrap) return;
    var chips = [{ v: '', label: 'Todas' }].concat(TAGS.map(function(t) { return { v: t, label: '#' + t }; }));
    wrap.innerHTML = chips.map(function(c) {
      var active = notesState.tag === c.v;
      return '<button data-tag="' + c.v + '" class="tag-chip" style="font-size:11px;padding:4px 12px;min-height:32px;border-radius:99px;cursor:pointer;font-family:var(--os-font-display);'
        + 'border:1px solid ' + (active ? 'var(--os-accent)' : 'var(--os-line)') + ';'
        + 'background:' + (active ? 'var(--os-accent)' : 'transparent') + ';'
        + 'color:' + (active ? '#fff' : 'var(--os-muted)') + ';">'
        + c.label + '</button>';
    }).join('');
    wrap.querySelectorAll('.tag-chip').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var t = this.dataset.tag || '';
        notesState.tag = (notesState.tag === t) ? '' : t;
        notesState.page = 1;
        renderTagChips();
        loadNotes();
      });
    });
  }

  function renderPager(page, pages) {
    var pager = document.getElementById('notes-pager');
    if (!pager) return;
    if (pages <= 1) { pager.style.display = 'none'; pager.innerHTML = ''; return; }
    pager.style.display = 'flex';

    // Ventana de numeros estilo Google: hasta 10 paginas visibles centradas en la actual.
    var start = Math.max(1, Math.min(page - 4, pages - 9));
    var end = Math.min(pages, start + 9);

    var btn = function(label, target, opts) {
      opts = opts || {};
      var current = opts.current;
      var disabled = opts.disabled;
      return '<button data-page="' + target + '" ' + (disabled ? 'disabled' : '')
        + ' style="min-width:36px;min-height:36px;padding:4px 10px;border-radius:8px;font-size:13px;font-family:var(--os-font-display);cursor:' + (disabled ? 'default' : 'pointer') + ';'
        + 'border:1px solid ' + (current ? 'var(--os-accent)' : 'transparent') + ';'
        + 'background:' + (current ? 'var(--os-accent)' : 'transparent') + ';'
        + 'color:' + (current ? '#fff' : (disabled ? 'var(--os-line)' : 'var(--os-accent-light)')) + ';">'
        + label + '</button>';
    };

    var html = btn('&lsaquo;', page - 1, { disabled: page <= 1 });
    for (var p = start; p <= end; p++) html += btn(String(p), p, { current: p === page });
    html += btn('&rsaquo;', page + 1, { disabled: page >= pages });
    pager.innerHTML = html;

    pager.querySelectorAll('button[data-page]').forEach(function(b) {
      if (b.disabled) return;
      b.addEventListener('click', function() {
        notesState.page = Number(this.dataset.page);
        loadNotes();
        var grid = document.getElementById('notes-grid');
        if (grid) grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  }

  async function loadNotes() {
    var grid = document.getElementById('notes-grid');
    if (grid) grid.style.opacity = '0.5';
    try {
      var params = 'limit=12&page=' + notesState.page + (notesState.tag ? '&tag=' + encodeURIComponent(notesState.tag) : '');
      var res = await fetch('/api/brain/notes?' + params);
      if (!res.ok) throw new Error(String(res.status));
      var data = await res.json();
      var notes = data.notes;

      var countEl = document.getElementById('nota-count');
      if (countEl) countEl.textContent = (data.total || notes.length) + ' notas indexadas';

      var metaEl = document.getElementById('notes-meta');
      if (metaEl) {
        metaEl.textContent = data.total + ' notas' + (notesState.tag ? ' con #' + notesState.tag : '') + ' · página ' + data.page + ' de ' + data.pages;
      }

      renderPager(data.page, data.pages);

      if (!grid) return;
      grid.style.opacity = '1';
      if (!notes.length) {
        grid.innerHTML = '<div class="os-card" style="color:var(--os-muted);font-size:13px;">Sin notas' + (notesState.tag ? ' con #' + esc(notesState.tag) : '') + '.</div>';
        return;
      }

      grid.innerHTML = notes.map(function(n) {
        var tagsHtml = (n.tags || []).map(function(t) {
          return '<span style="font-size:11px;color:var(--os-muted);background:var(--os-fill-subtle);padding:2px 7px;border-radius:4px;">#' + esc(t) + '</span>';
        }).join('');
        return '<div data-slug="' + esc(n.slug) + '" class="nota-card os-card" style="display:flex;flex-direction:column;gap:0.5rem;cursor:pointer;transition:border-color .15s;">'
          + '<h3 style="font-family:var(--os-font-display);font-size:13px;font-weight:700;color:var(--os-text);margin:0;line-height:1.3;">' + esc(n.titulo) + '</h3>'
          + '<p style="font-size:12px;color:var(--os-muted);margin:0;line-height:1.45;flex:1;">' + esc(n.resumen) + '</p>'
          + '<div style="display:flex;gap:4px;flex-wrap:wrap;">' + tagsHtml + '</div>'
          + '<p style="font-size:11px;color:var(--os-muted);margin:0;">' + esc(n.fecha) + '</p>'
          + '</div>';
      }).join('');

      // click handlers
      grid.querySelectorAll('.nota-card').forEach(function(card) {
        card.addEventListener('click', function() { openNote(this.dataset.slug); });
      });
    } catch (e) {
      if (grid) {
        grid.style.opacity = '1';
        grid.innerHTML = '<div style="color:var(--os-error);font-size:12px;padding:1rem;">Error cargando notas.</div>';
      }
    }
  }

  // ---- search ----
  var searchTimer;
  var searchInput = document.getElementById('brain-search');

  function renderResults(results) {
    var resultsEl = document.getElementById('search-results');
    if (!resultsEl) return;
    if (!results || !results.length) {
      resultsEl.innerHTML = '<p style="color:var(--os-muted);font-size:12px;padding:0.25rem 0;">Sin resultados.</p>';
      return;
    }
    resultsEl.innerHTML = '<div style="display:flex;flex-direction:column;gap:8px;">'
      + results.map(function(r) {
        return '<div data-slug="' + esc(r.slug) + '" class="result-card os-card" style="padding:0.875rem 1rem;cursor:pointer;transition:border-color .15s;">'
          + '<h4 style="font-size:13px;font-weight:700;color:var(--os-text);margin:0 0 4px;font-family:var(--os-font-display);">' + esc(r.titulo) + '</h4>'
          + '<p style="font-size:12px;color:var(--os-muted);margin:0;line-height:1.4;">' + esc(r.resumen) + '</p>'
          + '</div>';
      }).join('')
      + '</div>';

    resultsEl.querySelectorAll('.result-card').forEach(function(card) {
      card.addEventListener('click', function() { openNote(this.dataset.slug); });
    });
  }

  async function runSearch(q) {
    var resultsEl = document.getElementById('search-results');
    if (!resultsEl) return;
    resultsEl.style.display = 'block';
    resultsEl.innerHTML = '<p style="color:var(--os-muted);font-size:12px;padding:0.25rem 0;">Buscando...</p>';
    try {
      var res = await fetch('/api/brain/search?q=' + encodeURIComponent(q));
      if (!res.ok) throw new Error(String(res.status));
      var data = await res.json();
      renderResults(data.results);
    } catch {
      resultsEl.innerHTML = '<p style="color:var(--os-error);font-size:12px;">Error al buscar.</p>';
    }
  }

  if (searchInput) {
    searchInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        clearTimeout(searchTimer);
        var q = this.value.trim();
        var resultsEl = document.getElementById('search-results');
        if (!q) { if (resultsEl) { resultsEl.style.display = 'none'; resultsEl.innerHTML = ''; } return; }
        runSearch(q);
      }
    });

    searchInput.addEventListener('input', function() {
      clearTimeout(searchTimer);
      var q = this.value.trim();
      var resultsEl = document.getElementById('search-results');
      if (!q) { if (resultsEl) { resultsEl.style.display = 'none'; resultsEl.innerHTML = ''; } return; }
      searchTimer = setTimeout(function() { runSearch(q); }, 380);
    });
  }

  renderTagChips();
  loadNotes();
</script>
</OSLayout>
