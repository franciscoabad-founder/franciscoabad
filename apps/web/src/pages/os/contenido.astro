---
export const prerender = false;
import OSLayout from '../../layouts/OSLayout.astro';
import { ideas } from '../../os/data/contenido';

const statusColor: Record<string, string> = {
  idea: 'var(--os-muted)',
  'en-produccion': 'var(--os-accent)',
  publicado: 'var(--os-accent-light)',
  archivado: 'var(--os-muted)',
};
const statusLabel: Record<string, string> = {
  idea: 'Idea',
  'en-produccion': 'En produccion',
  publicado: 'Publicado',
  archivado: 'Archivado',
};
const formatoLabel: Record<string, string> = {
  hilo: 'Hilo',
  post: 'Post',
  articulo: 'Articulo',
  video: 'Video',
  newsletter: 'Newsletter',
};
---

<OSLayout title="Contenido">
  <div class="os-fade-up">

    <!-- Header -->
    <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.5rem;">
      <div>
        <p class="os-eyebrow" style="margin-bottom:6px;">Pipeline editorial</p>
        <h1 class="os-h1">Contenido</h1>
      </div>
      <span class="os-pill os-pill-accent">
        <span class="material-symbols-outlined" style="font-size:13px;">edit_note</span>
        <span class="os-num" style="color:inherit;">{ideas.filter(i => i.status === 'en-produccion').length}</span> en produccion
      </span>
    </div>

    <div style="display:flex;flex-direction:column;gap:12px;">
      {ideas.map((idea) => (
        <div class={idea.status === 'en-produccion' ? 'os-card-2 os-card-accent' : 'os-card-2'}>
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:0.75rem;flex-wrap:wrap;">
            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
              <span class="os-tag" style="font-family:var(--os-font-display);font-weight:600;letter-spacing:0.1em;text-transform:uppercase;">
                {formatoLabel[idea.formato]}
              </span>
              <span style={`font-size:11px;font-weight:600;color:${statusColor[idea.status]};`}>
                {statusLabel[idea.status]}
              </span>
            </div>
            {idea.fecha_target && (
              <span class="os-num" style="font-size:11px;white-space:nowrap;">{idea.fecha_target}</span>
            )}
          </div>

          <h3 style="font-family:var(--os-font-display);font-size:14px;font-weight:700;color:var(--os-text);margin:0 0 0.5rem;line-height:1.3;">{idea.titulo}</h3>
          <p style="font-size:13px;color:var(--os-text-2);margin:0 0 0.875rem;line-height:1.45;">{idea.idea_madre}</p>

          <div>
            <p class="os-section-title" style="margin:0 0 0.375rem;">Repurposing</p>
            <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:3px;">
              {idea.repurposing.map((r) => (
                <li style="display:flex;align-items:flex-start;gap:7px;">
                  <span class="material-symbols-outlined" style="font-size:14px;color:var(--os-accent-light);flex-shrink:0;margin-top:1px;">chevron_right</span>
                  <span style="font-size:12px;color:var(--os-text);line-height:1.4;">{r}</span>
                </li>
              ))}
            </ul>
          </div>

          {idea.plataformas.length > 0 && (
            <div style="margin-top:0.75rem;display:flex;gap:5px;flex-wrap:wrap;">
              {idea.plataformas.map((p) => (
                <span class="os-tag">{p}</span>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>

  <style>
    @media (max-width: 820px) {
      .os-card-2 { padding: 1rem; }
    }
  </style>
</OSLayout>
