import OSSaludCuerpo from '../../../os/components/salud/OSSaludCuerpo';
import OSSaludNav from '../../../os/components/salud/OSSaludNav.astro';
---

<OSLayout title="Cuerpo">
  <div class="os-fade-up">
    <div style="margin-bottom:1rem;">
      <p class="os-eyebrow" style="margin-bottom:6px;">Salud · Cuerpo</p>
      <h1 class="os-h1">Cuerpo</h1>
