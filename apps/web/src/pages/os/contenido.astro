---
import OSLayout from '../../layouts/OSLayout.astro';
import { ideas } from '../../os/data/contenido';

const statusColor: Record<string, string> = {
  idea: '#6B7280',
  'en-produccion': '#3B4ED9',
  publicado: '#6B7AE8',
  archivado: '#6B7280',
};
const statusLabel: Record<string, string> = {
  idea: 'Idea',
  'en-produccion': 'En produccion',
  publicado: 'Publicado',
  archivado: 'Archivado',
};
const formatoLabel: Record<string, string> = {
  hilo: 'Hilo',
  post: 'Post',
  articulo: 'Articulo',
  video: 'Video',
  newsletter: 'Newsletter',
};
---

<OSLayout title="Contenido">
  <div>
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1.75rem;">
      <h1 style="font-size:1.375rem;font-weight:700;color:#F4F6F8;margin:0;">Contenido</h1>
      <p style="font-size:12px;color:#6B7280;margin:0;">{ideas.filter(i => i.status === 'en-produccion').length} en produccion</p>
    </div>

    <div style="display:flex;flex-direction:column;gap:12px;">
      {ideas.map((idea) => (
        <div style={`background:#131F4A;border:1px solid ${idea.status === 'en-produccion' ? 'rgba(59,78,217,0.25)' : 'rgba(232,234,240,0.09)'};border-radius:12px;padding:1.25rem;`}>
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:0.75rem;flex-wrap:wrap;">
            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
              <span style="font-family:'Montserrat',sans-serif;font-size:9px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#6B7280;background:rgba(232,234,240,0.06);padding:2px 7px;border-radius:4px;">
                {formatoLabel[idea.formato]}
              </span>
              <span style={`font-size:11px;font-weight:500;color:${statusColor[idea.status]};`}>
                {statusLabel[idea.status]}
              </span>
            </div>
            {idea.fecha_target && (
              <span style="font-size:11px;color:#B5985A;white-space:nowrap;">{idea.fecha_target}</span>
            )}
          </div>

          <h3 style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:700;color:#F4F6F8;margin:0 0 0.5rem;line-height:1.3;">{idea.titulo}</h3>
          <p style="font-size:13px;color:#6B7280;margin:0 0 0.875rem;line-height:1.45;">{idea.idea_madre}</p>

          <div>
            <p style="font-family:'Montserrat',sans-serif;font-size:9px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#6B7280;margin:0 0 0.375rem;">Repurposing</p>
            <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:3px;">
              {idea.repurposing.map((r) => (
                <li style="display:flex;align-items:flex-start;gap:7px;">
                  <span style="color:#3B4ED9;flex-shrink:0;margin-top:3px;">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                  </span>
                  <span style="font-size:12px;color:#E8EAF0;">{r}</span>
                </li>
              ))}
            </ul>
          </div>

          {idea.plataformas.length > 0 && (
            <div style="margin-top:0.75rem;display:flex;gap:5px;flex-wrap:wrap;">
              {idea.plataformas.map((p) => (
                <span style="font-size:10px;color:#6B7280;background:rgba(232,234,240,0.06);padding:2px 7px;border-radius:4px;">{p}</span>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</OSLayout>
